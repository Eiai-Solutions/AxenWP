{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ReZ9e75cGx91H87HNXRScz","type":"tool_result","content":"    94→\n    95→class PostgresChatMessageHistory:\n    96→    \"\"\"Implementa o histórico de mensagens direto via SQLAlchemy (equivalente ao Postgres Chat Memory do n8n).\"\"\"\n    97→    \n    98→    def __init__(self, session_id: str):\n    99→        # A session_id idealmente será o location_id + telefone, por ex: \"location123__+55119999999\"\n   100→        self.session_id = session_id\n   101→        self.max_history = 20 # Mantém o contexto de no máximo N mensagens\n   102→\n   103→    def _fetch_messages_sync(self) -> List[BaseMessage]:\n   104→        \"\"\"Sync DB fetch — meant to be called via asyncio.to_thread().\"\"\"\n   105→        db = SessionLocal()\n   106→        try:\n   107→            records = db.query(ChatHistory).filter(\n   108→                ChatHistory.session_id == self.session_id\n   109→            ).order_by(ChatHistory.id.desc()).limit(self.max_history).all()\n   110→            records.reverse()\n   111→            msgs = []\n   112→            for r in records:\n   113→                if r.message_type == \"human\":\n   114→                    msgs.append(HumanMessage(content=r.content))\n   115→                elif r.message_type == \"ai\":\n   116→                    msgs.append(AIMessage(content=r.content))\n   117→            return msgs\n   118→        finally:\n   119→            db.close()\n   120→\n   121→    async def aget_messages(self) -> List[BaseMessage]:\n   122→        \"\"\"Async wrapper that runs the sync DB query in a thread.\"\"\"\n   123→        return await asyncio.to_thread(self._fetch_messages_sync)\n   124→\n   125→    def _add_message_sync(self, type_: str, content: str) -> None:\n   126→        \"\"\"Sync DB write — meant to be called via asyncio.to_thread().\"\"\"\n   127→        db = SessionLocal()\n   128→        try:\n   129→            history = ChatHistory(\n   130→                session_id=self.session_id,\n   131→                message_type=type_,\n   132→                content=content\n   133→            )\n   134→            db.add(history)\n   135→            db.commit()\n   136→        except Exception as e:\n   137→            logger.error(f\"Erro ao salvar mensagem no histórico: {e}\")\n   138→            db.rollback()\n   139→        finally:\n   140→            db.close()\n   141→\n   142→    async def add_user_message(self, message: str) -> None:\n   143→        await asyncio.to_thread(self._add_message_sync, \"human\", message)\n   144→\n   145→    async def add_ai_message(self, message: str) -> None:\n   146→        await asyncio.to_thread(self._add_message_sync, \"ai\", message)\n   147→\n   148→\n   149→class AIEngine:\n   150→    \"\"\"Core do motor IA integrando OpenRouter via LangChain e Memória persistente PostgreSQL.\"\"\"\n   151→    \n   152→    def __init__(self, agent_data: AIAgent):\n   153→        self.agent_config = agent_data"}]},"parent_tool_use_id":null,"session_id":"0b211461-9717-45cb-96b8-b1f56bba86ea","uuid":"cc4a78f0-65a6-4adb-8937-d7dd5b5d112d","timestamp":"2026-03-20T16:47:20.361Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/services/ai_service.py","content":"\nclass PostgresChatMessageHistory:\n    \"\"\"Implementa o histórico de mensagens direto via SQLAlchemy (equivalente ao Postgres Chat Memory do n8n).\"\"\"\n    \n    def __init__(self, session_id: str):\n        # A session_id idealmente será o location_id + telefone, por ex: \"location123__+55119999999\"\n        self.session_id = session_id\n        self.max_history = 20 # Mantém o contexto de no máximo N mensagens\n\n    def _fetch_messages_sync(self) -> List[BaseMessage]:\n        \"\"\"Sync DB fetch — meant to be called via asyncio.to_thread().\"\"\"\n        db = SessionLocal()\n        try:\n            records = db.query(ChatHistory).filter(\n                ChatHistory.session_id == self.session_id\n            ).order_by(ChatHistory.id.desc()).limit(self.max_history).all()\n            records.reverse()\n            msgs = []\n            for r in records:\n                if r.message_type == \"human\":\n                    msgs.append(HumanMessage(content=r.content))\n                elif r.message_type == \"ai\":\n                    msgs.append(AIMessage(content=r.content))\n            return msgs\n        finally:\n            db.close()\n\n    async def aget_messages(self) -> List[BaseMessage]:\n        \"\"\"Async wrapper that runs the sync DB query in a thread.\"\"\"\n        return await asyncio.to_thread(self._fetch_messages_sync)\n\n    def _add_message_sync(self, type_: str, content: str) -> None:\n        \"\"\"Sync DB write — meant to be called via asyncio.to_thread().\"\"\"\n        db = SessionLocal()\n        try:\n            history = ChatHistory(\n                session_id=self.session_id,\n                message_type=type_,\n                content=content\n            )\n            db.add(history)\n            db.commit()\n        except Exception as e:\n            logger.error(f\"Erro ao salvar mensagem no histórico: {e}\")\n            db.rollback()\n        finally:\n            db.close()\n\n    async def add_user_message(self, message: str) -> None:\n        await asyncio.to_thread(self._add_message_sync, \"human\", message)\n\n    async def add_ai_message(self, message: str) -> None:\n        await asyncio.to_thread(self._add_message_sync, \"ai\", message)\n\n\nclass AIEngine:\n    \"\"\"Core do motor IA integrando OpenRouter via LangChain e Memória persistente PostgreSQL.\"\"\"\n    \n    def __init__(self, agent_data: AIAgent):\n        self.agent_config = agent_data","numLines":60,"startLine":94,"totalLines":332}}}
