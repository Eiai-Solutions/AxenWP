{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AUSaFnsg2ZLP68TJEsJEQt","type":"tool_result","content":"     1→\"\"\"\n     2→Rotas do Admin Dashboard.\n     3→Fornece interface baseada em cookies + jinja2 para gerenciar tenants.\n     4→\"\"\"\n     5→\n     6→from fastapi import APIRouter, Request, Form, Depends, Cookie\n     7→from fastapi.responses import HTMLResponse, RedirectResponse\n     8→from fastapi.templating import Jinja2Templates\n     9→from typing import Optional\n    10→import hmac\n    11→import hashlib\n    12→\n    13→from utils.logger import logger\n    14→from utils.config import settings as app_settings\n    15→from auth.token_manager import token_manager\n    16→from services.zapi_service import zapi_service\n    17→\n    18→router = APIRouter(prefix=\"/admin\", tags=[\"Admin UI\"])\n    19→templates = Jinja2Templates(directory=\"web/templates\")\n    20→\n    21→# Config da senha do Painel — lida via settings (env var ADMIN_PASSWORD)\n    22→_WEAK_PASSWORDS = {\"admin123\", \"admin\", \"password\", \"123456\", \"\"}\n    23→\n    24→\n    25→def _get_admin_password() -> str:\n    26→    \"\"\"Retorna a senha admin configurada. Falha se nao definida em producao.\"\"\"\n    27→    pw = app_settings.admin_password\n    28→    if not pw and app_settings.debug:\n    29→        logger.warning(\"ADMIN_PASSWORD nao definido — usando fallback 'admin123' (modo DEBUG).\")\n    30→        return \"admin123\"\n    31→    if not pw:\n    32→        raise RuntimeError(\n    33→            \"ADMIN_PASSWORD nao configurado. \"\n    34→            \"Defina a variavel de ambiente ADMIN_PASSWORD antes de iniciar em producao.\"\n    35→        )\n    36→    if pw in _WEAK_PASSWORDS:\n    37→        logger.warning(\n    38→            \"ADMIN_PASSWORD e uma senha fraca conhecida. \"\n    39→            \"Troque por uma senha forte em producao.\"\n    40→        )\n    41→    return pw\n    42→\n    43→\n    44→def _make_session_token(password: str) -> str:\n    45→    \"\"\"Deriva um token de sessão seguro a partir da senha (nunca expõe a senha no cookie).\"\"\"\n    46→    return hmac.new(password.encode(), b\"axenwp-admin-session\", hashlib.sha256).hexdigest()\n    47→\n    48→\n    49→def verify_admin(admin_session: Optional[str] = Cookie(None)) -> bool:\n    50→    \"\"\"Valida se o cookie da sessão é um token HMAC válido.\"\"\""}]},"parent_tool_use_id":null,"session_id":"f9152fe4-5e63-4fec-8c83-14cd2076f95a","uuid":"ba7d1524-d041-4890-835f-9686aa08ddbb","timestamp":"2026-03-20T17:10:45.544Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/admin/dashboard.py","content":"\"\"\"\nRotas do Admin Dashboard.\nFornece interface baseada em cookies + jinja2 para gerenciar tenants.\n\"\"\"\n\nfrom fastapi import APIRouter, Request, Form, Depends, Cookie\nfrom fastapi.responses import HTMLResponse, RedirectResponse\nfrom fastapi.templating import Jinja2Templates\nfrom typing import Optional\nimport hmac\nimport hashlib\n\nfrom utils.logger import logger\nfrom utils.config import settings as app_settings\nfrom auth.token_manager import token_manager\nfrom services.zapi_service import zapi_service\n\nrouter = APIRouter(prefix=\"/admin\", tags=[\"Admin UI\"])\ntemplates = Jinja2Templates(directory=\"web/templates\")\n\n# Config da senha do Painel — lida via settings (env var ADMIN_PASSWORD)\n_WEAK_PASSWORDS = {\"admin123\", \"admin\", \"password\", \"123456\", \"\"}\n\n\ndef _get_admin_password() -> str:\n    \"\"\"Retorna a senha admin configurada. Falha se nao definida em producao.\"\"\"\n    pw = app_settings.admin_password\n    if not pw and app_settings.debug:\n        logger.warning(\"ADMIN_PASSWORD nao definido — usando fallback 'admin123' (modo DEBUG).\")\n        return \"admin123\"\n    if not pw:\n        raise RuntimeError(\n            \"ADMIN_PASSWORD nao configurado. \"\n            \"Defina a variavel de ambiente ADMIN_PASSWORD antes de iniciar em producao.\"\n        )\n    if pw in _WEAK_PASSWORDS:\n        logger.warning(\n            \"ADMIN_PASSWORD e uma senha fraca conhecida. \"\n            \"Troque por uma senha forte em producao.\"\n        )\n    return pw\n\n\ndef _make_session_token(password: str) -> str:\n    \"\"\"Deriva um token de sessão seguro a partir da senha (nunca expõe a senha no cookie).\"\"\"\n    return hmac.new(password.encode(), b\"axenwp-admin-session\", hashlib.sha256).hexdigest()\n\n\ndef verify_admin(admin_session: Optional[str] = Cookie(None)) -> bool:\n    \"\"\"Valida se o cookie da sessão é um token HMAC válido.\"\"\"","numLines":50,"startLine":1,"totalLines":297}}}
