{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RD6B9CbmzPNSJLp2MemQg5","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HBEiRUEw52yFBVy3vx3Fc8","name":"Edit","input":{"replace_all":false,"file_path":"/Users/luizantonio/Documents/Antigravity/AxenWP/webhooks/zapi_receiver.py","old_string":"DEFAULT_DEBOUNCE_SECONDS = 1.5\n_ai_pending_tasks: Dict[str, asyncio.Task] = {}   # contact_key -> Task\n_ai_message_buffers: Dict[str, list] = {}          # contact_key -> [(text, is_audio, audio_url), ...]\n_ai_debounce_config: Dict[str, float] = {}         # contact_key -> debounce_seconds\n\n\nasync def _run_ai_response(location_id: str, phone: str, contact_id: str, tenant, contact_key: str):\n    \"\"\"Aguarda o debounce e depois processa a IA com todas as mensagens acumuladas.\"\"\"\n    try:\n        delay = _ai_debounce_config.pop(contact_key, DEFAULT_DEBOUNCE_SECONDS)\n        await asyncio.sleep(delay)\n\n        messages = _ai_message_buffers.pop(contact_key, [])\n        _ai_pending_tasks.pop(contact_key, None)","new_string":"DEFAULT_DEBOUNCE_SECONDS = 1.5\n_ai_pending_tasks: Dict[str, asyncio.Task] = {}   # contact_key -> Task\n_ai_message_buffers: Dict[str, list] = {}          # contact_key -> [(text, is_audio, audio_url), ...]\n_ai_debounce_config: Dict[str, float] = {}         # contact_key -> debounce_seconds\n\n\ndef cleanup_stale_debounce_entries():\n    \"\"\"Remove entries from debounce dicts whose tasks are done (completed/failed).\n    Called periodically via APScheduler to prevent minor memory leaks.\"\"\"\n    stale_keys = [k for k, t in _ai_pending_tasks.items() if t.done()]\n    for key in stale_keys:\n        _ai_pending_tasks.pop(key, None)\n        _ai_message_buffers.pop(key, None)\n        _ai_debounce_config.pop(key, None)\n    if stale_keys:\n        logger.debug(f\"Debounce cleanup: removed {len(stale_keys)} stale entries.\")\n\n\nasync def _run_ai_response(location_id: str, phone: str, contact_id: str, tenant, contact_key: str):\n    \"\"\"Aguarda o debounce e depois processa a IA com todas as mensagens acumuladas.\"\"\"\n    try:\n        delay = _ai_debounce_config.pop(contact_key, DEFAULT_DEBOUNCE_SECONDS)\n        await asyncio.sleep(delay)\n\n        messages = _ai_message_buffers.pop(contact_key, [])\n        _ai_pending_tasks.pop(contact_key, None)"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6475,"cache_read_input_tokens":47106,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6475},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c65344f3-6aa1-4b02-b3ae-01430f0d6aae","uuid":"4232ba62-3660-4ee7-b728-e3db9912edc9"}
