{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VeipQ8oCP9Um9zb4W1A4iC","type":"tool_result","content":"     1→\"\"\"\n     2→Recebe webhooks do Z-API (Inbound).\n     3→Quando o cliente responde no WhatsApp, o Z-API avisa este servidor,\n     4→que formata e insere no GHL via /conversations/messages/inbound\n     5→\"\"\"\n     6→\n     7→import asyncio\n     8→from fastapi import APIRouter, Request, BackgroundTasks, Path\n     9→from typing import Dict, Any\n    10→\n    11→from utils.logger import logger\n    12→from utils.config import settings\n    13→from auth.token_manager import token_manager\n    14→from services.ghl_service import ghl_service\n    15→from services.zapi_service import zapi_service\n    16→\n    17→\n    18→router = APIRouter(prefix=\"/webhook/zapi\", tags=[\"Webhooks Z-API\"])\n    19→\n    20→# ---------------------------------------------------------------------------\n    21→# Debounce: evita múltiplas respostas da IA quando o usuário envia várias\n    22→# mensagens em sequência rápida. As mensagens são acumuladas por DEBOUNCE_SECONDS\n    23→# e processadas juntas em uma única chamada à IA.\n    24→# ---------------------------------------------------------------------------\n    25→DEFAULT_DEBOUNCE_SECONDS = 1.5\n    26→_ai_pending_tasks: Dict[str, asyncio.Task] = {}   # contact_key -> Task\n    27→_ai_message_buffers: Dict[str, list] = {}          # contact_key -> [(text, is_audio, audio_url), ...]\n    28→_ai_debounce_config: Dict[str, float] = {}         # contact_key -> debounce_seconds\n    29→\n    30→\n    31→async def _run_ai_response(location_id: str, phone: str, contact_id: str, tenant, contact_key: str):\n    32→    \"\"\"Aguarda o debounce e depois processa a IA com todas as mensagens acumuladas.\"\"\"\n    33→    try:\n    34→        delay = _ai_debounce_config.pop(contact_key, DEFAULT_DEBOUNCE_SECONDS)\n    35→        await asyncio.sleep(delay)\n    36→\n    37→        messages = _ai_message_buffers.pop(contact_key, [])\n    38→        _ai_pending_tasks.pop(contact_key, None)\n    39→\n    40→        if not messages:\n    41→            return\n    42→\n    43→        # Combina todas as mensagens recebidas na janela de debounce em um único turno\n    44→        combined_text = '\\n'.join(m[0] for m in messages if m[0])\n    45→        is_audio = any(m[1] for m in messages)\n    46→        # Pega a URL do último áudio recebido (para transcrição)\n    47→        audio_url = None\n    48→        for m in reversed(messages):\n    49→            if m[1] and m[2]:  # is_audio=True e tem audio_url\n    50→                audio_url = m[2]\n    51→                break\n    52→\n    53→        if not combined_text:\n    54→            return\n    55→\n    56→        if len(messages) > 1:\n    57→            logger.info(f\"🧠 Debounce: combinando {len(messages)} mensagens de {phone} em uma única chamada IA.\")\n    58→        else:\n    59→            logger.info(f\"🧠 Agente IA ativado para contato {contact_id}. Gerando resposta...\")\n    60→\n    61→        from services.ai_service import ai_service\n    62→\n    63→        ai_response = await ai_service.process_incoming_message(\n    64→            location_id, phone, combined_text, is_audio=is_audio, audio_url=audio_url\n    65→        )\n    66→        if not ai_response:\n    67→            return\n    68→\n    69→        ai_type = ai_response.get(\"type\", \"text\")\n    70→        ai_content = ai_response.get(\"content\", \"\")\n    71→        ai_text_for_ghl = ai_response.get(\"text\", ai_content)\n    72→\n    73→        logger.info(f\"🤖 IA respondeu ({ai_type}), enviando via Z-API...\")\n    74→\n    75→        if ai_type == \"audio\":\n    76→            sent_data = await zapi_service.send_audio(\n    77→                instance_id=tenant.zapi_instance_id,\n    78→                token=tenant.zapi_token,\n    79→                phone=phone,\n    80→                audio_url=ai_content,\n    81→                client_token=tenant.zapi_client_token,\n    82→                record_audio=True\n    83→            )\n    84→            if sent_data:\n    85→                zapi_message_id = sent_data.get(\"zapiMessageId\")\n    86→                outbound_resp = await ghl_service.send_inbound_message(\n    87→                    location_id=location_id,\n    88→                    phone=phone,\n    89→                    message=\"[Mensagem de Áudio enviada pela IA]\",\n    90→                    conversation_provider_id=tenant.conversation_provider_id,\n    91→                    contact_id=contact_id,\n    92→                    direction=\"outbound\"\n    93→                )\n    94→                if outbound_resp and not outbound_resp.get(\"error\"):\n    95→                    ghl_msg_id = outbound_resp.get(\"messageId\") or outbound_resp.get(\"id\")\n    96→                    if ghl_msg_id and zapi_message_id:\n    97→                        token_manager.save_message_mapping(zapi_message_id, ghl_msg_id, location_id)\n    98→        else:\n    99→            import re\n   100→\n   101→            chunks = [c.strip() for c in re.split(r'(?<=[.?!])\\s+(?=[A-Z0-9À-ÖØ-Þ*])', ai_content) if c.strip()]\n   102→            if not chunks:\n   103→                chunks = [ai_content.strip()]\n   104→\n   105→            for i, chunk in enumerate(chunks):\n   106→                delay = 5 if i > 0 else 2\n   107→                if i > 0:\n   108→                    await asyncio.sleep(delay)\n   109→\n   110→                sent_data = await zapi_service.send_text(\n   111→                    instance_id=tenant.zapi_instance_id,\n   112→                    token=tenant.zapi_token,\n   113→                    phone=phone,\n   114→                    message=chunk,\n   115→                    client_token=tenant.zapi_client_token,\n   116→                    delay_typing=delay\n   117→                )\n   118→                if sent_data:\n   119→                    zapi_message_id = sent_data.get(\"zapiMessageId\")\n   120→                    outbound_resp = await ghl_service.send_inbound_message(\n   121→                        location_id=location_id,\n   122→                        phone=phone,\n   123→                        message=chunk,\n   124→                        conversation_provider_id=tenant.conversation_provider_id,\n   125→                        contact_id=contact_id,\n   126→                        direction=\"outbound\"\n   127→                    )\n   128→                    if outbound_resp and not outbound_resp.get(\"error\"):\n   129→                        ghl_msg_id = outbound_resp.get(\"messageId\") or outbound_resp.get(\"id\")\n   130→                        if ghl_msg_id and zapi_message_id:\n   131→                            token_manager.save_message_mapping(zapi_message_id, ghl_msg_id, location_id)\n   132→\n   133→    except asyncio.CancelledError:\n   134→        # Nova mensagem chegou antes do delay expirar — comportamento esperado do debounce\n   135→        logger.debug(f\"IA debounce resetado para {phone} (nova mensagem chegou).\")\n   136→    except Exception as e:\n   137→        logger.error(f\"Erro no processamento IA (debounce): {e}\")\n   138→\n   139→\n   140→async def process_inbound_message(location_id: str, payload: Dict[str, Any]):\n   141→    \"\"\"\n   142→    Processa a mensagem recebida pelo webhook da Z-API.\n   143→    1. Verifica o token do provider para esse location_id.\n   144→    2. Extrai texto e anexos.\n   145→    3. Manda para a API Inbound do GHL.\n   146→    \"\"\"\n   147→    tenant = token_manager.get_tenant(location_id)\n   148→    if not tenant:\n   149→        logger.error(f\"Z-API Inbound abortado: Tenant {location_id} não registrado.\")\n   150→        return\n   151→\n   152→    if not getattr(tenant, 'is_active', True):\n   153→        logger.info(f\"Z-API Inbound abortado: Automação desativada para {location_id}.\")\n   154→        return\n   155→\n   156→    # Apenas logamos as infos para facilitar debug\n   157→    phone = payload.get(\"phone\", \"\")\n   158→    message_type = payload.get(\"type\", \"\")\n   159→    is_group = payload.get(\"isGroup\", False)\n   160→    from_me = payload.get(\"fromMe\", False)\n   161→\n   162→    # Filtrar mensagens indesejadas\n   163→    if is_group:\n   164→        logger.debug(f\"Ignorando mensagem de grupo.\")\n   165→        return\n   166→    if from_me:\n   167→        logger.debug(f\"Ignorando mensagem enviada por nós mesmos.\")\n   168→        return\n   169→    # Aceita apenas eventos de mensagem recebida\n   170→    if message_type not in [\"ReceivedCallback\", \"MessageReceived\"]:\n   171→        logger.debug(f\"Ignorando evento de tipo '{message_type}' (não é mensagem recebida).\")\n   172→        return\n   173→\n   174→    logger.info(f\"Processando inbound Z-API para tenant {location_id} (origem: {phone})\")\n   175→\n   176→    content_message = \"Mensagem recebida do WhatsApp\"\n   177→    attachments = []\n   178→    is_audio = False\n   179→    audio_url = None\n   180→\n   181→    # Parse do tipo de mensagem (Z-API possui várias estruturas)\n   182→    if \"text\" in payload and isinstance(payload[\"text\"], dict):\n   183→        content_message = payload[\"text\"].get(\"message\", \"\")\n   184→    elif \"image\" in payload and isinstance(payload[\"image\"], dict):\n   185→        content_message = payload[\"image\"].get(\"caption\", \"📸 Imagem recebida\")\n   186→        if \"imageUrl\" in payload[\"image\"]:\n   187→            attachments.append(payload[\"image\"][\"imageUrl\"])\n   188→    elif \"audio\" in payload and isinstance(payload[\"audio\"], dict):\n   189→        content_message = \"🎙️ Áudio recebido\"\n   190→        is_audio = True\n   191→        if \"audioUrl\" in payload[\"audio\"]:\n   192→            audio_url = payload[\"audio\"][\"audioUrl\"]\n   193→            attachments.append(audio_url)\n   194→    elif \"document\" in payload and isinstance(payload[\"document\"], dict):\n   195→        content_message = payload[\"document\"].get(\"fileName\", \"📄 Documento recebido\")\n   196→        if \"documentUrl\" in payload[\"document\"]:\n   197→            attachments.append(payload[\"document\"][\"documentUrl\"])\n   198→    \n   199→    # Se não conseguimos extrair texto decente mas a Z-API enviou string direto\n   200→    if not content_message and isinstance(payload.get(\"text\"), str):\n   201→        content_message = payload[\"text\"]\n   202→\n   203→    # 1. Tentar achar o mapeamento no banco de dados local primeiro (útil para @lid e velocidade)\n   204→    contact_id = token_manager.get_mapped_contact_id(location_id, phone)\n   205→    \n   206→    if not contact_id:\n   207→        # Se é um @lid e não está no banco, nem adianta pesquisar na API Oficial porque a API do GHL não busca lid.\n   208→        # Mas se for telefone normal, tentamos achar lá pra ver se já existe.\n   209→        if \"@lid\" not in phone:\n   210→            contact = await ghl_service.search_contact_by_phone(location_id, phone)\n   211→            if contact and \"id\" in contact:\n   212→                contact_id = contact[\"id\"]\n   213→        \n   214→        # Se ainda não temos um contact_id, criamos um novo\n   215→        if not contact_id:\n   216→            logger.info(f\"Contato {phone} não encontrado. Criando novo no GHL...\")\n   217→            sender_name = payload.get(\"senderName\") or payload.get(\"participantName\") or \"\"\n   218→            # Se vier só o lid, criamos o nome como \"Lead do WhatsApp\" para não ficar feio no CRM\n   219→            if not sender_name and \"@lid\" in phone:\n   220→                sender_name = \"Lead do WhatsApp (Anúncio)\"\n   221→                \n   222→            new_contact = await ghl_service.create_contact(location_id, phone, name=sender_name)\n   223→            if new_contact and \"id\" in new_contact:\n   224→                contact_id = new_contact[\"id\"]\n   225→        \n   226→        # 2. Se agora temos um contact_id (achado ou recém-criado), SALVAMOS no banco local\n   227→        if contact_id:\n   228→            token_manager.save_contact_mapping(location_id, phone, contact_id)\n   229→\n   230→    if not contact_id:\n   231→        logger.error(f\"Impossível registrar inbound: Falha ao obter/criar contactId para o telefone {phone}\")\n   232→        return\n   233→\n   234→    # Registrar no CRM\n   235→    resp = await ghl_service.send_inbound_message(\n   236→        location_id=location_id,\n   237→        phone=phone,\n   238→        message=content_message,\n   239→        attachments=attachments,\n   240→        conversation_provider_id=tenant.conversation_provider_id,\n   241→        contact_id=contact_id,\n   242→    )\n   243→\n   244→    # Detecção de contato deletado no GHL manualmente pelo usuário\n   245→    if resp and isinstance(resp, dict) and resp.get(\"error\"):\n   246→        if resp.get(\"status_code\") == 400 and \"Contact not found/deleted\" in str(resp.get(\"body\", {})):\n   247→            logger.warning(f\"Contato {contact_id} deletado no GHL. Limpando cache e recriando...\")\n   248→            token_manager.delete_contact_mapping(location_id, phone)\n   249→            \n   250→            # Recria o contato do zero\n   251→            sender_name = payload.get(\"senderName\") or payload.get(\"participantName\") or \"\"\n   252→            if not sender_name and \"@lid\" in phone:\n   253→                sender_name = \"Lead do WhatsApp (Anúncio)\"\n   254→                \n   255→            new_contact = await ghl_service.create_contact(location_id, phone, name=sender_name)\n   256→            if new_contact and \"id\" in new_contact:\n   257→                contact_id = new_contact[\"id\"]\n   258→                token_manager.save_contact_mapping(location_id, phone, contact_id)\n   259→                \n   260→                # Tenta enviar de novo\n   261→                resp = await ghl_service.send_inbound_message(\n   262→                    location_id=location_id,\n   263→                    phone=phone,\n   264→                    message=content_message,\n   265→                    attachments=attachments,\n   266→                    conversation_provider_id=tenant.conversation_provider_id,\n   267→                    contact_id=contact_id,\n   268→                )\n   269→    \n   270→    if resp and not resp.get(\"error\"):\n   271→        logger.info(f\"Sucesso ao registrar inbound ({phone}) no GHL para tenant {location_id}.\")\n   272→\n   273→        # =========================================================================\n   274→        # INTEGRAÇÃO AGENTE IA NATIVO — com debounce anti-duplicata\n   275→        # =========================================================================\n   276→        try:\n   277→            is_ai_active = await ghl_service.is_ai_active_for_contact(location_id, contact_id)\n   278→            if is_ai_active:\n   279→                contact_key = f\"{location_id}:{phone}\"\n   280→\n   281→                # Lê o debounce configurado no agente deste tenant\n   282→                from services.ai_service import ai_service as _ai_svc\n   283→                from data.database import SessionLocal as _SL\n   284→                from data.models import AIAgent as _AIAgent\n   285→                _db = _SL()\n   286→                try:\n   287→                    _agent = _db.query(_AIAgent).filter(_AIAgent.location_id == location_id).first()\n   288→                    debounce = float(_agent.debounce_seconds) if _agent and _agent.debounce_seconds is not None else DEFAULT_DEBOUNCE_SECONDS\n   289→                except Exception:\n   290→                    debounce = DEFAULT_DEBOUNCE_SECONDS\n   291→                finally:\n   292→                    _db.close()\n   293→\n   294→                # Acumula a mensagem no buffer desse contato\n   295→                if contact_key not in _ai_message_buffers:\n   296→                    _ai_message_buffers[contact_key] = []\n   297→                _ai_message_buffers[contact_key].append((content_message, is_audio, audio_url))\n   298→\n   299→                # Armazena o debounce configurado (sobrescreve com o último valor — ok)\n   300→                _ai_debounce_config[contact_key] = debounce\n   301→\n   302→                # Cancela o timer anterior se o usuário enviou outra mensagem antes do delay\n   303→                existing = _ai_pending_tasks.get(contact_key)\n   304→                if existing and not existing.done():\n   305→                    existing.cancel()\n   306→\n   307→                # Agenda nova tarefa com delay de debounce\n   308→                _ai_pending_tasks[contact_key] = asyncio.create_task(\n   309→                    _run_ai_response(location_id, phone, contact_id, tenant, contact_key)\n   310→                )\n   311→        except Exception as ai_e:\n   312→            logger.error(f\"Erro durante agendamento do motor IA: {ai_e}\")\n   313→            \n   314→    else:\n   315→        logger.error(f\"Falha ao transferir inbound ({phone}) para GHL no tenant {location_id}.\")\n   316→\n   317→\n   318→@router.post(\"/inbound/{location_id}\")\n   319→async def zapi_inbound_webhook(\n   320→    request: Request,\n   321→    background_tasks: BackgroundTasks,\n   322→    location_id: str = Path(..., description=\"O Location ID do GHL desta empresa\"),\n   323→):\n   324→    \"\"\"\n   325→    URL de Webhook que você vai colar no painel administrativo do Z-API:\n   326→    https://seu-servidor.com/webhook/zapi/inbound/{SEU_LOCATION_ID_DO_GHL}\n   327→    \n   328→    Ex: https://axenwp.meudominio.com/webhook/zapi/inbound/HjiMUOsCCHCjtxzEf8PR\n   329→    \"\"\"\n   330→    try:\n   331→        payload = await request.json()\n   332→    except Exception as e:\n   333→        logger.error(\"Payload Z-API Inbound inválido.\")\n   334→        return {\"success\": False, \"error\": \"Invalid JSON\"}\n   335→\n   336→    # Envia pro processamento em background\n   337→    background_tasks.add_task(process_inbound_message, location_id, payload)\n   338→    \n   339→    # Se o GHL exigir 200 sempre, Z-API também precisa para parar de reenviar\n   340→    return {\"success\": True}\n   341→\n   342→\n   343→async def process_status_update(location_id: str, payload: Dict[str, Any]):\n   344→    \"\"\"\n   345→    Processa webhooks de STATUS de mensagens (onMessageStatus) da Z-API\n   346→    e repassa pro GHL.\n   347→    Status esperados da Z-API: \"DELIVERED\", \"READ\", \"ERROR\", etc.\n   348→    \"\"\"\n   349→    zapi_message_id = payload.get(\"messageId\")\n   350→    status = payload.get(\"status\", \"\").upper()\n   351→    \n   352→    if not zapi_message_id:\n   353→        return\n   354→\n   355→    tenant = token_manager.get_tenant(location_id)\n   356→    if tenant and not getattr(tenant, 'is_active', True):\n   357→        logger.info(f\"Z-API Status abortado: Automação desativada para {location_id}.\")\n   358→        return\n   359→        \n   360→    mapping = token_manager.get_ghl_message_id_by_zapi(zapi_message_id)\n   361→    if not mapping:\n   362→        logger.debug(f\"Webhook de status ignorado: Z-API MessageId {zapi_message_id} não mapeado para GHL.\")\n   363→        return\n   364→        \n   365→    ghl_message_id = mapping.get(\"ghl_message_id\")\n   366→    \n   367→    # Traduzir status da Z-API para o GHL (delivered, read, failed)\n   368→    ghl_status = \"delivered\" # Default fallback seguro\n   369→    if status == \"DELIVERED\":\n   370→        ghl_status = \"delivered\"\n   371→    elif status == \"READ\":\n   372→        ghl_status = \"read\"\n   373→    elif status in [\"ERROR\", \"FAILED\", \"REJECTED\"]:\n   374→        ghl_status = \"failed\"\n   375→        \n   376→    logger.info(f\"Atualizando status no GHL para '{ghl_status}' (GHL MsgId: {ghl_message_id})\")\n   377→    await ghl_service.update_message_status(\n   378→        location_id=location_id,\n   379→        message_id=ghl_message_id,\n   380→        status=ghl_status,\n   381→        error_message=payload.get(\"error\", \"Erro remoto no Z-API\") if ghl_status == \"failed\" else None\n   382→    )\n   383→\n   384→\n   385→@router.post(\"/status/{location_id}\")\n   386→async def zapi_status_webhook(\n   387→    request: Request,\n   388→    background_tasks: BackgroundTasks,\n   389→    location_id: str = Path(..., description=\"O Location ID do GHL desta empresa\"),\n   390→):\n   391→    \"\"\"\n   392→    URL de Webhook (onMessageStatus) para colar no Z-API:\n   393→    https://seu-servidor.com/webhook/zapi/status/{SEU_LOCATION_ID_DO_GHL}\n   394→    \"\"\"\n   395→    try:\n   396→        payload = await request.json()\n   397→    except Exception as e:\n   398→        logger.error(\"Payload Z-API Status inválido.\")\n   399→        return {\"success\": False, \"error\": \"Invalid JSON\"}\n   400→\n   401→    background_tasks.add_task(process_status_update, location_id, payload)\n   402→    \n   403→    return {\"success\": True}\n   404→"}]},"parent_tool_use_id":null,"session_id":"c65344f3-6aa1-4b02-b3ae-01430f0d6aae","uuid":"49d8cdbd-6573-43b3-a41d-5dcd4278810d","timestamp":"2026-03-20T17:15:34.320Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/webhooks/zapi_receiver.py","content":"\"\"\"\nRecebe webhooks do Z-API (Inbound).\nQuando o cliente responde no WhatsApp, o Z-API avisa este servidor,\nque formata e insere no GHL via /conversations/messages/inbound\n\"\"\"\n\nimport asyncio\nfrom fastapi import APIRouter, Request, BackgroundTasks, Path\nfrom typing import Dict, Any\n\nfrom utils.logger import logger\nfrom utils.config import settings\nfrom auth.token_manager import token_manager\nfrom services.ghl_service import ghl_service\nfrom services.zapi_service import zapi_service\n\n\nrouter = APIRouter(prefix=\"/webhook/zapi\", tags=[\"Webhooks Z-API\"])\n\n# ---------------------------------------------------------------------------\n# Debounce: evita múltiplas respostas da IA quando o usuário envia várias\n# mensagens em sequência rápida. As mensagens são acumuladas por DEBOUNCE_SECONDS\n# e processadas juntas em uma única chamada à IA.\n# ---------------------------------------------------------------------------\nDEFAULT_DEBOUNCE_SECONDS = 1.5\n_ai_pending_tasks: Dict[str, asyncio.Task] = {}   # contact_key -> Task\n_ai_message_buffers: Dict[str, list] = {}          # contact_key -> [(text, is_audio, audio_url), ...]\n_ai_debounce_config: Dict[str, float] = {}         # contact_key -> debounce_seconds\n\n\nasync def _run_ai_response(location_id: str, phone: str, contact_id: str, tenant, contact_key: str):\n    \"\"\"Aguarda o debounce e depois processa a IA com todas as mensagens acumuladas.\"\"\"\n    try:\n        delay = _ai_debounce_config.pop(contact_key, DEFAULT_DEBOUNCE_SECONDS)\n        await asyncio.sleep(delay)\n\n        messages = _ai_message_buffers.pop(contact_key, [])\n        _ai_pending_tasks.pop(contact_key, None)\n\n        if not messages:\n            return\n\n        # Combina todas as mensagens recebidas na janela de debounce em um único turno\n        combined_text = '\\n'.join(m[0] for m in messages if m[0])\n        is_audio = any(m[1] for m in messages)\n        # Pega a URL do último áudio recebido (para transcrição)\n        audio_url = None\n        for m in reversed(messages):\n            if m[1] and m[2]:  # is_audio=True e tem audio_url\n                audio_url = m[2]\n                break\n\n        if not combined_text:\n            return\n\n        if len(messages) > 1:\n            logger.info(f\"🧠 Debounce: combinando {len(messages)} mensagens de {phone} em uma única chamada IA.\")\n        else:\n            logger.info(f\"🧠 Agente IA ativado para contato {contact_id}. Gerando resposta...\")\n\n        from services.ai_service import ai_service\n\n        ai_response = await ai_service.process_incoming_message(\n            location_id, phone, combined_text, is_audio=is_audio, audio_url=audio_url\n        )\n        if not ai_response:\n            return\n\n        ai_type = ai_response.get(\"type\", \"text\")\n        ai_content = ai_response.get(\"content\", \"\")\n        ai_text_for_ghl = ai_response.get(\"text\", ai_content)\n\n        logger.info(f\"🤖 IA respondeu ({ai_type}), enviando via Z-API...\")\n\n        if ai_type == \"audio\":\n            sent_data = await zapi_service.send_audio(\n                instance_id=tenant.zapi_instance_id,\n                token=tenant.zapi_token,\n                phone=phone,\n                audio_url=ai_content,\n                client_token=tenant.zapi_client_token,\n                record_audio=True\n            )\n            if sent_data:\n                zapi_message_id = sent_data.get(\"zapiMessageId\")\n                outbound_resp = await ghl_service.send_inbound_message(\n                    location_id=location_id,\n                    phone=phone,\n                    message=\"[Mensagem de Áudio enviada pela IA]\",\n                    conversation_provider_id=tenant.conversation_provider_id,\n                    contact_id=contact_id,\n                    direction=\"outbound\"\n                )\n                if outbound_resp and not outbound_resp.get(\"error\"):\n                    ghl_msg_id = outbound_resp.get(\"messageId\") or outbound_resp.get(\"id\")\n                    if ghl_msg_id and zapi_message_id:\n                        token_manager.save_message_mapping(zapi_message_id, ghl_msg_id, location_id)\n        else:\n            import re\n\n            chunks = [c.strip() for c in re.split(r'(?<=[.?!])\\s+(?=[A-Z0-9À-ÖØ-Þ*])', ai_content) if c.strip()]\n            if not chunks:\n                chunks = [ai_content.strip()]\n\n            for i, chunk in enumerate(chunks):\n                delay = 5 if i > 0 else 2\n                if i > 0:\n                    await asyncio.sleep(delay)\n\n                sent_data = await zapi_service.send_text(\n                    instance_id=tenant.zapi_instance_id,\n                    token=tenant.zapi_token,\n                    phone=phone,\n                    message=chunk,\n                    client_token=tenant.zapi_client_token,\n                    delay_typing=delay\n                )\n                if sent_data:\n                    zapi_message_id = sent_data.get(\"zapiMessageId\")\n                    outbound_resp = await ghl_service.send_inbound_message(\n                        location_id=location_id,\n                        phone=phone,\n                        message=chunk,\n                        conversation_provider_id=tenant.conversation_provider_id,\n                        contact_id=contact_id,\n                        direction=\"outbound\"\n                    )\n                    if outbound_resp and not outbound_resp.get(\"error\"):\n                        ghl_msg_id = outbound_resp.get(\"messageId\") or outbound_resp.get(\"id\")\n                        if ghl_msg_id and zapi_message_id:\n                            token_manager.save_message_mapping(zapi_message_id, ghl_msg_id, location_id)\n\n    except asyncio.CancelledError:\n        # Nova mensagem chegou antes do delay expirar — comportamento esperado do debounce\n        logger.debug(f\"IA debounce resetado para {phone} (nova mensagem chegou).\")\n    except Exception as e:\n        logger.error(f\"Erro no processamento IA (debounce): {e}\")\n\n\nasync def process_inbound_message(location_id: str, payload: Dict[str, Any]):\n    \"\"\"\n    Processa a mensagem recebida pelo webhook da Z-API.\n    1. Verifica o token do provider para esse location_id.\n    2. Extrai texto e anexos.\n    3. Manda para a API Inbound do GHL.\n    \"\"\"\n    tenant = token_manager.get_tenant(location_id)\n    if not tenant:\n        logger.error(f\"Z-API Inbound abortado: Tenant {location_id} não registrado.\")\n        return\n\n    if not getattr(tenant, 'is_active', True):\n        logger.info(f\"Z-API Inbound abortado: Automação desativada para {location_id}.\")\n        return\n\n    # Apenas logamos as infos para facilitar debug\n    phone = payload.get(\"phone\", \"\")\n    message_type = payload.get(\"type\", \"\")\n    is_group = payload.get(\"isGroup\", False)\n    from_me = payload.get(\"fromMe\", False)\n\n    # Filtrar mensagens indesejadas\n    if is_group:\n        logger.debug(f\"Ignorando mensagem de grupo.\")\n        return\n    if from_me:\n        logger.debug(f\"Ignorando mensagem enviada por nós mesmos.\")\n        return\n    # Aceita apenas eventos de mensagem recebida\n    if message_type not in [\"ReceivedCallback\", \"MessageReceived\"]:\n        logger.debug(f\"Ignorando evento de tipo '{message_type}' (não é mensagem recebida).\")\n        return\n\n    logger.info(f\"Processando inbound Z-API para tenant {location_id} (origem: {phone})\")\n\n    content_message = \"Mensagem recebida do WhatsApp\"\n    attachments = []\n    is_audio = False\n    audio_url = None\n\n    # Parse do tipo de mensagem (Z-API possui várias estruturas)\n    if \"text\" in payload and isinstance(payload[\"text\"], dict):\n        content_message = payload[\"text\"].get(\"message\", \"\")\n    elif \"image\" in payload and isinstance(payload[\"image\"], dict):\n        content_message = payload[\"image\"].get(\"caption\", \"📸 Imagem recebida\")\n        if \"imageUrl\" in payload[\"image\"]:\n            attachments.append(payload[\"image\"][\"imageUrl\"])\n    elif \"audio\" in payload and isinstance(payload[\"audio\"], dict):\n        content_message = \"🎙️ Áudio recebido\"\n        is_audio = True\n        if \"audioUrl\" in payload[\"audio\"]:\n            audio_url = payload[\"audio\"][\"audioUrl\"]\n            attachments.append(audio_url)\n    elif \"document\" in payload and isinstance(payload[\"document\"], dict):\n        content_message = payload[\"document\"].get(\"fileName\", \"📄 Documento recebido\")\n        if \"documentUrl\" in payload[\"document\"]:\n            attachments.append(payload[\"document\"][\"documentUrl\"])\n    \n    # Se não conseguimos extrair texto decente mas a Z-API enviou string direto\n    if not content_message and isinstance(payload.get(\"text\"), str):\n        content_message = payload[\"text\"]\n\n    # 1. Tentar achar o mapeamento no banco de dados local primeiro (útil para @lid e velocidade)\n    contact_id = token_manager.get_mapped_contact_id(location_id, phone)\n    \n    if not contact_id:\n        # Se é um @lid e não está no banco, nem adianta pesquisar na API Oficial porque a API do GHL não busca lid.\n        # Mas se for telefone normal, tentamos achar lá pra ver se já existe.\n        if \"@lid\" not in phone:\n            contact = await ghl_service.search_contact_by_phone(location_id, phone)\n            if contact and \"id\" in contact:\n                contact_id = contact[\"id\"]\n        \n        # Se ainda não temos um contact_id, criamos um novo\n        if not contact_id:\n            logger.info(f\"Contato {phone} não encontrado. Criando novo no GHL...\")\n            sender_name = payload.get(\"senderName\") or payload.get(\"participantName\") or \"\"\n            # Se vier só o lid, criamos o nome como \"Lead do WhatsApp\" para não ficar feio no CRM\n            if not sender_name and \"@lid\" in phone:\n                sender_name = \"Lead do WhatsApp (Anúncio)\"\n                \n            new_contact = await ghl_service.create_contact(location_id, phone, name=sender_name)\n            if new_contact and \"id\" in new_contact:\n                contact_id = new_contact[\"id\"]\n        \n        # 2. Se agora temos um contact_id (achado ou recém-criado), SALVAMOS no banco local\n        if contact_id:\n            token_manager.save_contact_mapping(location_id, phone, contact_id)\n\n    if not contact_id:\n        logger.error(f\"Impossível registrar inbound: Falha ao obter/criar contactId para o telefone {phone}\")\n        return\n\n    # Registrar no CRM\n    resp = await ghl_service.send_inbound_message(\n        location_id=location_id,\n        phone=phone,\n        message=content_message,\n        attachments=attachments,\n        conversation_provider_id=tenant.conversation_provider_id,\n        contact_id=contact_id,\n    )\n\n    # Detecção de contato deletado no GHL manualmente pelo usuário\n    if resp and isinstance(resp, dict) and resp.get(\"error\"):\n        if resp.get(\"status_code\") == 400 and \"Contact not found/deleted\" in str(resp.get(\"body\", {})):\n            logger.warning(f\"Contato {contact_id} deletado no GHL. Limpando cache e recriando...\")\n            token_manager.delete_contact_mapping(location_id, phone)\n            \n            # Recria o contato do zero\n            sender_name = payload.get(\"senderName\") or payload.get(\"participantName\") or \"\"\n            if not sender_name and \"@lid\" in phone:\n                sender_name = \"Lead do WhatsApp (Anúncio)\"\n                \n            new_contact = await ghl_service.create_contact(location_id, phone, name=sender_name)\n            if new_contact and \"id\" in new_contact:\n                contact_id = new_contact[\"id\"]\n                token_manager.save_contact_mapping(location_id, phone, contact_id)\n                \n                # Tenta enviar de novo\n                resp = await ghl_service.send_inbound_message(\n                    location_id=location_id,\n                    phone=phone,\n                    message=content_message,\n                    attachments=attachments,\n                    conversation_provider_id=tenant.conversation_provider_id,\n                    contact_id=contact_id,\n                )\n    \n    if resp and not resp.get(\"error\"):\n        logger.info(f\"Sucesso ao registrar inbound ({phone}) no GHL para tenant {location_id}.\")\n\n        # =========================================================================\n        # INTEGRAÇÃO AGENTE IA NATIVO — com debounce anti-duplicata\n        # =========================================================================\n        try:\n            is_ai_active = await ghl_service.is_ai_active_for_contact(location_id, contact_id)\n            if is_ai_active:\n                contact_key = f\"{location_id}:{phone}\"\n\n                # Lê o debounce configurado no agente deste tenant\n                from services.ai_service import ai_service as _ai_svc\n                from data.database import SessionLocal as _SL\n                from data.models import AIAgent as _AIAgent\n                _db = _SL()\n                try:\n                    _agent = _db.query(_AIAgent).filter(_AIAgent.location_id == location_id).first()\n                    debounce = float(_agent.debounce_seconds) if _agent and _agent.debounce_seconds is not None else DEFAULT_DEBOUNCE_SECONDS\n                except Exception:\n                    debounce = DEFAULT_DEBOUNCE_SECONDS\n                finally:\n                    _db.close()\n\n                # Acumula a mensagem no buffer desse contato\n                if contact_key not in _ai_message_buffers:\n                    _ai_message_buffers[contact_key] = []\n                _ai_message_buffers[contact_key].append((content_message, is_audio, audio_url))\n\n                # Armazena o debounce configurado (sobrescreve com o último valor — ok)\n                _ai_debounce_config[contact_key] = debounce\n\n                # Cancela o timer anterior se o usuário enviou outra mensagem antes do delay\n                existing = _ai_pending_tasks.get(contact_key)\n                if existing and not existing.done():\n                    existing.cancel()\n\n                # Agenda nova tarefa com delay de debounce\n                _ai_pending_tasks[contact_key] = asyncio.create_task(\n                    _run_ai_response(location_id, phone, contact_id, tenant, contact_key)\n                )\n        except Exception as ai_e:\n            logger.error(f\"Erro durante agendamento do motor IA: {ai_e}\")\n            \n    else:\n        logger.error(f\"Falha ao transferir inbound ({phone}) para GHL no tenant {location_id}.\")\n\n\n@router.post(\"/inbound/{location_id}\")\nasync def zapi_inbound_webhook(\n    request: Request,\n    background_tasks: BackgroundTasks,\n    location_id: str = Path(..., description=\"O Location ID do GHL desta empresa\"),\n):\n    \"\"\"\n    URL de Webhook que você vai colar no painel administrativo do Z-API:\n    https://seu-servidor.com/webhook/zapi/inbound/{SEU_LOCATION_ID_DO_GHL}\n    \n    Ex: https://axenwp.meudominio.com/webhook/zapi/inbound/HjiMUOsCCHCjtxzEf8PR\n    \"\"\"\n    try:\n        payload = await request.json()\n    except Exception as e:\n        logger.error(\"Payload Z-API Inbound inválido.\")\n        return {\"success\": False, \"error\": \"Invalid JSON\"}\n\n    # Envia pro processamento em background\n    background_tasks.add_task(process_inbound_message, location_id, payload)\n    \n    # Se o GHL exigir 200 sempre, Z-API também precisa para parar de reenviar\n    return {\"success\": True}\n\n\nasync def process_status_update(location_id: str, payload: Dict[str, Any]):\n    \"\"\"\n    Processa webhooks de STATUS de mensagens (onMessageStatus) da Z-API\n    e repassa pro GHL.\n    Status esperados da Z-API: \"DELIVERED\", \"READ\", \"ERROR\", etc.\n    \"\"\"\n    zapi_message_id = payload.get(\"messageId\")\n    status = payload.get(\"status\", \"\").upper()\n    \n    if not zapi_message_id:\n        return\n\n    tenant = token_manager.get_tenant(location_id)\n    if tenant and not getattr(tenant, 'is_active', True):\n        logger.info(f\"Z-API Status abortado: Automação desativada para {location_id}.\")\n        return\n        \n    mapping = token_manager.get_ghl_message_id_by_zapi(zapi_message_id)\n    if not mapping:\n        logger.debug(f\"Webhook de status ignorado: Z-API MessageId {zapi_message_id} não mapeado para GHL.\")\n        return\n        \n    ghl_message_id = mapping.get(\"ghl_message_id\")\n    \n    # Traduzir status da Z-API para o GHL (delivered, read, failed)\n    ghl_status = \"delivered\" # Default fallback seguro\n    if status == \"DELIVERED\":\n        ghl_status = \"delivered\"\n    elif status == \"READ\":\n        ghl_status = \"read\"\n    elif status in [\"ERROR\", \"FAILED\", \"REJECTED\"]:\n        ghl_status = \"failed\"\n        \n    logger.info(f\"Atualizando status no GHL para '{ghl_status}' (GHL MsgId: {ghl_message_id})\")\n    await ghl_service.update_message_status(\n        location_id=location_id,\n        message_id=ghl_message_id,\n        status=ghl_status,\n        error_message=payload.get(\"error\", \"Erro remoto no Z-API\") if ghl_status == \"failed\" else None\n    )\n\n\n@router.post(\"/status/{location_id}\")\nasync def zapi_status_webhook(\n    request: Request,\n    background_tasks: BackgroundTasks,\n    location_id: str = Path(..., description=\"O Location ID do GHL desta empresa\"),\n):\n    \"\"\"\n    URL de Webhook (onMessageStatus) para colar no Z-API:\n    https://seu-servidor.com/webhook/zapi/status/{SEU_LOCATION_ID_DO_GHL}\n    \"\"\"\n    try:\n        payload = await request.json()\n    except Exception as e:\n        logger.error(\"Payload Z-API Status inválido.\")\n        return {\"success\": False, \"error\": \"Invalid JSON\"}\n\n    background_tasks.add_task(process_status_update, location_id, payload)\n    \n    return {\"success\": True}\n","numLines":404,"startLine":1,"totalLines":404}}}
