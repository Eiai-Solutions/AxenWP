{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W6L9nTKM3qGRcaTTGN6dzk","type":"tool_result","content":"   100→            data = response.json()\n   101→            voices = [{\"voice_id\": v[\"voice_id\"], \"name\": v[\"name\"]} for v in data.get(\"voices\", [])]\n   102→            return {\"success\": True, \"voices\": voices}\n   103→\n   104→    except Exception as e:\n   105→        logger.error(f\"Erro ao buscar vozes na ElevenLabs: {e}\")\n   106→        raise HTTPException(status_code=500, detail=\"Erro interno ao consultar serviço de voz.\")\n   107→\n   108→\n   109→# ── Helpers para chamadas OpenRouter ──\n   110→\n   111→def _openrouter_headers(api_key: str, title: str = \"AxenWP\") -> dict:\n   112→    return {\n   113→        \"Authorization\": f\"Bearer {api_key}\",\n   114→        \"HTTP-Referer\": \"https://axenwp.com\",\n   115→        \"X-Title\": title,\n   116→    }\n   117→\n   118→def _extract_tag(text: str, tag: str) -> str:\n   119→    \"\"\"Extrai conteúdo entre tags XML. Usa greedy para capturar até o último fechamento.\"\"\"\n   120→    m = re.search(rf\"<{tag}>(.*)</{tag}>\", text, re.DOTALL)\n   121→    return m.group(1).strip() if m else \"\"\n   122→\n   123→\n   124→class AnalyzeRequest(BaseModel):\n   125→    prompt_text: str\n   126→\n   127→@router.post(\"/analyze-prompt\")\n   128→async def analyze_ai_prompt(payload: AnalyzeRequest):\n   129→    \"\"\"\n   130→    Analisa e melhora o prompt do agente em 3 etapas:\n   131→      1. Simula conversa Lead vs Agente\n   132→      2. Gera análise + lista de mudanças específicas (NÃO gera prompt completo)\n   133→      3. Chamada separada que aplica as mudanças ao prompt original (sem abreviar)\n   134→    \"\"\"\n   135→    db = SessionLocal()\n   136→    try:\n   137→        settings = db.query(SystemSettings).first()\n   138→        if not settings or not settings.admin_openrouter_key:\n   139→            return {\"success\": False, \"error\": \"Chave API do Administrador não configurada. Configure no menu superior (Admin Settings).\"}\n   140→\n   141→        model = settings.admin_openrouter_model or \"openai/gpt-4o\"\n   142→        headers = _openrouter_headers(settings.admin_openrouter_key, \"AxenWP Prompt Analyzer\")\n   143→\n   144→        async with httpx.AsyncClient(timeout=90.0) as client:\n   145→\n   146→            # ── ETAPA 1: Simular conversa Lead vs Agente ──\n   147→            sim_resp = await client.post(\n   148→                \"https://openrouter.ai/api/v1/chat/completions\",\n   149→                headers=headers,\n   150→                json={\n   151→                    \"model\": model,\n   152→                    \"messages\": [{\"role\": \"user\", \"content\": (\n   153→                        \"Você é um 'Lead' (cliente em potencial) interessado nos serviços da empresa, \"\n   154→                        \"mas você é ocupado, direto e um pouco cético.\\n\"\n   155→                        \"Simule uma conversa de 3 turnos com o Agente de IA.\\n\\n\"\n   156→                        f\"--- PROMPT DO AGENTE ---\\n{payload.prompt_text}\\n\\n\"\n   157→                        \"Formato:\\nLead: [pergunta]\\nAgente: [resposta]\\n\\n\"\n   158→                        \"Gere 3 turnos.\"\n   159→                    )}]\n   160→                }\n   161→            )\n   162→            transcript = sim_resp.json()[\"choices\"][0][\"message\"][\"content\"] if sim_resp.status_code == 200 else \"Falha na simulação.\"\n   163→\n   164→            # ── ETAPA 2: Análise + lista de mudanças (SEM gerar prompt completo) ──\n   165→            analysis_resp = await client.post(\n   166→                \"https://openrouter.ai/api/v1/chat/completions\",\n   167→                headers=headers,\n   168→                json={\n   169→                    \"model\": model,\n   170→                    \"max_tokens\": 4000,\n   171→                    \"messages\": [\n   172→                        {\"role\": \"system\", \"content\": (\n   173→                            \"Você é um especialista sênior em Prompt Engineering para agentes de WhatsApp B2B.\\n\\n\"\n   174→                            \"Sua tarefa: analisar o prompt do agente com base em uma conversa simulada \"\n   175→                            \"e listar MUDANÇAS ESPECÍFICAS a serem feitas.\\n\\n\"\n   176→                            \"NÃO gere o prompt completo. Apenas analise e liste as mudanças.\\n\\n\"\n   177→                            \"Retorne neste formato:\\n\\n\"\n   178→                            \"<analysis>\\n\"\n   179→                            \"[Diagnóstico em markdown: objetivo do agente, o que a simulação revelou, \"\n   180→                            \"pontos fortes, pontos fracos, e o que precisa mudar]\\n\"\n   181→                            \"</analysis>\\n\\n\"\n   182→                            \"<changes>\\n\"\n   183→                            \"1. [SEÇÃO: nome] — [AÇÃO: adicionar/alterar/remover/reorganizar] — [O QUE: descrição detalhada da mudança]\\n\"\n   184→                            \"2. ...\\n\"\n   185→                            \"</changes>\"\n   186→                        )},\n   187→                        {\"role\": \"user\", \"content\": (\n   188→                            f\"PROMPT DO AGENTE:\\n{payload.prompt_text}\\n\\n\"\n   189→                            f\"TRANSCRIÇÃO DO TESTE:\\n{transcript}\\n\\n\"\n   190→                            \"Analise e liste as mudanças necessárias.\"\n   191→                        )}\n   192→                    ]\n   193→                }\n   194→            )\n   195→\n   196→            if analysis_resp.status_code != 200:\n   197→                return {\"success\": False, \"error\": f\"IA Mestre falhou na análise ({analysis_resp.status_code}).\"}\n   198→\n   199→            analysis_raw = analysis_resp.json()[\"choices\"][0][\"message\"][\"content\"]\n   200→            analysis_text = _extract_tag(analysis_raw, \"analysis\")\n   201→            changes_text = _extract_tag(analysis_raw, \"changes\")\n   202→\n   203→            if not analysis_text and not changes_text:\n   204→                logger.error(f\"Delimitadores não encontrados na análise. Raw: {analysis_raw[:500]}\")\n   205→                return {\"success\": False, \"error\": \"Resposta malformada da IA Mestre.\"}\n   206→\n   207→            # Se não há mudanças sugeridas, retorna apenas a análise\n   208→            if not changes_text or changes_text.lower().strip() in [\"nenhuma\", \"nenhuma mudança\", \"\"]:\n   209→                return {\n   210→                    \"success\": True,\n   211→                    \"analysis\": analysis_text,\n   212→                    \"improved_prompt\": \"\",\n   213→                    \"simulation_transcript\": transcript,\n   214→                }\n   215→\n   216→            # ── ETAPA 3: Aplicar mudanças ao prompt original (chamada focada) ──\n   217→            apply_resp = await client.post(\n   218→                \"https://openrouter.ai/api/v1/chat/completions\",\n   219→                headers=headers,\n   220→                json={\n   221→                    \"model\": model,\n   222→                    \"max_tokens\": 16000,\n   223→                    \"messages\": [\n   224→                        {\"role\": \"system\", \"content\": (\n   225→                            \"Você é um editor de prompts. Sua ÚNICA tarefa é receber um prompt original \"\n   226→                            \"e uma lista de mudanças, e retornar o prompt completo com as mudanças aplicadas.\\n\\n\"\n   227→                            \"REGRAS ABSOLUTAS — violá-las é inaceitável:\\n\"\n   228→                            \"1. Retorne o prompt COMPLETO com as mudanças incorporadas\\n\"\n   229→                            \"2. Copie LITERALMENTE, palavra por palavra, todas as seções que NÃO foram alteradas\\n\"\n   230→                            \"3. PROIBIDO usar: '[...]', '[mesma seção]', '[mantido]', '[demais seções iguais]', \"\n   231→                            \"'[resto do prompt]', '[continua igual]' ou QUALQUER forma de abreviação\\n\"\n   232→                            \"4. PROIBIDO omitir, resumir ou pular qualquer seção, regra, instrução ou parágrafo\\n\"\n   233→                            \"5. O resultado será colado diretamente no agente — qualquer omissão é perda permanente\\n\"\n   234→                            \"6. Retorne APENAS o prompt final. Sem explicações, sem tags XML, sem comentários antes ou depois\"\n   235→                        )},\n   236→                        {\"role\": \"user\", \"content\": (\n   237→                            f\"PROMPT ORIGINAL (copie integralmente as partes não alteradas):\\n\"\n   238→                            f\"{payload.prompt_text}\\n\\n\"\n   239→                            f\"MUDANÇAS A APLICAR:\\n{changes_text}\\n\\n\"\n   240→                            \"Aplique as mudanças acima e retorne o prompt COMPLETO.\"\n   241→                        )}\n   242→                    ]\n   243→                }\n   244→            )\n   245→\n   246→            if apply_resp.status_code != 200:\n   247→                return {\"success\": False, \"error\": f\"IA Mestre falhou ao gerar prompt ({apply_resp.status_code}).\"}\n   248→\n   249→            apply_json = apply_resp.json()\n   250→            improved = apply_json[\"choices\"][0][\"message\"][\"content\"].strip()\n   251→            apply_finish = apply_json[\"choices\"][0].get(\"finish_reason\", \"\")\n   252→\n   253→            if apply_finish == \"length\":\n   254→                logger.warning(\"Prompt melhorado foi truncado (finish_reason=length).\")\n   255→                return {\n   256→                    \"success\": False,\n   257→                    \"error\": \"O prompt melhorado foi truncado por ser muito longo. Tente pedir melhorias pontuais pelo chat.\",\n   258→                }\n   259→\n   260→            return {\n   261→                \"success\": True,\n   262→                \"analysis\": analysis_text,\n   263→                \"improved_prompt\": improved,\n   264→                \"simulation_transcript\": transcript,\n   265→            }\n   266→    except Exception as e:\n   267→        logger.error(f\"Erro no analisador de prompt: {e}\", exc_info=True)\n   268→        return {\"success\": False, \"error\": \"Erro interno do servidor ao tentar analisar.\"}\n   269→    finally:\n   270→        db.close()\n   271→\n   272→class MasterChatRequest(BaseModel):\n   273→    original_prompt: str\n   274→    current_improved_prompt: str\n   275→    user_message: str\n   276→    chat_history: list = []\n   277→\n   278→@router.post(\"/master-chat\")\n   279→async def master_chat(payload: MasterChatRequest):\n   280→    \"\"\"\n   281→    Chat iterativo com a IA Mestre. O usuário envia feedback sobre o agente\n   282→    e a Mestre revisa o prompt levando em consideração esse feedback.\n   283→    Usa abordagem de 2 etapas: primeiro gera resposta + mudanças, depois aplica ao prompt.\n   284→    \"\"\"\n   285→    db = SessionLocal()\n   286→    try:\n   287→        settings = db.query(SystemSettings).first()\n   288→        if not settings or not settings.admin_openrouter_key:\n   289→            return {\"success\": False, \"error\": \"Chave API do Administrador não configurada.\"}\n   290→\n   291→        model = settings.admin_openrouter_model or \"openai/gpt-4o\"\n   292→        headers = _openrouter_headers(settings.admin_openrouter_key, \"AxenWP Master Chat\")\n   293→\n   294→        # ── ETAPA 1: Gerar resposta conversacional + lista de mudanças ──\n   295→        system_prompt = (\n   296→            \"Você é um especialista sênior em Prompt Engineering para agentes de WhatsApp B2B.\\n\\n\"\n   297→            \"Você já analisou o prompt de um agente e gerou uma sugestão de melhoria. \"\n   298→            \"Agora está em uma conversa com o dono do agente, que vai te dar feedback.\\n\\n\"\n   299→            \"Seu papel:\\n\"\n   300→            \"- Responder de forma direta e consultiva ao feedback\\n\"\n   301→            \"- Se o feedback exigir mudança, liste as mudanças específicas\\n\"\n   302→            \"- Se for apenas dúvida/confirmação, responda sem listar mudanças\\n\\n\"\n   303→            \"Retorne neste formato:\\n\\n\"\n   304→            \"<response>\\n[Sua resposta conversacional]\\n</response>\\n\\n\"\n   305→            \"<changes>\\n\"\n   306→            \"[Lista de mudanças específicas se necessário, ou VAZIO se não há mudanças]\\n\"\n   307→            \"</changes>\"\n   308→        )\n   309→\n   310→        messages = [{\"role\": \"system\", \"content\": system_prompt}]\n   311→        context_msg = (\n   312→            f\"PROMPT ATUAL DO AGENTE:\\n{payload.current_improved_prompt or payload.original_prompt}\"\n   313→        )\n   314→        messages.append({\"role\": \"user\", \"content\": context_msg})\n   315→        messages.append({\"role\": \"assistant\", \"content\": \"Entendido. Tenho o contexto completo do prompt. Pode compartilhar seu feedback.\"})\n   316→\n   317→        for turn in payload.chat_history:\n   318→            messages.append({\"role\": \"user\" if turn[\"from\"] == \"user\" else \"assistant\", \"content\": turn[\"text\"]})\n   319→\n   320→        messages.append({\"role\": \"user\", \"content\": payload.user_message})\n   321→\n   322→        async with httpx.AsyncClient(timeout=90.0) as client:\n   323→            resp = await client.post(\n   324→                \"https://openrouter.ai/api/v1/chat/completions\",\n   325→                headers=headers,\n   326→                json={\n   327→                    \"model\": model,\n   328→                    \"max_tokens\": 4000,\n   329→                    \"messages\": messages,\n   330→                }\n   331→            )\n   332→\n   333→            if resp.status_code != 200:\n   334→                return {\"success\": False, \"error\": f\"IA Mestre falhou ({resp.status_code}).\"}\n   335→\n   336→            raw = resp.json()[\"choices\"][0][\"message\"][\"content\"]\n   337→            response_text = _extract_tag(raw, \"response\") or raw.strip()\n   338→            changes_text = _extract_tag(raw, \"changes\")\n   339→\n   340→            # Se não há mudanças, retorna só a resposta\n   341→            if not changes_text or changes_text.lower().strip() in [\"vazio\", \"nenhuma\", \"\"]:\n   342→                return {\n   343→                    \"success\": True,\n   344→                    \"response\": response_text,\n   345→                    \"updated_prompt\": \"\",\n   346→                }\n   347→\n   348→            # ── ETAPA 2: Aplicar mudanças ao prompt atual ──\n   349→            current_prompt = payload.current_improved_prompt or payload.original_prompt\n   350→\n   351→            apply_resp = await client.post(\n   352→                \"https://openrouter.ai/api/v1/chat/completions\",\n   353→                headers=headers,\n   354→                json={\n   355→                    \"model\": model,\n   356→                    \"max_tokens\": 16000,\n   357→                    \"messages\": [\n   358→                        {\"role\": \"system\", \"content\": (\n   359→                            \"Você é um editor de prompts. Sua ÚNICA tarefa é receber um prompt original \"\n   360→                            \"e uma lista de mudanças, e retornar o prompt completo com as mudanças aplicadas.\\n\\n\"\n   361→                            \"REGRAS ABSOLUTAS:\\n\"\n   362→                            \"1. Retorne o prompt COMPLETO com as mudanças incorporadas\\n\"\n   363→                            \"2. Copie LITERALMENTE todas as seções NÃO alteradas\\n\"\n   364→                            \"3. PROIBIDO usar: '[...]', '[mesma seção]', '[mantido]', '[demais seções iguais]'\\n\"\n   365→                            \"4. PROIBIDO omitir, resumir ou pular qualquer parte\\n\"\n   366→                            \"5. Retorne APENAS o prompt final, sem explicações ou comentários\"\n   367→                        )},\n   368→                        {\"role\": \"user\", \"content\": (\n   369→                            f\"PROMPT ORIGINAL:\\n{current_prompt}\\n\\n\"\n   370→                            f\"MUDANÇAS A APLICAR:\\n{changes_text}\\n\\n\"\n   371→                            \"Aplique e retorne o prompt COMPLETO.\"\n   372→                        )}\n   373→                    ]\n   374→                }\n   375→            )\n   376→\n   377→            if apply_resp.status_code != 200:\n   378→                return {\n   379→                    \"success\": True,\n   380→                    \"response\": response_text + \"\\n\\n⚠️ Não foi possível gerar o prompt atualizado automaticamente.\",\n   381→                    \"updated_prompt\": \"\",\n   382→                }\n   383→\n   384→            updated_prompt = apply_resp.json()[\"choices\"][0][\"message\"][\"content\"].strip()\n   385→\n   386→            return {\n   387→                \"success\": True,\n   388→                \"response\": response_text,\n   389→                \"updated_prompt\": updated_prompt,\n   390→            }\n   391→\n   392→    except Exception as e:\n   393→        logger.error(f\"Erro no master chat: {e}\", exc_info=True)\n   394→        return {\"success\": False, \"error\": str(e)}\n   395→    finally:\n   396→        db.close()\n   397→\n   398→\n   399→@router.post(\"/{location_id}/test\")\n   400→async def test_ai_agent(location_id: str, request: Request):\n   401→    \"\"\"\n   402→    Endpoint manual para o Testador de Chat no dashboard.\n   403→    Recebe message e o prompt/modelo atual (mesmo sem salvar).\n   404→    \"\"\"\n   405→    try:\n   406→        payload = await request.json()\n   407→        agent_data = payload.get(\"agent_data\", {})\n   408→        prompt = agent_data.get(\"prompt\")\n   409→        model = agent_data.get(\"model\", \"openai/gpt-4o\")\n   410→        api_key = agent_data.get(\"api_key\")\n   411→        user_message = payload.get(\"message\")\n   412→        chat_history = payload.get(\"history\", [])\n   413→\n   414→        if not api_key:\n   415→            return {\"success\": False, \"error\": \"A Chave API do Agente é necessária para testar.\"}\n   416→\n   417→        messages = [{\"role\": \"system\", \"content\": prompt}]\n   418→        # Add history\n   419→        for h in chat_history[-5:]: # last 5\n   420→            messages.append({\"role\": \"user\" if h[\"from\"] == \"me\" else \"assistant\", \"content\": h[\"text\"]})\n   421→\n   422→        # Current message\n   423→        messages.append({\"role\": \"user\", \"content\": user_message})\n   424→\n   425→        async with httpx.AsyncClient(timeout=30.0) as client:\n   426→            resp = await client.post(\n   427→                \"https://openrouter.ai/api/v1/chat/completions\",\n   428→                headers={\n   429→                    \"Authorization\": f\"Bearer {api_key}\",\n   430→                    \"HTTP-Referer\": \"https://axenwp.com\",\n   431→                    \"X-Title\": \"AxenWP Agent Tester\",\n   432→                },\n   433→                json={\n   434→                    \"model\": model,\n   435→                    \"messages\": messages\n   436→                }\n   437→            )\n   438→\n   439→            if resp.status_code != 200:\n   440→                return {\"success\": False, \"error\": f\"Erro na API do Agente: {resp.text}\"}\n   441→\n   442→            data = resp.json()\n   443→            ai_response = data[\"choices\"][0][\"message\"][\"content\"]\n   444→            return {\"success\": True, \"response\": ai_response}\n   445→    except Exception as e:\n   446→        logger.error(f\"Erro no chat tester: {e}\", exc_info=True)\n   447→        return {\"success\": False, \"error\": str(e)}\n   448→"}]},"par