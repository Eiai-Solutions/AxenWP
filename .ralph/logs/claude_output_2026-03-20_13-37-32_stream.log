{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KCz5ho39wMoVFr4YrCQh2H","type":"tool_result","content":"     1→\"\"\"\n     2→Ponto de entrada do servidor FastAPI do Axen WP.\n     3→\"\"\"\n     4→\n     5→from fastapi import FastAPI\n     6→from fastapi.middleware.cors import CORSMiddleware\n     7→from fastapi.staticfiles import StaticFiles\n     8→from fastapi.responses import FileResponse\n     9→import uvicorn\n    10→from contextlib import asynccontextmanager\n    11→\n    12→from apscheduler.schedulers.asyncio import AsyncIOScheduler\n    13→\n    14→from utils.logger import logger\n    15→from utils.config import settings\n    16→from auth.token_manager import token_manager\n    17→\n    18→# Importa as rotas\n    19→from auth.oauth import router as oauth_router\n    20→from webhooks.ghl_provider import router as ghl_webhook_router\n    21→from webhooks.zapi_receiver import router as zapi_webhook_router\n    22→from admin.dashboard import router as admin_router\n    23→from admin.ai_agent import router as admin_ai_agent_router\n    24→\n    25→# =============================================================================\n    26→# Configuração do APScheduler (Tokens)\n    27→# =============================================================================\n    28→scheduler = AsyncIOScheduler()\n    29→\n    30→async def refresh_tokens_job():\n    31→    logger.info(\"Executando job periódico de refresh de tokens...\")\n    32→    await token_manager.refresh_all_tokens()\n    33→\n    34→from data.database import Base, engine, SessionLocal\n    35→from data.models import ChatHistory\n    36→\n    37→# =============================================================================\n    38→# Limpeza periódica de histórico antigo\n    39→# =============================================================================\n    40→def cleanup_old_chat_history(days: int = 30):\n    41→    \"\"\"Remove entradas de chat_histories com mais de `days` dias.\"\"\"\n    42→    from datetime import datetime, timezone, timedelta\n    43→    cutoff = datetime.now(timezone.utc) - timedelta(days=days)\n    44→    db = SessionLocal()\n    45→    try:\n    46→        deleted = db.query(ChatHistory).filter(ChatHistory.created_at < cutoff).delete()\n    47→        db.commit()\n    48→        if deleted:\n    49→            logger.info(f\"Limpeza de histórico: {deleted} mensagens antigas removidas (>{days} dias).\")\n    50→        else:\n    51→            logger.debug(\"Limpeza de histórico: nenhuma mensagem antiga encontrada.\")\n    52→    except Exception as e:\n    53→        logger.error(f\"Erro na limpeza de histórico: {e}\")\n    54→        db.rollback()\n    55→    finally:\n    56→        db.close()\n    57→\n    58→\n    59→# =============================================================================\n    60→# Ciclo de Vida do FastAPI (Start/Shutdown)\n    61→# =============================================================================\n    62→@asynccontextmanager\n    63→async def lifespan(app: FastAPI):\n    64→    # 1. Cria tabelas novas que ainda não existem no banco (idempotente)\n    65→    Base.metadata.create_all(bind=engine)\n    66→    logger.info(\"Tabelas do banco de dados verificadas/criadas.\")\n    67→\n    68→    # 2. Aplica migrações de schema via Alembic (adiciona colunas, etc.)\n    69→    import os\n    70→    from alembic.config import Config as AlembicConfig\n    71→    from alembic import command as alembic_command\n    72→    try:\n    73→        alembic_cfg = AlembicConfig(os.path.join(os.path.dirname(__file__), \"alembic.ini\"))\n    74→        alembic_command.upgrade(alembic_cfg, \"head\")\n    75→        logger.info(\"Migrações Alembic aplicadas com sucesso.\")\n    76→    except Exception as e:\n    77→        logger.error(f\"Erro ao aplicar migrações Alembic: {e}\", exc_info=True)\n    78→\n    79→    # Inicializa scheduler de token refresh a cada 12 horas (proteção)\n    80→    # E roda imediatamente na subida\n    81→    logger.info(\"Axen WP Server iniciando...\")\n    82→    scheduler.add_job(refresh_tokens_job, \"interval\", hours=12)\n    83→    scheduler.add_job(cleanup_old_chat_history, \"interval\", hours=24)\n    84→    scheduler.start()\n    85→    \n    86→    await refresh_tokens_job()\n    87→    cleanup_old_chat_history()\n    88→    \n    89→    yield\n    90→    \n    91→    logger.info(\"Desligando servidor...\")\n    92→    scheduler.shutdown()\n    93→\n    94→# =============================================================================\n    95→# App FastAPI\n    96→# =============================================================================\n    97→app = FastAPI(\n    98→    title=\"Axen WP - WhatsApp Automation\",\n    99→    description=\"Hub de integração GHL Custom Conversation Provider e Z-API\",\n   100→    version=\"1.0.0\",\n   101→    lifespan=lifespan\n   102→)\n   103→\n   104→# CORS: restrito a origens configuradas; em debug mode permite tudo\n   105→_cors_origins = (\n   106→    [o.strip() for o in settings.allowed_origins.split(\",\") if o.strip()]\n   107→    if settings.allowed_origins\n   108→    else []\n   109→)\n   110→if not _cors_origins and not settings.debug:\n   111→    logger.warning(\n   112→        \"ALLOWED_ORIGINS nao configurado e DEBUG=false. \"\n   113→        \"CORS bloqueara requests cross-origin. \"\n   114→        \"Configure ALLOWED_ORIGINS no .env.\"\n   115→    )\n   116→\n   117→app.add_middleware(\n   118→    CORSMiddleware,\n   119→    allow_origins=_cors_origins if _cors_origins else ([\"*\"] if settings.debug else []),\n   120→    allow_credentials=True,\n   121→    allow_methods=[\"*\"],\n   122→    allow_headers=[\"*\"],\n   123→)\n   124→\n   125→# Registro de Rotas\n   126→app.include_router(oauth_router)\n   127→app.include_router(ghl_webhook_router)\n   128→app.include_router(zapi_webhook_router)\n   129→app.include_router(admin_router)\n   130→app.include_router(admin_ai_agent_router)\n   131→\n   132→\n   133→# Montagem de arquivos estáticos\n   134→app.mount(\"/static\", StaticFiles(directory=\"web/static\"), name=\"static\")\n   135→\n   136→@app.get(\"/favicon.ico\", include_in_schema=False)\n   137→async def favicon():\n   138→    return FileResponse(\"web/static/favicon.svg\", media_type=\"image/svg+xml\")\n   139→\n   140→@app.get(\"/\", tags=[\"Health\"])\n   141→async def root():\n   142→    # Redireciona a raiz para o admin se acessada no navegador\n   143→    from fastapi.responses import RedirectResponse\n   144→    return RedirectResponse(url=\"/admin/dashboard\", status_code=303)\n   145→\n   146→\n   147→@app.get(\"/health\", tags=[\"Health\"])\n   148→async def health_check():\n   149→    \"\"\"Retorna estado do servidor e os tenants ativos.\"\"\"\n   150→    tenants = token_manager.get_all_tenants()\n   151→    active_tenants = []\n   152→    \n   153→    for t in tenants:\n   154→        active_tenants.append({\n   155→            \"company\": t.company_name,\n   156→            \"location_id\": t.location_id,\n   157→            \"token_valid\": not t.is_token_expired,\n   158→            \"zapi_configured\": bool(t.zapi_instance_id and t.zapi_token),\n   159→            \"zapi_instance_id\": t.zapi_instance_id\n   160→        })\n   161→        \n   162→    return {\n   163→        \"status\": \"healthy\",\n   164→        \"tenants_loaded\": len(tenants),\n   165→        \"tenants\": active_tenants\n   166→    }\n   167→\n   168→\n   169→if __name__ == \"__main__\":\n   170→    logger.info(f\"Starting uvicorn server on {settings.host}:{settings.port}...\")\n   171→    uvicorn.run(\"main:app\", host=settings.host, port=settings.port, reload=settings.debug)\n   172→"}]},"parent_tool_use_id":null,"session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"30be9686-2b15-4f92-bae7-683446f8fdc4","timestamp":"2026-03-20T16:40:57.017Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/main.py","content":"\"\"\"\nPonto de entrada do servidor FastAPI do Axen WP.\n\"\"\"\n\nfrom fastapi import FastAPI\nfrom fastapi.middleware.cors import CORSMiddleware\nfrom fastapi.staticfiles import StaticFiles\nfrom fastapi.responses import FileResponse\nimport uvicorn\nfrom contextlib import asynccontextmanager\n\nfrom apscheduler.schedulers.asyncio import AsyncIOScheduler\n\nfrom utils.logger import logger\nfrom utils.config import settings\nfrom auth.token_manager import token_manager\n\n# Importa as rotas\nfrom auth.oauth import router as oauth_router\nfrom webhooks.ghl_provider import router as ghl_webhook_router\nfrom webhooks.zapi_receiver import router as zapi_webhook_router\nfrom admin.dashboard import router as admin_router\nfrom admin.ai_agent import router as admin_ai_agent_router\n\n# =============================================================================\n# Configuração do APScheduler (Tokens)\n# =============================================================================\nscheduler = AsyncIOScheduler()\n\nasync def refresh_tokens_job():\n    logger.info(\"Executando job periódico de refresh de tokens...\")\n    await token_manager.refresh_all_tokens()\n\nfrom data.database import Base, engine, SessionLocal\nfrom data.models import ChatHistory\n\n# =============================================================================\n# Limpeza periódica de histórico antigo\n# =============================================================================\ndef cleanup_old_chat_history(days: int = 30):\n    \"\"\"Remove entradas de chat_histories com mais de `days` dias.\"\"\"\n    from datetime import datetime, timezone, timedelta\n    cutoff = datetime.now(timezone.utc) - timedelta(days=days)\n    db = SessionLocal()\n    try:\n        deleted = db.query(ChatHistory).filter(ChatHistory.created_at < cutoff).delete()\n        db.commit()\n        if deleted:\n            logger.info(f\"Limpeza de histórico: {deleted} mensagens antigas removidas (>{days} dias).\")\n        else:\n            logger.debug(\"Limpeza de histórico: nenhuma mensagem antiga encontrada.\")\n    except Exception as e:\n        logger.error(f\"Erro na limpeza de histórico: {e}\")\n        db.rollback()\n    finally:\n        db.close()\n\n\n# =============================================================================\n# Ciclo de Vida do FastAPI (Start/Shutdown)\n# =============================================================================\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    # 1. Cria tabelas novas que ainda não existem no banco (idempotente)\n    Base.metadata.create_all(bind=engine)\n    logger.info(\"Tabelas do banco de dados verificadas/criadas.\")\n\n    # 2. Aplica migrações de schema via Alembic (adiciona colunas, etc.)\n    import os\n    from alembic.config import Config as AlembicConfig\n    from alembic import command as alembic_command\n    try:\n        alembic_cfg = AlembicConfig(os.path.join(os.path.dirname(__file__), \"alembic.ini\"))\n        alembic_command.upgrade(alembic_cfg, \"head\")\n        logger.info(\"Migrações Alembic aplicadas com sucesso.\")\n    except Exception as e:\n        logger.error(f\"Erro ao aplicar migrações Alembic: {e}\", exc_info=True)\n\n    # Inicializa scheduler de token refresh a cada 12 horas (proteção)\n    # E roda imediatamente na subida\n    logger.info(\"Axen WP Server iniciando...\")\n    scheduler.add_job(refresh_tokens_job, \"interval\", hours=12)\n    scheduler.add_job(cleanup_old_chat_history, \"interval\", hours=24)\n    scheduler.start()\n    \n    await refresh_tokens_job()\n    cleanup_old_chat_history()\n    \n    yield\n    \n    logger.info(\"Desligando servidor...\")\n    scheduler.shutdown()\n\n# =============================================================================\n# App FastAPI\n# =============================================================================\napp = FastAPI(\n    title=\"Axen WP - WhatsApp Automation\",\n    description=\"Hub de integração GHL Custom Conversation Provider e Z-API\",\n    version=\"1.0.0\",\n    lifespan=lifespan\n)\n\n# CORS: restrito a origens configuradas; em debug mode permite tudo\n_cors_origins = (\n    [o.strip() for o in settings.allowed_origins.split(\",\") if o.strip()]\n    if settings.allowed_origins\n    else []\n)\nif not _cors_origins and not settings.debug:\n    logger.warning(\n        \"ALLOWED_ORIGINS nao configurado e DEBUG=false. \"\n        \"CORS bloqueara requests cross-origin. \"\n        \"Configure ALLOWED_ORIGINS no .env.\"\n    )\n\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=_cors_origins if _cors_origins else ([\"*\"] if settings.debug else []),\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\n# Registro de Rotas\napp.include_router(oauth_router)\napp.include_router(ghl_webhook_router)\napp.include_router(zapi_webhook_router)\napp.include_router(admin_router)\napp.include_router(admin_ai_agent_router)\n\n\n# Montagem de arquivos estáticos\napp.mount(\"/static\", StaticFiles(directory=\"web/static\"), name=\"static\")\n\n@app.get(\"/favicon.ico\", include_in_schema=False)\nasync def favicon():\n    return FileResponse(\"web/static/favicon.svg\", media_type=\"image/svg+xml\")\n\n@app.get(\"/\", tags=[\"Health\"])\nasync def root():\n    # Redireciona a raiz para o admin se acessada no navegador\n    from fastapi.responses import RedirectResponse\n    return RedirectResponse(url=\"/admin/dashboard\", status_code=303)\n\n\n@app.get(\"/health\", tags=[\"Health\"])\nasync def health_check():\n    \"\"\"Retorna estado do servidor e os tenants ativos.\"\"\"\n    tenants = token_manager.get_all_tenants()\n    active_tenants = []\n    \n    for t in tenants:\n        active_tenants.append({\n            \"company\": t.company_name,\n            \"location_id\": t.location_id,\n            \"token_valid\": not t.is_token_expired,\n            \"zapi_configured\": bool(t.zapi_instance_id and t.zapi_token),\n            \"zapi_instance_id\": t.zapi_instance_id\n        })\n        \n    return {\n        \"status\": \"healthy\",\n        \"tenants_loaded\": len(tenants),\n        \"tenants\": active_tenants\n    }\n\n\nif __name__ == \"__main__\":\n    logger.info(f\"Starting uvicorn server on {settings.host}:{settings.port}...\")\n    uvicorn.run(\"main:app\", host=settings.host, port=settings.port, reload=settings.debug)\n","numLines":172,"startLine":1,"totalLines":172}}}
