{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D3Z7juYzzvqCjMTnLefhu1","type":"tool_result","content":"     1→\"\"\"\n     2→Cliente HTTP para a API do GoHighLevel.\n     3→Gerencia envio de mensagens inbound, atualização de status e contatos.\n     4→\"\"\"\n     5→\n     6→import httpx\n     7→\n     8→from utils.config import settings\n     9→from utils.logger import logger\n    10→from auth.token_manager import token_manager\n    11→\n    12→\n    13→class GHLService:\n    14→    \"\"\"Serviço para interagir com a API do GoHighLevel.\"\"\"\n    15→\n    16→    BASE_URL = settings.ghl_api_base\n    17→    \n    18→    # Cache para os mapeamentos de Custom Fields por Location ID\n    19→    # formato: {\"location_id\": {\"Nome do Campo\": \"id_do_campo\"}}\n    20→    _custom_fields_cache = {}\n    21→\n    22→    async def _get_headers(self, location_id: str) -> dict | None:\n    23→        \"\"\"Monta os headers com o token válido do tenant.\"\"\"\n    24→        token = await token_manager.get_valid_token(location_id)\n    25→        if not token:\n    26→            logger.error(f\"Sem token válido para location {location_id}\")\n    27→            return None\n    28→        return {\n    29→            \"Authorization\": f\"Bearer {token}\",\n    30→            \"Content-Type\": \"application/json\",\n    31→            \"Version\": \"2021-07-28\",\n    32→        }\n    33→\n    34→    async def send_inbound_message(\n    35→        self,\n    36→        location_id: str,\n    37→        phone: str,\n    38→        message: str,\n    39→        attachments: list[str] | None = None,\n    40→        conversation_provider_id: str = \"\",\n    41→        contact_id: str | None = None,\n    42→        direction: str = \"inbound\"\n    43→    ) -> dict | None:\n    44→        \"\"\"\n    45→        Registra uma mensagem inbound (recebida do WhatsApp) no CRM.\n    46→        POST /conversations/messages/inbound\n    47→        \"\"\"\n    48→        headers = await self._get_headers(location_id)\n    49→        if not headers:\n    50→            return None\n    51→\n    52→        tenant = token_manager.get_tenant(location_id)\n    53→        provider_id = conversation_provider_id or (\n    54→            tenant.conversation_provider_id if tenant else \"\"\n    55→        )\n    56→\n    57→        # Formatar telefone no padrão internacional (com +)\n    58→        formatted_phone = phone.strip()\n    59→        if not formatted_phone.startswith(\"+\"):\n    60→            formatted_phone = f\"+{formatted_phone}\"\n    61→\n    62→        payload = {\n    63→            \"type\": \"SMS\",\n    64→            \"locationId\": location_id,\n    65→            \"phone\": formatted_phone,\n    66→            \"message\": message,\n    67→            \"direction\": direction,\n    68→        }\n    69→\n    70→        if contact_id:\n    71→            payload[\"contactId\"] = contact_id\n    72→\n    73→        if provider_id:\n    74→            payload[\"conversationProviderId\"] = provider_id\n    75→\n    76→        if attachments:\n    77→            payload[\"attachments\"] = attachments\n    78→\n    79→        try:\n    80→            async with httpx.AsyncClient(timeout=30.0) as client:\n    81→                response = await client.post(\n    82→                    f\"{self.BASE_URL}/conversations/messages/inbound\",\n    83→                    json=payload,\n    84→                    headers=headers,\n    85→                )\n    86→\n    87→                if response.status_code in (200, 201):\n    88→                    data = response.json()\n    89→                    logger.info(\n    90→                        f\"Mensagem inbound registrada no GHL: \"\n    91→                        f\"phone={formatted_phone}, location={location_id}\"\n    92→                    )\n    93→                    return data\n    94→                else:\n    95→                    body_data = {}\n    96→                    try:\n    97→                        body_data = response.json()\n    98→                    except:\n    99→                        body_data = {\"text\": response.text}\n   100→\n   101→                    logger.error(\n   102→                        f\"Erro ao registrar inbound no GHL: \"\n   103→                        f\"status={response.status_code}, body={response.text}\"\n   104→                    )\n   105→                    return {\"error\": True, \"status_code\": response.status_code, \"body\": body_data}\n   106→\n   107→        except Exception as e:\n   108→            logger.error(f\"Exceção ao enviar inbound para GHL: {e}\")\n   109→            return {\"error\": True, \"status_code\": 500, \"body\": {\"message\": str(e)}}\n   110→\n   111→    async def update_message_status(\n   112→        self,\n   113→        location_id: str,\n   114→        message_id: str,\n   115→        status: str = \"delivered\",\n   116→        error_code: str | None = None,\n   117→        error_message: str | None = None,\n   118→    ) -> bool:\n   119→        \"\"\"\n   120→        Atualiza o status de uma mensagem outbound.\n   121→        PUT /conversations/messages/{messageId}/status\n   122→        \"\"\"\n   123→        headers = await self._get_headers(location_id)\n   124→        if not headers:\n   125→            return False\n   126→\n   127→        payload = {\"status\": status}\n   128→        if error_code or error_message:\n   129→            payload[\"error\"] = {\n   130→                \"code\": error_code or \"API_ERROR\",\n   131→                \"message\": error_message or \"Unknown error\"\n   132→            }\n   133→\n   134→        try:\n   135→            async with httpx.AsyncClient(timeout=30.0) as client:\n   136→                response = await client.put(\n   137→                    f\"{self.BASE_URL}/conversations/messages/{message_id}/status\",\n   138→                    json=payload,\n   139→                    headers=headers,\n   140→                )\n   141→\n   142→                if response.status_code == 200:\n   143→                    logger.info(\n   144→                        f\"Status da mensagem {message_id} atualizado para '{status}'\"\n   145→                    )\n   146→                    return True\n   147→                else:\n   148→                    logger.error(\n   149→                        f\"Erro ao atualizar status da mensagem: \"\n   150→                        f\"status={response.status_code}, body={response.text}\"\n   151→                    )\n   152→                    return False\n   153→\n   154→        except Exception as e:\n   155→            logger.error(f\"Exceção ao atualizar status de mensagem: {e}\")\n   156→            return False\n   157→\n   158→    async def get_contact(self, location_id: str, contact_id: str) -> dict | None:\n   159→        \"\"\"\n   160→        Busca um contato pelo ID para descobrir o telefone.\n   161→        GET /contacts/{contactId}\n   162→        \"\"\"\n   163→        headers = await self._get_headers(location_id)\n   164→        if not headers:\n   165→            return None\n   166→\n   167→        try:\n   168→            async with httpx.AsyncClient(timeout=30.0) as client:\n   169→                response = await client.get(\n   170→                    f\"{self.BASE_URL}/contacts/{contact_id}\",\n   171→                    headers=headers,\n   172→                )\n   173→\n   174→                if response.status_code == 200:\n   175→                    data = response.json()\n   176→                    return data.get(\"contact\", {})\n   177→                else:\n   178→                    logger.warning(\n   179→                        f\"Busca de contato por ID retornou status {response.status_code}: {response.text}\"\n   180→                    )\n   181→                    return None\n   182→        except Exception as e:\n   183→            logger.error(f\"Exceção ao buscar contato por ID: {e}\")\n   184→            return None\n   185→\n   186→    async def search_contact_by_phone(\n   187→        self, location_id: str, phone: str\n   188→    ) -> dict | None:\n   189→        \"\"\"\n   190→        Busca um contato pelo telefone.\n   191→        Tenta buscar o número exato. Se for do Brasil (+55) e tiver DDD, \n   192→        tenta buscar a variação com/sem o 9º dígito para evitar duplicidade.\n   193→        GET /contacts/search?query={phone}&locationId={locationId}\n   194→        \"\"\"\n   195→        headers = await self._get_headers(location_id)\n   196→        if not headers:\n   197→            return None\n   198→\n   199→        async def _do_search(query_phone: str):\n   200→            try:\n   201→                async with httpx.AsyncClient(timeout=30.0) as client:\n   202→                    response = await client.get(\n   203→                        f\"{self.BASE_URL}/contacts/search\",\n   204→                        params={\"query\": query_phone, \"locationId\": location_id},\n   205→                        headers=headers,\n   206→                    )\n   207→                    if response.status_code == 200:\n   208→                        data = response.json()\n   209→                        contacts = data.get(\"contacts\", [])\n   210→                        if contacts:\n   211→                            return contacts[0]\n   212→                    return None\n   213→            except Exception as e:\n   214→                logger.error(f\"Exceção ao buscar contato ({query_phone}): {e}\")\n   215→                return None\n   216→\n   217→        # 1. Garante que o número comece com '+' para a API do GHL entender que é um telefone\n   218→        clean_phone = phone.strip()\n   219→        if not clean_phone.startswith(\"+\"):\n   220→            clean_phone = f\"+{clean_phone}\"\n   221→\n   222→        contact = await _do_search(clean_phone)\n   223→        if contact:\n   224→            return contact\n   225→\n   226→        # 2. Se for Brasil (+55), tenta a variação do 9º dígito\n   227→        if clean_phone.startswith(\"+55\") and len(clean_phone) in (13, 14):\n   228→            # +55 (3 chars) + DDD (2 chars) + Número (8 ou 9 chars)\n   229→            ddd = clean_phone[3:5]\n   230→            numero = clean_phone[5:]\n   231→            \n   232→            alt_phone = None\n   233→            if len(numero) == 9 and numero.startswith(\"9\"):\n   234→                # Tem 9, vamos buscar sem o 9\n   235→                alt_phone = f\"+55{ddd}{numero[1:]}\"\n   236→            elif len(numero) == 8:\n   237→                # Não tem 9, vamos buscar com o 9\n   238→                alt_phone = f\"+55{ddd}9{numero}\"\n   239→\n   240→            if alt_phone:\n   241→                logger.info(f\"Contato não encontrado com {clean_phone}. Tentando variação BR: {alt_phone}\")\n   242→                contact_alt = await _do_search(alt_phone)\n   243→                if contact_alt:\n   244→                    return contact_alt\n   245→\n   246→        return None\n   247→\n   248→    async def create_contact(\n   249→        self, location_id: str, phone: str, name: str = \"\", email: str = \"\"\n   250→    ) -> dict | None:\n   251→        \"\"\"\n   252→        Cria um novo contato no GHL.\n   253→        Se for um @lid, não enviamos como \"phone\" para não dar erro de formatação na API.\n   254→        POST /contacts/\n   255→        \"\"\"\n   256→        headers = await self._get_headers(location_id)\n   257→        if not headers:\n   258→            return None\n   259→\n   260→        first_name = name or phone\n   261→        payload = {\n   262→            \"locationId\": location_id,\n   263→            \"firstName\": first_name,\n   264→        }\n   265→        \n   266→        # Só envia 'phone' se for um número de verdade\n   267→        if \"@lid\" not in phone:\n   268→            formatted_phone = phone.strip()\n   269→            if not formatted_phone.startswith(\"+\"):\n   270→                formatted_phone = f\"+{formatted_phone}\"\n   271→            payload[\"phone\"] = formatted_phone\n   272→\n   273→        if email:\n   274→            payload[\"email\"] = email\n   275→\n   276→        try:\n   277→            async with httpx.AsyncClient(timeout=30.0) as client:\n   278→                response = await client.post(\n   279→                    f\"{self.BASE_URL}/contacts/\",\n   280→                    json=payload,\n   281→                    headers=headers,\n   282→                )\n   283→                if response.status_code in (200, 201):\n   284→                    data = response.json()\n   285→                    logger.info(f\"Novo contato criado no GHL: {phone}\")\n   286→                    return data.get(\"contact\", {})\n   287→                else:\n   288→                    logger.error(f\"Erro ao criar contato {phone}: {response.text}\")\n   289→                    return None\n   290→        except Exception as e:\n   291→            logger.error(f\"Exceção ao criar contato: {e}\")\n   292→            return None\n   293→\n   294→    async def _get_custom_field_id_by_name(self, location_id: str, field_name: str) -> str | None:\n   295→        \"\"\"Busca e faz cache do ID de um Custom Field com base no seu nome.\"\"\"\n   296→        if location_id in self._custom_fields_cache and field_name in self._custom_fields_cache[location_id]:\n   297→            return self._custom_fields_cache[location_id][field_name]\n   298→            \n   299→        headers = await self._get_headers(location_id)\n   300→        if not headers:\n   301→            return None\n   302→            \n   303→        try:\n   304→            async with httpx.AsyncClient(timeout=30.0) as client:\n   305→                response = await client.get(\n   306→                    f\"{self.BASE_URL}/locations/{location_id}/customFields\",\n   307→                    headers=headers,\n   308→                )\n   309→                if response.status_code == 200:\n   310→                    data = response.json()\n   311→                    fields = data.get(\"customFields\", [])\n   312→                    \n   313→                    if location_id not in self._custom_fields_cache:\n   314→                        self._custom_fields_cache[location_id] = {}\n   315→                        \n   316→                    for field in fields:\n   317→                        self._custom_fields_cache[location_id][field[\"name\"]] = field[\"id\"]\n   318→                        \n   319→                    return self._custom_fields_cache[location_id].get(field_name)\n   320→                else:\n   321→                    logger.warning(f\"Erro ao buscar Custom Fields da location {location_id}: {response.text}\")\n   322→                    return None\n   323→        except Exception as e:\n   324→            logger.error(f\"Exceção ao buscar custom fields: {e}\")\n   325→            return None\n   326→\n   327→    async def is_ai_active_for_contact(self, location_id: str, contact_id: str) -> bool:\n   328→        \"\"\"\n   329→        Verifica se o contato tem o Custom Field 'Status IA' com o valor 'Ativada'.\n   330→        \"\"\"\n   331→        field_id = await self._get_custom_field_id_by_name(location_id, \"Status IA\")\n   332→        if not field_id:\n   333→            logger.debug(f\"Custom Field 'Status IA' não encontrado na location {location_id}.\")\n   334→            return False\n   335→            \n   336→        contact = await self.get_contact(location_id, contact_id)\n   337→        if not contact:\n   338→            return False\n   339→            \n   340→        custom_fields = contact.get(\"customFields\", [])\n   341→        for cf in custom_fields:\n   342→            if cf.get(\"id\") == field_id:\n   343→                # O valor pode ser uma lista dependendo do tipo do campo, ou uma string.\n   344→                val = cf.get(\"value\")\n   345→                if isinstance(val, list):\n   346→                    return \"Ativada\" in val\n   347→                elif isinstance(val, str):\n   348→                    return val.strip().lower() == \"ativada\"\n   349→                    \n   350→        return False\n   351→\n   352→\n   353→\n   354→# Instância global\n   355→ghl_service = GHLService()\n   356→"}]},"parent_tool_use_id":null,"session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"5be0692b-2acb-4698-a03e-6f26d5cb8ac6","timestamp":"2026-03-20T16:39:07.776Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/services/ghl_service.py","content":"\"\"\"\nCliente HTTP para a API do GoHighLevel.\nGerencia envio de mensagens inbound, atualização de status e contatos.\n\"\"\"\n\nimport httpx\n\nfrom utils.config import settings\nfrom utils.logger import logger\nfrom auth.token_manager import token_manager\n\n\nclass GHLService:\n    \"\"\"Serviço para interagir com a API do GoHighLevel.\"\"\"\n\n    BASE_URL = settings.ghl_api_base\n    \n    # Cache para os mapeamentos de Custom Fields por Location ID\n    # formato: {\"location_id\": {\"Nome do Campo\": \"id_do_campo\"}}\n    _custom_fields_cache = {}\n\n    async def _get_headers(self, location_id: str) -> dict | None:\n        \"\"\"Monta os headers com o token válido do tenant.\"\"\"\n        token = await token_manager.get_valid_token(location_id)\n        if not token:\n            logger.error(f\"Sem token válido para location {location_id}\")\n            return None\n        return {\n            \"Authorization\": f\"Bearer {token}\",\n            \"Content-Type\": \"application/json\",\n            \"Version\": \"2021-07-28\",\n        }\n\n    async def send_inbound_message(\n        self,\n        location_id: str,\n        phone: str,\n        message: str,\n        attachments: list[str] | None = None,\n        conversation_provider_id: str = \"\",\n        contact_id: str | None = None,\n        direction: str = \"inbound\"\n    ) -> dict | None:\n        \"\"\"\n        Registra uma mensagem inbound (recebida do WhatsApp) no CRM.\n        POST /conversations/messages/inbound\n        \"\"\"\n        headers = await self._get_headers(location_id)\n        if not headers:\n            return None\n\n        tenant = token_manager.get_tenant(location_id)\n        provider_id = conversation_provider_id or (\n            tenant.conversation_provider_id if tenant else \"\"\n        )\n\n        # Formatar telefone no padrão internacional (com +)\n        formatted_phone = phone.strip()\n        if not formatted_phone.startswith(\"+\"):\n            formatted_phone = f\"+{formatted_phone}\"\n\n        payload = {\n            \"type\": \"SMS\",\n            \"locationId\": location_id,\n            \"phone\": formatted_phone,\n            \"message\": message,\n            \"direction\": direction,\n        }\n\n        if contact_id:\n            payload[\"contactId\"] = contact_id\n\n        if provider_id:\n            payload[\"conversationProviderId\"] = provider_id\n\n        if attachments:\n            payload[\"attachments\"] = attachments\n\n        try:\n            async with httpx.AsyncClient(timeout=30.0) as client:\n                response = await client.post(\n                    f\"{self.BASE_URL}/conversations/messages/inbound\",\n                    json=payload,\n                    headers=headers,\n                )\n\n                if response.status_code in (200, 201):\n                    data = response.json()\n                    logger.info(\n                        f\"Mensagem inbound registrada no GHL: \"\n                        f\"phone={formatted_phone}, location={location_id}\"\n                    )\n                    return data\n                else:\n                    body_data = {}\n                    try:\n                        body_data = response.json()\n                    except:\n                        body_data = {\"text\": response.text}\n\n                    logger.error(\n                        f\"Erro ao registrar inbound no GHL: \"\n                        f\"status={response.status_code}, body={response.text}\"\n                    )\n                    return {\"error\": True, \"status_code\": response.status_code, \"body\": body_data}\n\n        except Exception as e:\n            logger.error(f\"Exceção ao enviar inbound para GHL: {e}\")\n            return {\"error\": True, \"status_code\": 500, \"body\": {\"message\": str(e)}}\n\n    async def update_message_status(\n        self,\n        location_id: str,\n        message_id: str,\n        status: str = \"delivered\",\n        error_code: str | None = None,\n        error_message: str | None = None,\n    ) -> bool:\n        \"\"\"\n        Atualiza o status de uma mensagem outbound.\n        PUT /conversations/messages/{messageId}/status\n        \"\"\"\n        headers = await self._get_headers(location_id)\n        if not headers:\n            return False\n\n        payload = {\"status\": status}\n        if error_code or error_message:\n            payload[\"error\"] = {\n                \"code\": error_code or \"API_ERROR\",\n                \"message\": error_message or \"Unknown error\"\n            }\n\n        try:\n            async with httpx.AsyncClient(timeout=30.0) as client:\n                response = await client.put(\n                    f\"{self.BASE_URL}/conversations/messages/{message_id}/status\",\n                    json=payload,\n                    headers=headers,\n                )\n\n                if response.status_code == 200:\n                    logger.info(\n                        f\"Status da mensagem {message_id} atualizado para '{status}'\"\n                    )\n                    return True\n                else:\n                    logger.error(\n                        f\"Erro ao atualizar status da mensagem: \"\n                        f\"status={response.status_code}, body={response.text}\"\n                    )\n                    return False\n\n        except Exception as e:\n            logger.error(f\"Exceção ao atualizar status de mensagem: {e}\")\n            return False\n\n    async def get_contact(self, location_id: str, contact_id: str) -> dict | None:\n        \"\"\"\n        Busca um contato pelo ID para descobrir o telefone.\n        GET /contacts/{contactId}\n        \"\"\"\n        headers = await self._get_headers(location_id)\n        if not headers:\n            return None\n\n        try:\n            async with httpx.AsyncClient(timeout=30.0) as client:\n                response = await client.get(\n                    f\"{self.BASE_URL}/contacts/{contact_id}\",\n                    headers=headers,\n                )\n\n                if response.status_code == 200:\n                    data = response.json()\n                    return data.get(\"contact\", {})\n                else:\n                    logger.warning(\n                        f\"Busca de contato por ID retornou status {response.status_code}: {response.text}\"\n                    )\n                    return None\n        except Exception as e:\n            logger.error(f\"Exceção ao buscar contato por ID: {e}\")\n            return None\n\n    async def search_contact_by_phone(\n        self, location_id: str, phone: str\n    ) -> dict | None:\n        \"\"\"\n        Busca um contato pelo telefone.\n        Tenta buscar o número exato. Se for do Brasil (+55) e tiver DDD, \n        tenta buscar a variação com/sem o 9º dígito para evitar duplicidade.\n        GET /contacts/search?query={phone}&locationId={locationId}\n        \"\"\"\n        headers = await self._get_headers(location_id)\n        if not headers:\n            return None\n\n        async def _do_search(query_phone: str):\n            try:\n                async with httpx.AsyncClient(timeout=30.0) as client:\n                    response = await client.get(\n                        f\"{self.BASE_URL}/contacts/search\",\n                        params={\"query\": query_phone, \"locationId\": location_id},\n                        headers=headers,\n                    )\n                    if response.status_code == 200:\n                        data = response.json()\n                        contacts = data.get(\"contacts\", [])\n                        if contacts:\n                            return contacts[0]\n                    return None\n            except Exception as e:\n                logger.error(f\"Exceção ao buscar contato ({query_phone}): {e}\")\n                return None\n\n        # 1. Garante que o número comece com '+' para a API do GHL entender que é um telefone\n        clean_phone = phone.strip()\n        if not clean_phone.startswith(\"+\"):\n            clean_phone = f\"+{clean_phone}\"\n\n        contact = await _do_search(clean_phone)\n        if contact:\n            return contact\n\n        # 2. Se for Brasil (+55), tenta a variação do 9º dígito\n        if clean_phone.startswith(\"+55\") and len(clean_phone) in (13, 14):\n            # +55 (3 chars) + DDD (2 chars) + Número (8 ou 9 chars)\n            ddd = clean_phone[3:5]\n            numero = clean_phone[5:]\n            \n            alt_phone = None\n            if len(numero) == 9 and numero.startswith(\"9\"):\n                # Tem 9, vamos buscar sem o 9\n                alt_phone = f\"+55{ddd}{numero[1:]}\"\n            elif len(numero) == 8:\n                # Não tem 9, vamos buscar com o 9\n                alt_phone = f\"+55{ddd}9{numero}\"\n\n            if alt_phone:\n                logger.info(f\"Contato não encontrado com {clean_phone}. Tentando variação BR: {alt_phone}\")\n                contact_alt = await _do_search(alt_phone)\n                if contact_alt:\n                    return contact_alt\n\n        return None\n\n    async def create_contact(\n        self, location_id: str, phone: str, name: str = \"\", email: str = \"\"\n    ) -> dict | None:\n        \"\"\"\n        Cria um novo contato no GHL.\n        Se for um @lid, não enviamos como \"phone\" para não dar erro de formatação na API.\n        POST /contacts/\n        \"\"\"\n        headers = await self._get_headers(location_id)\n        if not headers:\n            return None\n\n        first_name = name or phone\n        payload = {\n            \"locationId\": location_id,\n            \"firstName\": first_name,\n        }\n        \n        # Só envia 'phone' se for um número de verdade\n        if \"@lid\" not in phone:\n            formatted_phone = phone.strip()\n            if not formatted_phone.startswith(\"+\"):\n                formatted_phone = f\"+{formatted_phone}\"\n            payload[\"phone\"] = formatted_phone\n\n        if email:\n            payload[\"email\"] = email\n\n        try:\n            async with httpx.AsyncClient(timeout=30.0) as client:\n                response = await client.post(\n                    f\"{self.BASE_URL}/contacts/\",\n                    json=payload,\n                    headers=headers,\n                )\n                if response.status_code in (200, 201):\n                    data = response.json()\n                    logger.info(f\"Novo contato criado no GHL: {phone}\")\n                    return data.get(\"contact\", {})\n                else:\n                    logger.error(f\"Erro ao criar contato {phone}: {response.text}\")\n                    return None\n        except Exception as e:\n            logger.error(f\"Exceção ao criar contato: {e}\")\n            return None\n\n    async def _get_custom_field_id_by_name(self, location_id: str, field_name: str) -> str | None:\n        \"\"\"Busca e faz cache do ID de um Custom Field com base no seu nome.\"\"\"\n        if location_id in self._custom_fields_cache and field_name in self._custom_fields_cache[location_id]:\n            return self._custom_fields_cache[location_id][field_name]\n            \n        headers = await self._get_headers(location_id)\n        if not headers:\n            return None\n            \n        try:\n            async with httpx.AsyncClient(timeout=30.0) as client:\n                response = await client.get(\n                    f\"{self.BASE_URL}/locations/{location_id}/customFields\",\n                    headers=headers,\n                )\n                if response.status_code == 200:\n                    data = response.json()\n                    fields = data.get(\"customFields\", [])\n                    \n                    if location_id not in self._custom_fields_cache:\n                        self._custom_fields_cache[location_id] = {}\n                        \n                    for field in fields:\n                        self._custom_fields_cache[location_id][field[\"name\"]] = field[\"id\"]\n                        \n                    return self._custom_fields_cache[location_id].get(field_name)\n                else:\n                    logger.warning(f\"Erro ao buscar Custom Fields da location {location_id}: {response.text}\")\n                    return None\n        except Exception as e:\n            logger.error(f\"Exceção ao buscar custom fields: {e}\")\n            return None\n\n    async def is_ai_active_for_contact(self, location_id: str, contact_id: str) -> bool:\n        \"\"\"\n        Verifica se o contato tem o Custom Field 'Status IA' com o valor 'Ativada'.\n        \"\"\"\n        field_id = await self._get_custom_field_id_by_name(location_id, \"Status IA\")\n        if not field_id:\n            logger.debug(f\"Custom Field 'Status IA' não encontrado na location {location_id}.\")\n            return False\n            \n        contact = await self.get_contact(location_id, contact_id)\n        if not contact:\n            return False\n            \n        custom_fields = contact.get(\"customFields\", [])\n        for cf in custom_fields:\n            if cf.get(\"id\") == field_id:\n                # O valor pode ser uma lista dependendo do tipo do campo, ou uma string.\n                val = cf.get(\"value\")\n                if isinstance(val, list):\n                    return \"Ativada\" in val\n                elif isinstance(val, str):\n                    return val.strip().lower() == \"ativada\"\n                    \n        return False\n\n\n\n# Instância global\nghl_service = GHLService()\n","numLines":356,"startLine":1,"totalLines":356}}}
