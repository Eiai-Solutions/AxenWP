{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KjDd3PbhLFiTo1y7JyyGqP","type":"tool_result","content":"     1→\"\"\"\n     2→Configurações globais carregadas do .env.\n     3→\"\"\"\n     4→\n     5→from pydantic_settings import BaseSettings\n     6→from pydantic import Field\n     7→\n     8→\n     9→class Settings(BaseSettings):\n    10→    \"\"\"Configurações da aplicação. Valores lidos do arquivo .env.\"\"\"\n    11→\n    12→    # GoHighLevel App\n    13→    ghl_client_id: str = Field(default=\"\", description=\"Client ID do app no Marketplace\")\n    14→    ghl_client_secret: str = Field(default=\"\", description=\"Client Secret do app\")\n    15→    ghl_redirect_uri: str = Field(\n    16→        default=\"http://localhost:8000/oauth/callback\",\n    17→        description=\"URI de callback OAuth\",\n    18→    )\n    19→    ghl_conversation_provider_id: str = Field(\n    20→        default=\"\", description=\"ID do Conversation Provider Axen WP\"\n    21→    )\n    22→\n    23→    database_url: str = Field(\n    24→        default=\"sqlite:///./data/axenwp.db\",\n    25→        description=\"URL de conexão com o banco de dados (ex: postgresql://...)\"\n    26→    )\n    27→\n    28→    # Servidor\n    29→    host: str = Field(default=\"0.0.0.0\")\n    30→    port: int = Field(default=8000)\n    31→\n    32→    # Segurança\n    33→    zapi_webhook_secret: str = Field(\n    34→        default=\"\", description=\"Token para validar webhooks do Z-API\"\n    35→    )\n    36→    allowed_origins: str = Field(\n    37→        default=\"\",\n    38→        description=\"Origens permitidas para CORS (separadas por virgula). Ex: https://app.example.com,https://admin.example.com\"\n    39→    )\n    40→    debug: bool = Field(default=False, description=\"Modo debug (habilita reload, CORS permissivo, etc.)\")\n    41→\n    42→    # Logs\n    43→    log_level: str = Field(default=\"INFO\")\n    44→\n    45→    # GHL API Base\n    46→    ghl_api_base: str = Field(\n    47→        default=\"https://services.leadconnectorhq.com\",\n    48→        description=\"Base URL da API GHL\",\n    49→    )\n    50→\n    51→    class Config:\n    52→        env_file = \".env\"\n    53→        env_file_encoding = \"utf-8\"\n    54→\n    55→\n    56→# Instância global\n    57→settings = Settings()\n    58→"}]},"parent_tool_use_id":null,"session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"65c35410-81c3-49d6-91ef-126682ad604d","timestamp":"2026-03-20T16:40:35.146Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/utils/config.py","content":"\"\"\"\nConfigurações globais carregadas do .env.\n\"\"\"\n\nfrom pydantic_settings import BaseSettings\nfrom pydantic import Field\n\n\nclass Settings(BaseSettings):\n    \"\"\"Configurações da aplicação. Valores lidos do arquivo .env.\"\"\"\n\n    # GoHighLevel App\n    ghl_client_id: str = Field(default=\"\", description=\"Client ID do app no Marketplace\")\n    ghl_client_secret: str = Field(default=\"\", description=\"Client Secret do app\")\n    ghl_redirect_uri: str = Field(\n        default=\"http://localhost:8000/oauth/callback\",\n        description=\"URI de callback OAuth\",\n    )\n    ghl_conversation_provider_id: str = Field(\n        default=\"\", description=\"ID do Conversation Provider Axen WP\"\n    )\n\n    database_url: str = Field(\n        default=\"sqlite:///./data/axenwp.db\",\n        description=\"URL de conexão com o banco de dados (ex: postgresql://...)\"\n    )\n\n    # Servidor\n    host: str = Field(default=\"0.0.0.0\")\n    port: int = Field(default=8000)\n\n    # Segurança\n    zapi_webhook_secret: str = Field(\n        default=\"\", description=\"Token para validar webhooks do Z-API\"\n    )\n    allowed_origins: str = Field(\n        default=\"\",\n        description=\"Origens permitidas para CORS (separadas por virgula). Ex: https://app.example.com,https://admin.example.com\"\n    )\n    debug: bool = Field(default=False, description=\"Modo debug (habilita reload, CORS permissivo, etc.)\")\n\n    # Logs\n    log_level: str = Field(default=\"INFO\")\n\n    # GHL API Base\n    ghl_api_base: str = Field(\n        default=\"https://services.leadconnectorhq.com\",\n        description=\"Base URL da API GHL\",\n    )\n\n    class Config:\n        env_file = \".env\"\n        env_file_encoding = \"utf-8\"\n\n\n# Instância global\nsettings = Settings()\n","numLines":58,"startLine":1,"totalLines":58}}}
