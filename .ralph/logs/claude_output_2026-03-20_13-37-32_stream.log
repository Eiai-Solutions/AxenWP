{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013sa1KqmboyR4bkrLLUgd82","type":"tool_result","content":"     1→import logging\n     2→import re\n     3→from typing import Optional\n     4→from fastapi import APIRouter, Depends, Form, HTTPException, Request\n     5→import httpx\n     6→from fastapi.responses import HTMLResponse, RedirectResponse\n     7→from fastapi.templating import Jinja2Templates\n     8→\n     9→from data.database import get_db, SessionLocal\n    10→from data.models import Tenant, AIAgent, SystemSettings\n    11→from auth.token_manager import token_manager\n    12→from datetime import datetime\n    13→from pydantic import BaseModel\n    14→\n    15→router = APIRouter(prefix=\"/admin/agents\", tags=[\"admin_agents\"])\n    16→logger = logging.getLogger(__name__)\n    17→\n    18→# Reutilizando o mesmo diretório de templates\n    19→templates = Jinja2Templates(directory=\"web/templates\")\n    20→\n    21→@router.post(\"/{location_id}/save\")\n    22→async def save_agent_settings(\n    23→    location_id: str,\n    24→    name: str = Form(...),\n    25→    prompt: str = Form(...),\n    26→    model: str = Form(\"openai/gpt-4o\"),\n    27→    api_key: Optional[str] = Form(None),\n    28→    elevenlabs_api_key: Optional[str] = Form(None),\n    29→    elevenlabs_voice_id: Optional[str] = Form(None),\n    30→    elevenlabs_speed: float = Form(1.0),\n    31→    elevenlabs_stability: float = Form(0.5),\n    32→    elevenlabs_similarity: float = Form(0.75),\n    33→    groq_api_key: Optional[str] = Form(None),\n    34→    always_reply_with_audio: bool = Form(False),\n    35→    is_active: bool = Form(False),\n    36→    debounce_seconds: float = Form(1.5)\n    37→):\n    38→    \"\"\"\n    39→    Cria ou atualiza as configurações do Agente de IA para um Tenant específico.\n    40→    \"\"\"\n    41→    db = SessionLocal()\n    42→    try:\n    43→        tenant = db.query(Tenant).filter(Tenant.location_id == location_id).first()\n    44→        if not tenant:\n    45→            logger.error(f\"Tenant {location_id} não encontrado ao tentar salvar Agente IA.\")\n    46→            return RedirectResponse(url=\"/admin/dashboard?err=Tenant+não+encontrado\", status_code=303)\n    47→\n    48→        # Busca agente existente ou cria novo\n    49→        agent = db.query(AIAgent).filter(AIAgent.location_id == location_id).first()\n    50→\n    51→        if not agent:\n    52→            agent = AIAgent(location_id=location_id)\n    53→            db.add(agent)\n    54→\n    55→        agent.name = name\n    56→        agent.prompt = prompt\n    57→        agent.model = model\n    58→        agent.api_key = api_key\n    59→        agent.elevenlabs_api_key = elevenlabs_api_key\n    60→        agent.elevenlabs_voice_id = elevenlabs_voice_id\n    61→        agent.elevenlabs_speed = max(0.25, min(float(elevenlabs_speed), 4.0))\n    62→        agent.elevenlabs_stability = max(0.0, min(float(elevenlabs_stability), 1.0))\n    63→        agent.elevenlabs_similarity = max(0.0, min(float(elevenlabs_similarity), 1.0))\n    64→        agent.groq_api_key = groq_api_key\n    65→        agent.always_reply_with_audio = always_reply_with_audio\n    66→        agent.is_active = is_active\n    67→        agent.debounce_seconds = max(0.5, min(float(debounce_seconds), 30.0))\n    68→        agent.updated_at = datetime.utcnow()\n    69→\n    70→        db.commit()\n    71→        logger.info(f\"Configurações do Agente IA atualizadas para o Tenant {location_id}.\")\n    72→\n    73→        return RedirectResponse(url=\"/admin/dashboard?msg=Agente+IA+atualizado+com+sucesso\", status_code=303)\n    74→\n    75→    except Exception as e:\n    76→        db.rollback()\n    77→        logger.error(f\"Erro ao salvar Agente IA para o tenant {location_id}: {e}\", exc_info=True)\n    78→        return RedirectResponse(url=\"/admin/dashboard?err=Erro+ao+salvar+Agente+IA\", status_code=303)\n    79→    finally:\n    80→        db.close()\n    81→\n    82→@router.get(\"/elevenlabs/voices\")\n    83→async def get_elevenlabs_voices(api_key: str):\n    84→    \"\"\"\n    85→    Busca a lista de vozes disponíveis na conta da ElevenLabs usando a API Key fornecida.\n    86→    \"\"\"\n    87→    if not api_key:\n    88→        raise HTTPException(status_code=400, detail=\"API Key da ElevenLabs é obrigatória.\")\n    89→\n    90→    try:\n    91→        async with httpx.AsyncClient(timeout=10.0) as client:\n    92→            response = await client.get(\n    93→                \"https://api.elevenlabs.io/v1/voices\",\n    94→                headers={\"xi-api-key\": api_key}\n    95→            )\n    96→\n    97→            if response.status_code != 200:\n    98→                raise HTTPException(status_code=400, detail=\"Não foi possível verificar a API Key na ElevenLabs\")\n    99→\n   100→            data = response.json()"}]},"parent_tool_use_id":"toolu_01B8mnjTvTQtsNa3ZEvvAPWv","session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"3821733a-a4bf-44df-ad1d-6d5782bcd784","timestamp":"2026-03-20T16:37:59.107Z"}
