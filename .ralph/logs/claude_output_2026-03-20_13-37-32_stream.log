{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017sixHU4gWPEpvx1gszPW2S","type":"tool_result","content":"     1→\"\"\"\n     2→Rotas do Admin Dashboard.\n     3→Fornece interface baseada em cookies + jinja2 para gerenciar tenants.\n     4→\"\"\"\n     5→\n     6→from fastapi import APIRouter, Request, Form, Depends, Cookie\n     7→from fastapi.responses import HTMLResponse, RedirectResponse\n     8→from fastapi.templating import Jinja2Templates\n     9→from typing import Optional\n    10→import os\n    11→import hmac\n    12→import hashlib\n    13→\n    14→from utils.logger import logger\n    15→from utils.config import settings\n    16→from auth.token_manager import token_manager\n    17→from services.zapi_service import zapi_service\n    18→\n    19→router = APIRouter(prefix=\"/admin\", tags=[\"Admin UI\"])\n    20→templates = Jinja2Templates(directory=\"web/templates\")\n    21→\n    22→# Config da senha do Painel\n    23→ADMIN_PASSWORD = os.getenv(\"ADMIN_PASSWORD\", \"admin123\")\n    24→\n    25→\n    26→def _make_session_token(password: str) -> str:\n    27→    \"\"\"Deriva um token de sessão seguro a partir da senha (nunca expõe a senha no cookie).\"\"\"\n    28→    return hmac.new(password.encode(), b\"axenwp-admin-session\", hashlib.sha256).hexdigest()\n    29→\n    30→\n    31→def verify_admin(admin_session: Optional[str] = Cookie(None)) -> bool:\n    32→    \"\"\"Valida se o cookie da sessão é um token HMAC válido.\"\"\"\n    33→    expected = _make_session_token(ADMIN_PASSWORD)\n    34→    return hmac.compare_digest(admin_session or \"\", expected)\n    35→\n    36→\n    37→@router.get(\"/login\", response_class=HTMLResponse)\n    38→async def login_page(request: Request, error: str = None):\n    39→    return templates.TemplateResponse(\"login.html\", {\"request\": request, \"error\": error})\n    40→\n    41→\n    42→@router.post(\"/login\")\n    43→async def do_login(password: str = Form(...)):\n    44→    if password == ADMIN_PASSWORD:\n    45→        response = RedirectResponse(url=\"/admin/dashboard\", status_code=303)\n    46→        response.set_cookie(\n    47→            key=\"admin_session\",\n    48→            value=_make_session_token(password),\n    49→            httponly=True,\n    50→            samesite=\"lax\",\n    51→            max_age=86400 * 30,\n    52→        )\n    53→        return response\n    54→\n    55→    return RedirectResponse(url=\"/admin/login?error=Senha incorreta\", status_code=303)\n    56→\n    57→\n    58→@router.get(\"/logout\")\n    59→async def logout():\n    60→    response = RedirectResponse(url=\"/admin/login\", status_code=303)\n    61→    response.delete_cookie(\"admin_session\")\n    62→    return response\n    63→\n    64→\n    65→@router.get(\"/dashboard\", response_class=HTMLResponse)\n    66→async def dashboard_page(request: Request, msg: str = None, err: str = None, authenticated: bool = Depends(verify_admin)):\n    67→    if not authenticated:\n    68→        return RedirectResponse(url=\"/admin/login\", status_code=303)\n    69→\n    70→    tenants = token_manager.get_all_tenants()\n    71→    # Ordenar por data de criação ou nome da empresa\n    72→    tenants.sort(key=lambda x: x.company_name)\n    73→    \n    74→    # Busca os Agentes de IA e System Settings\n    75→    from data.database import SessionLocal\n    76→    from data.models import AIAgent, SystemSettings\n    77→    db = SessionLocal()\n    78→    agent_map = {}\n    79→    system_settings = None\n    80→    try:"}]},"parent_tool_use_id":"toolu_01B8mnjTvTQtsNa3ZEvvAPWv","session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"336ea443-99b3-4efb-b82d-1aa7ee641396","timestamp":"2026-03-20T16:38:10.505Z"}
