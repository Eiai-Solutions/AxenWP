{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WGWAe8im4X87GB8VWxkdQg","type":"tool_result","content":"     1→\"\"\"Add missing columns to tenants and ai_agents\n     2→\n     3→Revision ID: 001\n     4→Revises:\n     5→Create Date: 2026-03-11\n     6→\n     7→Migração idempotente: verifica existência de cada coluna antes de adicionar.\n     8→Seguro rodar múltiplas vezes ou em bancos que já tenham parte das colunas.\n     9→\"\"\"\n    10→from typing import Sequence, Union\n    11→\n    12→import sqlalchemy as sa\n    13→from alembic import op\n    14→\n    15→revision: str = \"001\"\n    16→down_revision: Union[str, None] = None\n    17→branch_labels: Union[str, Sequence[str], None] = None\n    18→depends_on: Union[str, Sequence[str], None] = None\n    19→\n    20→\n    21→def _column_exists(table: str, column: str) -> bool:\n    22→    bind = op.get_bind()\n    23→    inspector = sa.inspect(bind)\n    24→    return column in {c[\"name\"] for c in inspector.get_columns(table)}\n    25→\n    26→\n    27→def _table_exists(table: str) -> bool:\n    28→    bind = op.get_bind()\n    29→    inspector = sa.inspect(bind)\n    30→    return table in inspector.get_table_names()\n    31→\n    32→\n    33→def upgrade() -> None:\n    34→    # --- tenants ---\n    35→    if not _column_exists(\"tenants\", \"is_active\"):\n    36→        op.add_column(\"tenants\", sa.Column(\"is_active\", sa.Boolean(), nullable=True, server_default=sa.text(\"true\")))\n    37→\n    38→    # --- ai_agents ---\n    39→    if _table_exists(\"ai_agents\"):\n    40→        if not _column_exists(\"ai_agents\", \"elevenlabs_api_key\"):\n    41→            op.add_column(\"ai_agents\", sa.Column(\"elevenlabs_api_key\", sa.String(255), nullable=True))\n    42→\n    43→        if not _column_exists(\"ai_agents\", \"elevenlabs_voice_id\"):\n    44→            op.add_column(\"ai_agents\", sa.Column(\"elevenlabs_voice_id\", sa.String(100), nullable=True))\n    45→\n    46→        if not _column_exists(\"ai_agents\", \"always_reply_with_audio\"):\n    47→            op.add_column(\"ai_agents\", sa.Column(\"always_reply_with_audio\", sa.Boolean(), nullable=True, server_default=sa.text(\"false\")))\n    48→\n    49→        if not _column_exists(\"ai_agents\", \"updated_at\"):\n    50→            op.add_column(\"ai_agents\", sa.Column(\"updated_at\", sa.DateTime(), nullable=True))\n    51→\n    52→    # --- system_settings (criada pelo create_all, mas garantimos aqui também) ---\n    53→    if not _table_exists(\"system_settings\"):\n    54→        op.create_table(\n    55→            \"system_settings\",\n    56→            sa.Column(\"id\", sa.Integer(), primary_key=True, index=True),\n    57→            sa.Column(\"admin_openrouter_key\", sa.String(512), nullable=True),\n    58→            sa.Column(\"admin_openrouter_model\", sa.String(100), nullable=True, server_default=sa.text(\"'openai/gpt-4o'\")),\n    59→            sa.Column(\"updated_at\", sa.DateTime(), nullable=True),\n    60→        )\n    61→\n    62→\n    63→def downgrade() -> None:\n    64→    # Downgrade intencional não destrói dados — apenas documenta a reversão lógica\n    65→    pass\n    66→"}]},"parent_tool_use_id":"toolu_01B8mnjTvTQtsNa3ZEvvAPWv","session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"cde1130f-27fb-4059-a1f7-b87071051590","timestamp":"2026-03-20T16:38:04.067Z"}
