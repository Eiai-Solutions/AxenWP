{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015myUz7trvV6YEuASrECuUY","type":"tool_result","content":"     1→\"\"\"\n     2→Gerenciamento de tokens OAuth do GoHighLevel usando PostgreSQL (SQLAlchemy).\n     3→Renova tokens automaticamente quando expiram.\n     4→\"\"\"\n     5→\n     6→from datetime import datetime, timezone, timedelta\n     7→from typing import Optional\n     8→\n     9→import httpx\n    10→from sqlalchemy.orm import Session\n    11→\n    12→from utils.logger import logger\n    13→from utils.config import settings\n    14→from data.database import SessionLocal\n    15→from data.models import Tenant\n    16→\n    17→class TokenManager:\n    18→    \"\"\"Gerencia tokens de todos os tenants armazenados no bando de dados.\"\"\"\n    19→\n    20→    def __init__(self):\n    21→        pass\n    22→\n    23→    def get_tenant(self, location_id: str, db: Session = None) -> Optional[Tenant]:\n    24→        \"\"\"Retorna o tenant pelo location_id a partir do banco de dados.\"\"\"\n    25→        session = db or SessionLocal()\n    26→        try:\n    27→            return session.query(Tenant).filter(Tenant.location_id == location_id).first()\n    28→        finally:\n    29→            if not db:\n    30→                session.close()\n    31→\n    32→    def get_all_tenants(self, db: Session = None) -> list[Tenant]:\n    33→        \"\"\"Retorna todos os tenants cadastrados no banco.\"\"\"\n    34→        session = db or SessionLocal()\n    35→        try:\n    36→            return session.query(Tenant).all()\n    37→        finally:\n    38→            if not db:\n    39→                session.close()\n    40→\n    41→    def register_tenant(\n    42→        self,\n    43→        location_id: str,\n    44→        company_name: str,\n    45→        access_token: str,\n    46→        refresh_token: str,\n    47→        expires_in: int,\n    48→        client_id: str = \"\",\n    49→        client_secret: str = \"\",\n    50→        **extras,\n    51→    ) -> Tenant:\n    52→        \"\"\"Registra (ou atualiza) um tenant com os dados do OAuth no DB.\"\"\"\n    53→        expires_at = datetime.now(timezone.utc) + timedelta(seconds=expires_in)\n    54→\n    55→        db = SessionLocal()\n    56→        try:\n    57→            tenant = self.get_tenant(location_id, db=db)\n    58→            if not tenant:\n    59→                tenant = Tenant(location_id=location_id)\n    60→                db.add(tenant)\n    61→\n    62→            tenant.company_name = company_name or tenant.company_name\n    63→            tenant.client_id = client_id or tenant.client_id or settings.ghl_client_id\n    64→            tenant.client_secret = client_secret or tenant.client_secret or settings.ghl_client_secret\n    65→            tenant.access_token = access_token\n    66→            tenant.refresh_token = refresh_token\n    67→            tenant.token_expires_at = expires_at.isoformat()\n    68→            \n    69→            # Atualiza extras se existirem\n    70→            for key, value in extras.items():\n    71→                if hasattr(tenant, key):\n    72→                    setattr(tenant, key, value)\n    73→\n    74→            db.commit()\n    75→            db.refresh(tenant)\n    76→            \n    77→            logger.info(f\"Tenant {tenant.company_name} ({tenant.location_id}) registrado no banco\")\n    78→            return tenant\n    79→        finally:\n    80→            db.close()\n    81→            \n    82→    def update_zapi_credentials(self, location_id: str, instance_id: str, token: str, client_token: str = \"\"):\n    83→        \"\"\"Atualiza as credenciais Z-API de um determinado tenant.\"\"\"\n    84→        db = SessionLocal()\n    85→        try:\n    86→            tenant = self.get_tenant(location_id, db=db)\n    87→            if tenant:\n    88→                tenant.zapi_instance_id = instance_id\n    89→                tenant.zapi_token = token\n    90→                tenant.zapi_client_token = client_token\n    91→                db.commit()\n    92→                logger.info(f\"Credenciais Z-API salvas no banco para {tenant.company_name}\")\n    93→        finally:\n    94→            db.close()\n    95→\n    96→    def toggle_active_status(self, location_id: str, is_active: bool):\n    97→        \"\"\"Ativa/desativa a automação inteira no nível do Tenant.\"\"\"\n    98→        db = SessionLocal()\n    99→        try:\n   100→            tenant = self.get_tenant(location_id, db=db)\n   101→            if tenant:\n   102→                tenant.is_active = is_active\n   103→                db.commit()\n   104→                logger.info(f\"Automação de {tenant.company_name} alterada para {'ATIVA' if is_active else 'PAUSADA'}\")\n   105→        finally:\n   106→            db.close()\n   107→\n   108→    def is_token_expired(self, tenant: Tenant) -> bool:\n   109→        \"\"\"Verifica se o access_token está expirado ou prestes a expirar.\"\"\"\n   110→        if not tenant.token_expires_at:\n   111→            return True\n   112→        try:\n   113→            expires = datetime.fromisoformat(tenant.token_expires_at.replace(\"Z\", \"+00:00\"))\n   114→            margin = timedelta(hours=1)\n   115→            return datetime.now(timezone.utc) >= (expires - margin)\n   116→        except (ValueError, TypeError):\n   117→            return True\n   118→\n   119→    async def get_valid_token(self, location_id: str) -> Optional[str]:\n   120→        \"\"\"\n   121→        Retorna um access_token válido.\n   122→        Se estiver expirado, faz o refresh automaticamente.\n   123→        \"\"\"\n   124→        tenant = self.get_tenant(location_id)\n   125→        if not tenant:\n   126→            logger.error(f\"Tenant {location_id} não encontrado\")\n   127→            return None\n   128→\n   129→        if not self.is_token_expired(tenant):\n   130→            return tenant.access_token\n   131→\n   132→        # Precisa renovar\n   133→        logger.info(f\"Token expirado para {tenant.company_name}, renovando...\")\n   134→        success = await self._refresh_token(tenant.location_id)\n   135→        if success:\n   136→            return self.get_tenant(location_id).access_token\n   137→\n   138→        logger.error(f\"Falha ao renovar token para {tenant.company_name}\")\n   139→        return None\n   140→\n   141→    async def _refresh_token(self, location_id: str) -> bool:\n   142→        \"\"\"Faz o refresh do access_token via API GHL.\"\"\"\n   143→        db = SessionLocal()\n   144→        try:\n   145→            tenant = self.get_tenant(location_id, db=db)\n   146→            if not tenant:\n   147→                return False\n   148→\n   149→            async with httpx.AsyncClient(timeout=30.0) as client:\n   150→                response = await client.post(\n   151→                    f\"{settings.ghl_api_base}/oauth/token\",\n   152→                    data={\n   153→                        \"client_id\": tenant.client_id,\n   154→                        \"client_secret\": tenant.client_secret,\n   155→                        \"grant_type\": \"refresh_token\",\n   156→                        \"refresh_token\": tenant.refresh_token,\n   157→                        \"user_type\": \"Location\",\n   158→                        \"redirect_uri\": settings.ghl_redirect_uri,\n   159→                    },\n   160→                    headers={\n   161→                        \"Accept\": \"application/json\",\n   162→                        \"Content-Type\": \"application/x-www-form-urlencoded\",\n   163→                    },\n   164→                )\n   165→\n   166→                if response.status_code != 200:\n   167→                    logger.error(\n   168→                        f\"Refresh falhou para {tenant.company_name}: \"\n   169→                        f\"status={response.status_code}, body={response.text}\"\n   170→                    )\n   171→                    return False\n   172→\n   173→                data = response.json()\n   174→                expires_at = datetime.now(timezone.utc) + timedelta(\n   175→                    seconds=data.get(\"expires_in\", 86399)\n   176→                )\n   177→\n   178→                tenant.access_token = data[\"access_token\"]\n   179→                tenant.refresh_token = data[\"refresh_token\"]\n   180→                tenant.token_expires_at = expires_at.isoformat()\n   181→\n   182→                db.commit()\n   183→\n   184→                logger.info(f\"Token renovado com sucesso para {tenant.company_name}\")\n   185→                return True\n   186→\n   187→        except Exception as e:\n   188→            logger.error(f\"Exceção ao renovar token: {e}\")\n   189→            return False\n   190→        finally:\n   191→            db.close()\n   192→\n   193→    async def refresh_all_tokens(self):\n   194→        \"\"\"Verifica e renova tokens de todos os tenants que estão prestes a expirar.\"\"\"\n   195→        logger.info(\"Verificando tokens de todos os tenants no banco...\")\n   196→        db = SessionLocal()\n   197→        try:\n   198→            tenants = db.query(Tenant).all()\n   199→            for tenant in tenants:\n   200→                if self.is_token_expired(tenant):\n   201→                    await self._refresh_token(tenant.location_id)\n   202→        finally:\n   203→            db.close()\n   204→\n   205→    # --- CONTACT MAPPING FUNCS ---\n   206→    def get_mapped_contact_id(self, location_id: str, phone_or_lid: str) -> Optional[str]:\n   207→        \"\"\"Tenta achar um ID de contato do GHL associado a um telefone_ou_lid no banco local.\"\"\"\n   208→        from data.models import ContactMapping\n   209→        db = SessionLocal()\n   210→        try:\n   211→            mapping = db.query(ContactMapping).filter_by(\n   212→                location_id=location_id, \n   213→                phone_or_lid=phone_or_lid\n   214→            ).first()\n   215→            return mapping.ghl_contact_id if mapping else None\n   216→        finally:\n   217→            db.close()\n   218→\n   219→    def save_contact_mapping(self, location_id: str, phone_or_lid: str, ghl_contact_id: str):\n   220→        \"\"\"Salva a associação entre o numero do WhatsApp (@lid) e o ID real do GHL.\"\"\"\n   221→        from data.models import ContactMapping\n   222→        db = SessionLocal()\n   223→        try:\n   224→            mapping_id = f\"{location_id}_{phone_or_lid}\"\n   225→            mapping = db.query(ContactMapping).filter_by(id=mapping_id).first()\n   226→            if not mapping:\n   227→                mapping = ContactMapping(\n   228→                    id=mapping_id,\n   229→                    location_id=location_id,\n   230→                    phone_or_lid=phone_or_lid,\n   231→                    ghl_contact_id=ghl_contact_id\n   232→                )\n   233→                db.add(mapping)\n   234→            else:\n   235→                mapping.ghl_contact_id = ghl_contact_id\n   236→            db.commit()\n   237→        except Exception as e:\n   238→            logger.error(f\"Erro ao salvar mapping de contato DB: {e}\")\n   239→        finally:\n   240→            db.close()\n   241→\n   242→    def delete_contact_mapping(self, location_id: str, phone_or_lid: str):\n   243→        \"\"\"Remove o mapeamento em caso de contato deletado no GHL.\"\"\"\n   244→        from data.models import ContactMapping\n   245→        db = SessionLocal()\n   246→        try:\n   247→            mapping_id = f\"{location_id}_{phone_or_lid}\"\n   248→            db.query(ContactMapping).filter_by(id=mapping_id).delete()\n   249→            db.commit()\n   250→        except Exception as e:\n   251→            logger.error(f\"Erro ao deletar mapping de contato DB: {e}\")\n   252→        finally:\n   253→            db.close()\n   254→\n   255→    # --- MESSAGE MAPPING FUNCS ---\n   256→    def save_message_mapping(self, zapi_message_id: str, ghl_message_id: str, location_id: str):\n   257→        \"\"\"Salva a associação entre o ID da mensagem na Z-API e no GHL.\"\"\"\n   258→        from data.models import MessageMapping\n   259→        db = SessionLocal()\n   260→        try:\n   261→            mapping = db.query(MessageMapping).filter_by(zapi_message_id=zapi_message_id).first()\n   262→            if not mapping:\n   263→                mapping = MessageMapping(\n   264→                    zapi_message_id=zapi_message_id,\n   265→                    ghl_message_id=ghl_message_id,\n   266→                    location_id=location_id\n   267→                )\n   268→                db.add(mapping)\n   269→            else:\n   270→                mapping.ghl_message_id = ghl_message_id\n   271→            db.commit()\n   272→        except Exception as e:\n   273→            logger.error(f\"Erro ao salvar mapping de mensagem DB: {e}\")\n   274→        finally:\n   275→            db.close()\n   276→\n   277→    def get_ghl_message_id_by_zapi(self, zapi_message_id: str) -> Optional[dict]:\n   278→        \"\"\"Tenta achar o ID da mensagem no GHL pelo ID da Z-API.\"\"\"\n   279→        from data.models import MessageMapping\n   280→        db = SessionLocal()\n   281→        try:\n   282→            mapping = db.query(MessageMapping).filter_by(zapi_message_id=zapi_message_id).first()\n   283→            if mapping:\n   284→                return {\n   285→                    \"ghl_message_id\": mapping.ghl_message_id,\n   286→                    \"location_id\": mapping.location_id\n   287→                }\n   288→            return None\n   289→        finally:\n   290→            db.close()\n   291→\n   292→# Instância global\n   293→token_manager = TokenManager()\n   294→"}]},"parent_tool_use_id":null,"session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"659fcde0-fcd4-4caf-9f99-a3e256562ae5","timestamp":"2026-03-20T16:39:08.927Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/auth/token_manager.py","content":"\"\"\"\nGerenciamento de tokens OAuth do GoHighLevel usando PostgreSQL (SQLAlchemy).\nRenova tokens automaticamente quando expiram.\n\"\"\"\n\nfrom datetime import datetime, timezone, timedelta\nfrom typing import Optional\n\nimport httpx\nfrom sqlalchemy.orm import Session\n\nfrom utils.logger import logger\nfrom utils.config import settings\nfrom data.database import SessionLocal\nfrom data.models import Tenant\n\nclass TokenManager:\n    \"\"\"Gerencia tokens de todos os tenants armazenados no bando de dados.\"\"\"\n\n    def __init__(self):\n        pass\n\n    def get_tenant(self, location_id: str, db: Session = None) -> Optional[Tenant]:\n        \"\"\"Retorna o tenant pelo location_id a partir do banco de dados.\"\"\"\n        session = db or SessionLocal()\n        try:\n            return session.query(Tenant).filter(Tenant.location_id == location_id).first()\n        finally:\n            if not db:\n                session.close()\n\n    def get_all_tenants(self, db: Session = None) -> list[Tenant]:\n        \"\"\"Retorna todos os tenants cadastrados no banco.\"\"\"\n        session = db or SessionLocal()\n        try:\n            return session.query(Tenant).all()\n        finally:\n            if not db:\n                session.close()\n\n    def register_tenant(\n        self,\n        location_id: str,\n        company_name: str,\n        access_token: str,\n        refresh_token: str,\n        expires_in: int,\n        client_id: str = \"\",\n        client_secret: str = \"\",\n        **extras,\n    ) -> Tenant:\n        \"\"\"Registra (ou atualiza) um tenant com os dados do OAuth no DB.\"\"\"\n        expires_at = datetime.now(timezone.utc) + timedelta(seconds=expires_in)\n\n        db = SessionLocal()\n        try:\n            tenant = self.get_tenant(location_id, db=db)\n            if not tenant:\n                tenant = Tenant(location_id=location_id)\n                db.add(tenant)\n\n            tenant.company_name = company_name or tenant.company_name\n            tenant.client_id = client_id or tenant.client_id or settings.ghl_client_id\n            tenant.client_secret = client_secret or tenant.client_secret or settings.ghl_client_secret\n            tenant.access_token = access_token\n            tenant.refresh_token = refresh_token\n            tenant.token_expires_at = expires_at.isoformat()\n            \n            # Atualiza extras se existirem\n            for key, value in extras.items():\n                if hasattr(tenant, key):\n                    setattr(tenant, key, value)\n\n            db.commit()\n            db.refresh(tenant)\n            \n            logger.info(f\"Tenant {tenant.company_name} ({tenant.location_id}) registrado no banco\")\n            return tenant\n        finally:\n            db.close()\n            \n    def update_zapi_credentials(self, location_id: str, instance_id: str, token: str, client_token: str = \"\"):\n        \"\"\"Atualiza as credenciais Z-API de um determinado tenant.\"\"\"\n        db = SessionLocal()\n        try:\n            tenant = self.get_tenant(location_id, db=db)\n            if tenant:\n                tenant.zapi_instance_id = instance_id\n                tenant.zapi_token = token\n                tenant.zapi_client_token = client_token\n                db.commit()\n                logger.info(f\"Credenciais Z-API salvas no banco para {tenant.company_name}\")\n        finally:\n            db.close()\n\n    def toggle_active_status(self, location_id: str, is_active: bool):\n        \"\"\"Ativa/desativa a automação inteira no nível do Tenant.\"\"\"\n        db = SessionLocal()\n        try:\n            tenant = self.get_tenant(location_id, db=db)\n            if tenant:\n                tenant.is_active = is_active\n                db.commit()\n                logger.info(f\"Automação de {tenant.company_name} alterada para {'ATIVA' if is_active else 'PAUSADA'}\")\n        finally:\n            db.close()\n\n    def is_token_expired(self, tenant: Tenant) -> bool:\n        \"\"\"Verifica se o access_token está expirado ou prestes a expirar.\"\"\"\n        if not tenant.token_expires_at:\n            return True\n        try:\n            expires = datetime.fromisoformat(tenant.token_expires_at.replace(\"Z\", \"+00:00\"))\n            margin = timedelta(hours=1)\n            return datetime.now(timezone.utc) >= (expires - margin)\n        except (ValueError, TypeError):\n            return True\n\n    async def get_valid_token(self, location_id: str) -> Optional[str]:\n        \"\"\"\n        Retorna um access_token válido.\n        Se estiver expirado, faz o refresh automaticamente.\n        \"\"\"\n        tenant = self.get_tenant(location_id)\n        if not tenant:\n            logger.error(f\"Tenant {location_id} não encontrado\")\n            return None\n\n        if not self.is_token_expired(tenant):\n            return tenant.access_token\n\n        # Precisa renovar\n        logger.info(f\"Token expirado para {tenant.company_name}, renovando...\")\n        success = await self._refresh_token(tenant.location_id)\n        if success:\n            return self.get_tenant(location_id).access_token\n\n        logger.error(f\"Falha ao renovar token para {tenant.company_name}\")\n        return None\n\n    async def _refresh_token(self, location_id: str) -> bool:\n        \"\"\"Faz o refresh do access_token via API GHL.\"\"\"\n        db = SessionLocal()\n        try:\n            tenant = self.get_tenant(location_id, db=db)\n            if not tenant:\n                return False\n\n            async with httpx.AsyncClient(timeout=30.0) as client:\n                response = await client.post(\n                    f\"{settings.ghl_api_base}/oauth/token\",\n                    data={\n                        \"client_id\": tenant.client_id,\n                        \"client_secret\": tenant.client_secret,\n                        \"grant_type\": \"refresh_token\",\n                        \"refresh_token\": tenant.refresh_token,\n                        \"user_type\": \"Location\",\n                        \"redirect_uri\": settings.ghl_redirect_uri,\n                    },\n                    headers={\n                        \"Accept\": \"application/json\",\n                        \"Content-Type\": \"application/x-www-form-urlencoded\",\n                    },\n                )\n\n                if response.status_code != 200:\n                    logger.error(\n                        f\"Refresh falhou para {tenant.company_name}: \"\n                        f\"status={response.status_code}, body={response.text}\"\n                    )\n                    return False\n\n                data = response.json()\n                expires_at = datetime.now(timezone.utc) + timedelta(\n                    seconds=data.get(\"expires_in\", 86399)\n                )\n\n                tenant.access_token = data[\"access_token\"]\n                tenant.refresh_token = data[\"refresh_token\"]\n                tenant.token_expires_at = expires_at.isoformat()\n\n                db.commit()\n\n                logger.info(f\"Token renovado com sucesso para {tenant.company_name}\")\n                return True\n\n        except Exception as e:\n            logger.error(f\"Exceção ao renovar token: {e}\")\n            return False\n        finally:\n            db.close()\n\n    async def refresh_all_tokens(self):\n        \"\"\"Verifica e renova tokens de todos os tenants que estão prestes a expirar.\"\"\"\n        logger.info(\"Verificando tokens de todos os tenants no banco...\")\n        db = SessionLocal()\n        try:\n            tenants = db.query(Tenant).all()\n            for tenant in tenants:\n                if self.is_token_expired(tenant):\n                    await self._refresh_token(tenant.location_id)\n        finally:\n            db.close()\n\n    # --- CONTACT MAPPING FUNCS ---\n    def get_mapped_contact_id(self, location_id: str, phone_or_lid: str) -> Optional[str]:\n        \"\"\"Tenta achar um ID de contato do GHL associado a um telefone_ou_lid no banco local.\"\"\"\n        from data.models import ContactMapping\n        db = SessionLocal()\n        try:\n            mapping = db.query(ContactMapping).filter_by(\n                location_id=location_id, \n                phone_or_lid=phone_or_lid\n            ).first()\n            return mapping.ghl_contact_id if mapping else None\n        finally:\n            db.close()\n\n    def save_contact_mapping(self, location_id: str, phone_or_lid: str, ghl_contact_id: str):\n        \"\"\"Salva a associação entre o numero do WhatsApp (@lid) e o ID real do GHL.\"\"\"\n        from data.models import ContactMapping\n        db = SessionLocal()\n        try:\n            mapping_id = f\"{location_id}_{phone_or_lid}\"\n            mapping = db.query(ContactMapping).filter_by(id=mapping_id).first()\n            if not mapping:\n                mapping = ContactMapping(\n                    id=mapping_id,\n                    location_id=location_id,\n                    phone_or_lid=phone_or_lid,\n                    ghl_contact_id=ghl_contact_id\n                )\n                db.add(mapping)\n            else:\n                mapping.ghl_contact_id = ghl_contact_id\n            db.commit()\n        except Exception as e:\n            logger.error(f\"Erro ao salvar mapping de contato DB: {e}\")\n        finally:\n            db.close()\n\n    def delete_contact_mapping(self, location_id: str, phone_or_lid: str):\n        \"\"\"Remove o mapeamento em caso de contato deletado no GHL.\"\"\"\n        from data.models import ContactMapping\n        db = SessionLocal()\n        try:\n            mapping_id = f\"{location_id}_{phone_or_lid}\"\n            db.query(ContactMapping).filter_by(id=mapping_id).delete()\n            db.commit()\n        except Exception as e:\n            logger.error(f\"Erro ao deletar mapping de contato DB: {e}\")\n        finally:\n            db.close()\n\n    # --- MESSAGE MAPPING FUNCS ---\n    def save_message_mapping(self, zapi_message_id: str, ghl_message_id: str, location_id: str):\n        \"\"\"Salva a associação entre o ID da mensagem na Z-API e no GHL.\"\"\"\n        from data.models import MessageMapping\n        db = SessionLocal()\n        try:\n            mapping = db.query(MessageMapping).filter_by(zapi_message_id=zapi_message_id).first()\n            if not mapping:\n                mapping = MessageMapping(\n                    zapi_message_id=zapi_message_id,\n                    ghl_message_id=ghl_message_id,\n                    location_id=location_id\n                )\n                db.add(mapping)\n            else:\n                mapping.ghl_message_id = ghl_message_id\n            db.commit()\n        except Exception as e:\n            logger.error(f\"Erro ao salvar mapping de mensagem DB: {e}\")\n        finally:\n            db.close()\n\n    def get_ghl_message_id_by_zapi(self, zapi_message_id: str) -> Optional[dict]:\n        \"\"\"Tenta achar o ID da mensagem no GHL pelo ID da Z-API.\"\"\"\n        from data.models import MessageMapping\n        db = SessionLocal()\n        try:\n            mapping = db.query(MessageMapping).filter_by(zapi_message_id=zapi_message_id).first()\n            if mapping:\n                return {\n                    \"ghl_message_id\": mapping.ghl_message_id,\n                    \"location_id\": mapping.location_id\n                }\n            return None\n        finally:\n            db.close()\n\n# Instância global\ntoken_manager = TokenManager()\n","numLines":294,"startLine":1,"totalLines":294}}}
