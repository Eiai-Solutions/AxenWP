{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VCXPXDZh5sE41RRUwxiTsC","type":"tool_result","content":"     1→import logging\n     2→import re\n     3→import base64\n     4→import tempfile\n     5→import os\n     6→from typing import List, Optional\n     7→from datetime import datetime\n     8→\n     9→import httpx\n    10→from langchain_openai import ChatOpenAI\n    11→from langchain_core.messages import HumanMessage, AIMessage, SystemMessage, BaseMessage\n    12→\n    13→from data.database import SessionLocal\n    14→from data.models import AIAgent, ChatHistory, Tenant\n    15→\n    16→logger = logging.getLogger(__name__)\n    17→\n    18→\n    19→async def transcribe_audio(audio_url: str, groq_api_key: str) -> Optional[str]:\n    20→    \"\"\"\n    21→    Baixa o áudio da URL (Z-API) e transcreve usando Groq Whisper (gratuito e rápido).\n    22→    Retorna o texto transcrito ou None em caso de erro.\n    23→    \"\"\"\n    24→    try:\n    25→        # 1. Baixar o áudio da Z-API\n    26→        async with httpx.AsyncClient(timeout=30.0, follow_redirects=True) as client:\n    27→            audio_resp = await client.get(audio_url)\n    28→            if audio_resp.status_code != 200:\n    29→                logger.error(f\"Erro ao baixar áudio da Z-API: status={audio_resp.status_code}\")\n    30→                return None\n    31→            audio_bytes = audio_resp.content\n    32→\n    33→        # 2. Salvar em arquivo temporário para enviar ao Groq\n    34→        with tempfile.NamedTemporaryFile(suffix=\".ogg\", delete=False) as tmp:\n    35→            tmp.write(audio_bytes)\n    36→            tmp_path = tmp.name\n    37→\n    38→        try:\n    39→            # 3. Enviar para Groq Whisper API (OpenAI-compatible)\n    40→            async with httpx.AsyncClient(timeout=60.0) as client:\n    41→                with open(tmp_path, \"rb\") as f:\n    42→                    resp = await client.post(\n    43→                        \"https://api.groq.com/openai/v1/audio/transcriptions\",\n    44→                        headers={\"Authorization\": f\"Bearer {groq_api_key}\"},\n    45→                        data={\n    46→                            \"model\": \"whisper-large-v3\",\n    47→                            \"language\": \"pt\",\n    48→                            \"response_format\": \"text\",\n    49→                        },\n    50→                        files={\"file\": (\"audio.ogg\", f, \"audio/ogg\")},\n    51→                    )\n    52→\n    53→                if resp.status_code == 200:\n    54→                    transcription = resp.text.strip()\n    55→                    logger.info(f\"Áudio transcrito com sucesso ({len(transcription)} chars): {transcription[:80]}...\")\n    56→                    return transcription\n    57→                else:\n    58→                    logger.error(f\"Erro na transcrição Groq Whisper: status={resp.status_code}, body={resp.text}\")\n    59→                    return None\n    60→        finally:\n    61→            os.unlink(tmp_path)\n    62→\n    63→    except Exception as e:\n    64→        logger.error(f\"Exceção ao transcrever áudio: {e}\")\n    65→        return None\n    66→\n    67→\n    68→def _contains_special_content(text: str) -> bool:\n    69→    \"\"\"\n    70→    Verifica se o texto contém conteúdo que ficaria bugado em TTS:\n    71→    - URLs / links (https://, www., .com, .com.br)\n    72→    - Emails (@)\n    73→    - Valores monetários (R$ 1.500,00)\n    74→    - Números longos (telefone, CEP, CNPJ, CPF)\n    75→    - Endereços (Rua, Av., Avenida, etc.)\n    76→    \"\"\"\n    77→    patterns = [\n    78→        r'https?://',                          # URLs\n    79→        r'www\\.',                              # Links www\n    80→        r'\\.[a-z]{2,3}\\.br\\b',                # Domínios .com.br, .org.br\n    81→        r'\\b\\w+\\.(com|net|org|io|app)\\b',     # Domínios genéricos\n    82→        r'@',                                  # Emails\n    83→        r'R\\$\\s*[\\d.,]+',                      # Valores em reais: R$ 1.500,00\n    84→        r'\\d{1,3}(?:\\.\\d{3})+,\\d{2}',         # Formato brasileiro de número: 1.500,00\n    85→        r'\\d{5}[\\-]?\\d{3}',                   # CEP: 01234-567 ou 01234567\n    86→        r'\\d{2}[\\.\\-]?\\d{3}[\\.\\-]?\\d{3}[\\/\\-]?\\d{4}[\\-]?\\d{2}',  # CNPJ\n    87→        r'\\d{3}[\\.\\-]?\\d{3}[\\.\\-]?\\d{3}[\\-]?\\d{2}',              # CPF\n    88→        r'\\(?\\d{2}\\)?\\s*\\d{4,5}[\\-\\s]?\\d{4}', # Telefone: (11) 99999-9999\n    89→        r'\\b(?:Rua|Av\\.|Avenida|Alameda|Travessa|Praça|Rodovia|Estrada|R\\.)\\s',  # Endereços\n    90→    ]\n    91→    combined = '|'.join(patterns)\n    92→    return bool(re.search(combined, text, re.IGNORECASE))\n    93→\n    94→class PostgresChatMessageHistory:\n    95→    \"\"\"Implementa o histórico de mensagens direto via SQLAlchemy (equivalente ao Postgres Chat Memory do n8n).\"\"\"\n    96→    \n    97→    def __init__(self, session_id: str):\n    98→        # A session_id idealmente será o location_id + telefone, por ex: \"location123__+55119999999\"\n    99→        self.session_id = session_id\n   100→        self.max_history = 20 # Mantém o contexto de no máximo N mensagens\n   101→\n   102→    @property\n   103→    def messages(self) -> List[BaseMessage]:\n   104→        db = SessionLocal()\n   105→        try:\n   106→            # Pega as últimas N mensagens\n   107→            records = db.query(ChatHistory).filter(\n   108→                ChatHistory.session_id == self.session_id\n   109→            ).order_by(ChatHistory.id.desc()).limit(self.max_history).all()\n   110→            \n   111→            # Reverte para ficar em ordem cronológica p/ o modelo\n   112→            records.reverse()\n   113→            \n   114→            msgs = []\n   115→            for r in records:\n   116→                if r.message_type == \"human\":\n   117→                    msgs.append(HumanMessage(content=r.content))\n   118→                elif r.message_type == \"ai\":\n   119→                    msgs.append(AIMessage(content=r.content))\n   120→            return msgs\n   121→        finally:\n   122→            db.close()\n   123→            \n   124→    def add_user_message(self, message: str) -> None:\n   125→        self._add_message(\"human\", message)\n   126→        \n   127→    def add_ai_message(self, message: str) -> None:\n   128→        self._add_message(\"ai\", message)\n   129→        \n   130→    def _add_message(self, type_: str, content: str) -> None:\n   131→        db = SessionLocal()\n   132→        try:\n   133→            history = ChatHistory(\n   134→                session_id=self.session_id,\n   135→                message_type=type_,\n   136→                content=content\n   137→            )\n   138→            db.add(history)\n   139→            db.commit()\n   140→        except Exception as e:\n   141→            logger.error(f\"Erro ao salvar mensagem no histórico: {e}\")\n   142→            db.rollback()\n   143→        finally:\n   144→            db.close()\n   145→\n   146→\n   147→class AIEngine:\n   148→    \"\"\"Core do motor IA integrando OpenRouter via LangChain e Memória persistente PostgreSQL.\"\"\"\n   149→    \n   150→    def __init__(self, agent_data: AIAgent):\n   151→        self.agent_config = agent_data\n   152→        # Inicializa o LLM via OpenRouter usando a biblioteca oficial OpenAI com base_url\n   153→        # (já que OpenRouter é OpenAI-compatible)\n   154→        \n   155→        # Só inicializa se tiver chave\n   156→        self.llm = None\n   157→        if self.agent_config.api_key:\n   158→            try:\n   159→                self.llm = ChatOpenAI(\n   160→                    model=self.agent_config.model,\n   161→                    api_key=self.agent_config.api_key,\n   162→                    base_url=\"https://openrouter.ai/api/v1\",\n   163→                    temperature=0.3,\n   164→                    max_tokens=1000,\n   165→                    model_kwargs={\n   166→                        # Headers extras úteis no OpenRouter (opcional mas recomendado)\n   167→                        \"extra_headers\": {\n   168→                            \"HTTP-Referer\": \"https://axenwp.com\",\n   169→                            \"X-Title\": \"AxenWP IA Engine\"\n   170→                        }\n   171→                    }\n   172→                )\n   173→            except Exception as e:\n   174→                logger.error(f\"Erro ao instanciar LLM OpenRouter: {e}\")\n   175→\n   176→    async def generate_response(\n   177→        self, user_phone: str, user_message: str,\n   178→        is_audio: bool = False, audio_url: Optional[str] = None,\n   179→    ) -> Optional[dict]:\n   180→        \"\"\"\n   181→        Recebe a mensagem do usuário, busca o histórico e gera a resposta com o LLM.\n   182→        Retorna um dicionário: {\"type\": \"text\"|\"audio\", \"content\": <string ou base64>, \"text\": <str>}\n   183→        \"\"\"\n   184→        if not self.agent_config.is_active or not self.llm:\n   185→            logger.info(\"Agente IA inativo ou sem API Key configurada. Ignorando processamento cognitivo.\")\n   186→            return None\n   187→\n   188→        # ── Transcrição de áudio (STT) ──\n   189→        actual_message = user_message\n   190→        if is_audio and audio_url and self.agent_config.groq_api_key:\n   191→            logger.info(f\"Áudio recebido de {user_phone}. Transcrevendo via Groq Whisper...\")\n   192→            transcription = await transcribe_audio(audio_url, self.agent_config.groq_api_key)\n   193→            if transcription:\n   194→                actual_message = transcription\n   195→            else:\n   196→                logger.warning(\"Falha na transcrição. Usando mensagem original como fallback.\")\n   197→        elif is_audio and not self.agent_config.groq_api_key:\n   198→            logger.warning(\"Áudio recebido mas Groq API Key não configurada. Ignorando transcrição.\")\n   199→\n   200→        # Identificador único de sessão de memória\n   201→        session_id = f\"{self.agent_config.location_id}_{user_phone}\"\n   202→        memory = PostgresChatMessageHistory(session_id)\n   203→\n   204→        # Recupera histórico\n   205→        past_messages = memory.messages\n   206→        logger.info(f\"Histórico carregado para {user_phone}: {len(past_messages)} mensagens (session: {session_id})\")\n   207→\n   208→        # Monta as mensagens diretamente (sem template string) para evitar\n   209→        # conflito com {} no prompt do usuário\n   210→        messages_for_llm: list[BaseMessage] = [\n   211→            SystemMessage(content=self.agent_config.prompt),\n   212→            *past_messages,\n   213→            HumanMessage(content=actual_message),\n   214→        ]\n   215→\n   216→        try:\n   217→            # Invoca o LLM de forma assíncrona para não bloquear o event loop\n   218→            response = await self.llm.ainvoke(messages_for_llm)\n   219→\n   220→            ai_text = response.content\n   221→\n   222→            # Se deu certo, salva ambas as mensagens no banco (Humano + IA)\n   223→            memory.add_user_message(actual_message)\n   224→            memory.add_ai_message(ai_text)\n   225→            logger.info(f\"Histórico salvo para {user_phone}: user='{actual_message[:50]}...' ai='{ai_text[:50]}...'\")\n   226→\n   227→            # ── Decisão: responder com áudio ou texto ──\n   228→            # Regra: cliente mandou áudio → responde áudio / cliente mandou texto → responde texto\n   229→            should_send_audio = is_audio\n   230→\n   231→            # Exceção: fallback para texto se a resposta contém conteúdo especial\n   232→            # (R$, URLs, endereços, CPF, CNPJ, telefone, etc.)\n   233→            if should_send_audio and _contains_special_content(ai_text):\n   234→                logger.info(\"Resposta contém conteúdo especial (R$, URL, endereço, etc.). Fallback para texto.\")\n   235→                should_send_audio = False\n   236→\n   237→            # ── Gerar áudio via ElevenLabs (TTS) ──\n   238→            if should_send_audio and self.agent_config.elevenlabs_api_key and self.agent_config.elevenlabs_voice_id:\n   239→                try:\n   240→                    logger.info(f\"Gerando áudio via ElevenLabs (VoiceID: {self.agent_config.elevenlabs_voice_id})...\")\n   241→                    async with httpx.AsyncClient(timeout=30.0) as client:\n   242→                        # output_format=ogg_opus → formato nativo de mensagem de voz do WhatsApp (PTT com ondas)\n   243→                        speed = float(self.agent_config.elevenlabs_speed or 1.0)\n   244→                        stability = float(self.agent_config.elevenlabs_stability or 0.5)\n   245→                        similarity = float(self.agent_config.elevenlabs_similarity or 0.75)\n   246→\n   247→                        response_el = await client.post(\n   248→                            f\"https://api.elevenlabs.io/v1/text-to-speech/{self.agent_config.elevenlabs_voice_id}?output_format=ogg_opus\",\n   249→                            headers={\n   250→                                \"xi-api-key\": self.agent_config.elevenlabs_api_key,\n   251→                                \"Content-Type\": \"application/json\"\n   252→                            },\n   253→                            json={\n   254→                                \"text\": ai_text,\n   255→                                \"model_id\": \"eleven_multilingual_v2\",\n   256→                                \"voice_settings\": {\n   257→                                    \"stability\": stability,\n   258→                                    \"similarity_boost\": similarity,\n   259→                                    \"speed\": speed,\n   260→                                }\n   261→                            }\n   262→                        )\n   263→\n   264→                        if response_el.status_code == 200:\n   265→                            audio_content = response_el.content\n   266→                            b64_audio = base64.b64encode(audio_content).decode(\"utf-8\")\n   267→                            return {\"type\": \"audio\", \"content\": f\"data:audio/ogg;base64,{b64_audio}\", \"text\": ai_text}\n   268→                        else:\n   269→                            logger.error(f\"Erro ao gerar ElevenLabs: {response_el.text}. Fallback texto.\")\n   270→                except Exception as ex_el:\n   271→                    logger.error(f\"Exceção no ElevenLabs: {ex_el}. Fallback texto.\")\n   272→\n   273→            # Resposta Padrão de Texto\n   274→            return {\"type\": \"text\", \"content\": ai_text}\n   275→\n   276→        except Exception as e:\n   277→            logger.error(f\"Erro ao gerar resposta do Agente IA: {e}\")\n   278→            return None\n   279→\n   280→# Serviço singleton para instanciar/invocações fáceis\n   281→class AIService:\n   282→    # Cache: location_id -> (updated_at, AIEngine)\n   283→    _engine_cache: dict = {}\n   284→\n   285→    def get_agent_for_tenant(self, location_id: str) -> Optional[AIEngine]:\n   286→        db = SessionLocal()\n   287→        try:\n   288→            agent = db.query(AIAgent).filter(AIAgent.location_id == location_id).first()\n   289→            if not agent or not agent.is_active or not agent.api_key:\n   290→                self._engine_cache.pop(location_id, None)\n   291→                return None\n   292→\n   293→            # Retorna do cache se o agente não foi alterado desde a última vez\n   294→            cached = self._engine_cache.get(location_id)\n   295→            if cached and cached[0] == agent.updated_at:\n   296→                return cached[1]\n   297→\n   298→            engine = AIEngine(agent)\n   299→            self._engine_cache[location_id] = (agent.updated_at, engine)\n   300→            return engine\n   301→        finally:\n   302→            db.close()\n   303→            \n   304→    async def process_incoming_message(\n   305→        self, location_id: str, remote_jid: str, text_content: str,\n   306→        is_audio: bool = False, audio_url: Optional[str] = None,\n   307→    ) -> Optional[dict]:\n   308→        \"\"\"\n   309→        Gatilho unificado. Executa o Agente caso o inquilino tenha ativado e retorna um dict p/ zapi_receiver.\n   310→        \"\"\"\n   311→        engine = self.get_agent_for_tenant(location_id)\n   312→        if not engine:\n   313→            return None\n   314→\n   315→        # O JID geralmente vem no formato '5511... @s.whatsapp.net', limpar\n   316→        phone_number = remote_jid.split('@')[0] if '@' in remote_jid else remote_jid\n   317→\n   318→        return await engine.generate_response(\n   319→            user_phone=phone_number,\n   320→            user_message=text_content,\n   321→            is_audio=is_audio,\n   322→            audio_url=audio_url,\n   323→        )\n   324→\n   325→ai_service = AIService()\n   326→"}]},"parent_tool_use_id":null,"session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"50330232-78c4-4c70-b9f0-233a88b2f8da","timestamp":"2026-03-20T16:39:02.505Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/services/ai_service.py","content":"import logging\nimport re\nimport base64\nimport tempfile\nimport os\nfrom typing import List, Optional\nfrom datetime import datetime\n\nimport httpx\nfrom langchain_openai import ChatOpenAI\nfrom langchain_core.messages import HumanMessage, AIMessage, SystemMessage, BaseMessage\n\nfrom data.database import SessionLocal\nfrom data.models import AIAgent, ChatHistory, Tenant\n\nlogger = logging.getLogger(__name__)\n\n\nasync def transcribe_audio(audio_url: str, groq_api_key: str) -> Optional[str]:\n    \"\"\"\n    Baixa o áudio da URL (Z-API) e transcreve usando Groq Whisper (gratuito e rápido).\n    Retorna o texto transcrito ou None em caso de erro.\n    \"\"\"\n    try:\n        # 1. Baixar o áudio da Z-API\n        async with httpx.AsyncClient(timeout=30.0, follow_redirects=True) as client:\n            audio_resp = await client.get(audio_url)\n            if audio_resp.status_code != 200:\n                logger.error(f\"Erro ao baixar áudio da Z-API: status={audio_resp.status_code}\")\n                return None\n            audio_bytes = audio_resp.content\n\n        # 2. Salvar em arquivo temporário para enviar ao Groq\n        with tempfile.NamedTemporaryFile(suffix=\".ogg\", delete=False) as tmp:\n            tmp.write(audio_bytes)\n            tmp_path = tmp.name\n\n        try:\n            # 3. Enviar para Groq Whisper API (OpenAI-compatible)\n            async with httpx.AsyncClient(timeout=60.0) as client:\n                with open(tmp_path, \"rb\") as f:\n                    resp = await client.post(\n                        \"https://api.groq.com/openai/v1/audio/transcriptions\",\n                        headers={\"Authorization\": f\"Bearer {groq_api_key}\"},\n                        data={\n                            \"model\": \"whisper-large-v3\",\n                            \"language\": \"pt\",\n                            \"response_format\": \"text\",\n                        },\n                        files={\"file\": (\"audio.ogg\", f, \"audio/ogg\")},\n                    )\n\n                if resp.status_code == 200:\n                    transcription = resp.text.strip()\n                    logger.info(f\"Áudio transcrito com sucesso ({len(transcription)} chars): {transcription[:80]}...\")\n                    return transcription\n                else:\n                    logger.error(f\"Erro na transcrição Groq Whisper: status={resp.status_code}, body={resp.text}\")\n                    return None\n        finally:\n            os.unlink(tmp_path)\n\n    except Exception as e:\n        logger.error(f\"Exceção ao transcrever áudio: {e}\")\n        return None\n\n\ndef _contains_special_content(text: str) -> bool:\n    \"\"\"\n    Verifica se o texto contém conteúdo que ficaria bugado em TTS:\n    - URLs / links (https://, www., .com, .com.br)\n    - Emails (@)\n    - Valores monetários (R$ 1.500,00)\n    - Números longos (telefone, CEP, CNPJ, CPF)\n    - Endereços (Rua, Av., Avenida, etc.)\n    \"\"\"\n    patterns = [\n        r'https?://',                          # URLs\n        r'www\\.',                              # Links www\n        r'\\.[a-z]{2,3}\\.br\\b',                # Domínios .com.br, .org.br\n        r'\\b\\w+\\.(com|net|org|io|app)\\b',     # Domínios genéricos\n        r'@',                                  # Emails\n        r'R\\$\\s*[\\d.,]+',                      # Valores em reais: R$ 1.500,00\n        r'\\d{1,3}(?:\\.\\d{3})+,\\d{2}',         # Formato brasileiro de número: 1.500,00\n        r'\\d{5}[\\-]?\\d{3}',                   # CEP: 01234-567 ou 01234567\n        r'\\d{2}[\\.\\-]?\\d{3}[\\.\\-]?\\d{3}[\\/\\-]?\\d{4}[\\-]?\\d{2}',  # CNPJ\n        r'\\d{3}[\\.\\-]?\\d{3}[\\.\\-]?\\d{3}[\\-]?\\d{2}',              # CPF\n        r'\\(?\\d{2}\\)?\\s*\\d{4,5}[\\-\\s]?\\d{4}', # Telefone: (11) 99999-9999\n        r'\\b(?:Rua|Av\\.|Avenida|Alameda|Travessa|Praça|Rodovia|Estrada|R\\.)\\s',  # Endereços\n    ]\n    combined = '|'.join(patterns)\n    return bool(re.search(combined, text, re.IGNORECASE))\n\nclass PostgresChatMessageHistory:\n    \"\"\"Implementa o histórico de mensagens direto via SQLAlchemy (equivalente ao Postgres Chat Memory do n8n).\"\"\"\n    \n    def __init__(self, session_id: str):\n        # A session_id idealmente será o location_id + telefone, por ex: \"location123__+55119999999\"\n        self.session_id = session_id\n        self.max_history = 20 # Mantém o contexto de no máximo N mensagens\n\n    @property\n    def messages(self) -> List[BaseMessage]:\n        db = SessionLocal()\n        try:\n            # Pega as últimas N mensagens\n            records = db.query(ChatHistory).filter(\n                ChatHistory.session_id == self.session_id\n            ).order_by(ChatHistory.id.desc()).limit(self.max_history).all()\n            \n            # Reverte para ficar em ordem cronológica p/ o modelo\n            records.reverse()\n            \n            msgs = []\n            for r in records:\n                if r.message_type == \"human\":\n                    msgs.append(HumanMessage(content=r.content))\n                elif r.message_type == \"ai\":\n                    msgs.append(AIMessage(content=r.content))\n            return msgs\n        finally:\n            db.close()\n            \n    def add_user_message(self, message: str) -> None:\n        self._add_message(\"human\", message)\n        \n    def add_ai_message(self, message: str) -> None:\n        self._add_message(\"ai\", message)\n        \n    def _add_message(self, type_: str, content: str) -> None:\n        db = SessionLocal()\n        try:\n            history = ChatHistory(\n                session_id=self.session_id,\n                message_type=type_,\n                content=content\n            )\n            db.add(history)\n            db.commit()\n        except Exception as e:\n            logger.error(f\"Erro ao salvar mensagem no histórico: {e}\")\n            db.rollback()\n        finally:\n            db.close()\n\n\nclass AIEngine:\n    \"\"\"Core do motor IA integrando OpenRouter via LangChain e Memória persistente PostgreSQL.\"\"\"\n    \n    def __init__(self, agent_data: AIAgent):\n        self.agent_config = agent_data\n        # Inicializa o LLM via OpenRouter usando a biblioteca oficial OpenAI com base_url\n        # (já que OpenRouter é OpenAI-compatible)\n        \n        # Só inicializa se tiver chave\n        self.llm = None\n        if self.agent_config.api_key:\n            try:\n                self.llm = ChatOpenAI(\n                    model=self.agent_config.model,\n                    api_key=self.agent_config.api_key,\n                    base_url=\"https://openrouter.ai/api/v1\",\n                    temperature=0.3,\n                    max_tokens=1000,\n                    model_kwargs={\n                        # Headers extras úteis no OpenRouter (opcional mas recomendado)\n                        \"extra_headers\": {\n                            \"HTTP-Referer\": \"https://axenwp.com\",\n                            \"X-Title\": \"AxenWP IA Engine\"\n                        }\n                    }\n                )\n            except Exception as e:\n                logger.error(f\"Erro ao instanciar LLM OpenRouter: {e}\")\n\n    async def generate_response(\n        self, user_phone: str, user_message: str,\n        is_audio: bool = False, audio_url: Optional[str] = None,\n    ) -> Optional[dict]:\n        \"\"\"\n        Recebe a mensagem do usuário, busca o histórico e gera a resposta com o LLM.\n        Retorna um dicionário: {\"type\": \"text\"|\"audio\", \"content\": <string ou base64>, \"text\": <str>}\n        \"\"\"\n        if not self.agent_config.is_active or not self.llm:\n            logger.info(\"Agente IA inativo ou sem API Key configurada. Ignorando processamento cognitivo.\")\n            return None\n\n        # ── Transcrição de áudio (STT) ──\n        actual_message = user_message\n        if is_audio and audio_url and self.agent_config.groq_api_key:\n            logger.info(f\"Áudio recebido de {user_phone}. Transcrevendo via Groq Whisper...\")\n            transcription = await transcribe_audio(audio_url, self.agent_config.groq_api_key)\n            if transcription:\n                actual_message = transcription\n            else:\n                logger.warning(\"Falha na transcrição. Usando mensagem original como fallback.\")\n        elif is_audio and not self.agent_config.groq_api_key:\n            logger.warning(\"Áudio recebido mas Groq API Key não configurada. Ignorando transcrição.\")\n\n        # Identificador único de sessão de memória\n        session_id = f\"{self.agent_config.location_id}_{user_phone}\"\n        memory = PostgresChatMessageHistory(session_id)\n\n        # Recupera histórico\n        past_messages = memory.messages\n        logger.info(f\"Histórico carregado para {user_phone}: {len(past_messages)} mensagens (session: {session_id})\")\n\n        # Monta as mensagens diretamente (sem template string) para evitar\n        # conflito com {} no prompt do usuário\n        messages_for_llm: list[BaseMessage] = [\n            SystemMessage(content=self.agent_config.prompt),\n            *past_messages,\n            HumanMessage(content=actual_message),\n        ]\n\n        try:\n            # Invoca o LLM de forma assíncrona para não bloquear o event loop\n            response = await self.llm.ainvoke(messages_for_llm)\n\n            ai_text = response.content\n\n            # Se deu certo, salva ambas as mensagens no banco (Humano + IA)\n            memory.add_user_message(actual_message)\n            memory.add_ai_message(ai_text)\n            logger.info(f\"Histórico salvo para {user_phone}: user='{actual_message[:50]}...' ai='{ai_text[:50]}...'\")\n\n            # ── Decisão: responder com áudio ou texto ──\n            # Regra: cliente mandou áudio → responde áudio / cliente mandou texto → responde texto\n            should_send_audio = is_audio\n\n            # Exceção: fallback para texto se a resposta contém conteúdo especial\n            # (R$, URLs, endereços, CPF, CNPJ, telefone, etc.)\n            if should_send_audio and _contains_special_content(ai_text):\n                logger.info(\"Resposta contém conteúdo especial (R$, URL, endereço, etc.). Fallback para texto.\")\n                should_send_audio = False\n\n            # ── Gerar áudio via ElevenLabs (TTS) ──\n            if should_send_audio and self.agent_config.elevenlabs_api_key and self.agent_config.elevenlabs_voice_id:\n                try:\n                    logger.info(f\"Gerando áudio via ElevenLabs (VoiceID: {self.agent_config.elevenlabs_voice_id})...\")\n                    async with httpx.AsyncClient(timeout=30.0) as client:\n                        # output_format=ogg_opus → formato nativo de mensagem de voz do WhatsApp (PTT com ondas)\n                        speed = float(self.agent_config.elevenlabs_speed or 1.0)\n                        stability = float(self.agent_config.elevenlabs_stability or 0.5)\n                        similarity = float(self.agent_config.elevenlabs_similarity or 0.75)\n\n                        response_el = await client.post(\n                            f\"https://api.elevenlabs.io/v1/text-to-speech/{self.agent_config.elevenlabs_voice_id}?output_format=ogg_opus\",\n                            headers={\n                                \"xi-api-key\": self.agent_config.elevenlabs_api_key,\n                                \"Content-Type\": \"application/json\"\n                            },\n                            json={\n                                \"text\": ai_text,\n                                \"model_id\": \"eleven_multilingual_v2\",\n                                \"voice_settings\": {\n                                    \"stability\": stability,\n                                    \"similarity_boost\": similarity,\n                                    \"speed\": speed,\n                                }\n                            }\n                        )\n\n                        if response_el.status_code == 200:\n                            audio_content = response_el.content\n                            b64_audio = base64.b64encode(audio_content).decode(\"utf-8\")\n                            return {\"type\": \"audio\", \"content\": f\"data:audio/ogg;base64,{b64_audio}\", \"text\": ai_text}\n                        else:\n                            logger.error(f\"Erro ao gerar ElevenLabs: {response_el.text}. Fallback texto.\")\n                except Exception as ex_el:\n                    logger.error(f\"Exceção no ElevenLabs: {ex_el}. Fallback texto.\")\n\n            # Resposta Padrão de Texto\n            return {\"type\": \"text\", \"content\": ai_text}\n\n        except Exception as e:\n            logger.error(f\"Erro ao gerar resposta do Agente IA: {e}\")\n            return None\n\n# Serviço singleton para instanciar/invocações fáceis\nclass AIService:\n    # Cache: location_id -> (updated_at, AIEngine)\n    _engine_cache: dict = {}\n\n    def get_agent_for_tenant(self, location_id: str) -> Optional[AIEngine]:\n        db = SessionLocal()\n        try:\n            agent = db.query(AIAgent).filter(AIAgent.location_id == location_id).first()\n            if not agent or not agent.is_active or not agent.api_key:\n                self._engine_cache.pop(location_id, None)\n                return None\n\n            # Retorna do cache se o agente não foi alterado desde a última vez\n            cached = self._engine_cache.get(location_id)\n            if cached and cached[0] == agent.updated_at:\n                return cached[1]\n\n            engine = AIEngine(agent)\n            self._engine_cache[location_id] = (agent.updated_at, engine)\n            return engine\n        finally:\n            db.close()\n            \n    async def process_incoming_message(\n        self, location_id: str, remote_jid: str, text_content: str,\n        is_audio: bool = False, audio_url: Optional[str] = None,\n    ) -> Optional[dict]:\n        \"\"\"\n        Gatilho unificado. Executa o Agente caso o inquilino tenha ativado e retorna um dict p/ zapi_receiver.\n        \"\"\"\n        engine = self.get_agent_for_tenant(location_id)\n        if not engine:\n            return None\n\n        # O JID geralmente vem no formato '5511... @s.whatsapp.net', limpar\n        phone_number = remote_jid.split('@')[0] if '@' in remote_jid else remote_jid\n\n        return await engine.generate_response(\n            user_phone=phone_number,\n            user_message=text_content,\n            is_audio=is_audio,\n            audio_url=audio_url,\n        )\n\nai_service = AIService()\n","numLines":326,"startLine":1,"totalLines":326}}}
