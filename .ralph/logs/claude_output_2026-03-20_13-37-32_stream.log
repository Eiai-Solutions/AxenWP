{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BfMnDq7Fh2qVvxg1TVTt1n","type":"tool_result","content":"     1→\"\"\"\n     2→Ponto de entrada do servidor FastAPI do Axen WP.\n     3→\"\"\"\n     4→\n     5→from fastapi import FastAPI\n     6→from fastapi.middleware.cors import CORSMiddleware\n     7→from fastapi.staticfiles import StaticFiles\n     8→from fastapi.responses import FileResponse\n     9→import uvicorn\n    10→from contextlib import asynccontextmanager\n    11→\n    12→from apscheduler.schedulers.asyncio import AsyncIOScheduler\n    13→\n    14→from utils.logger import logger\n    15→from utils.config import settings\n    16→from auth.token_manager import token_manager\n    17→\n    18→# Importa as rotas\n    19→from auth.oauth import router as oauth_router\n    20→from webhooks.ghl_provider import router as ghl_webhook_router\n    21→from webhooks.zapi_receiver import router as zapi_webhook_router\n    22→from admin.dashboard import router as admin_router\n    23→from admin.ai_agent import router as admin_ai_agent_router\n    24→\n    25→# =============================================================================\n    26→# Configuração do APScheduler (Tokens)\n    27→# =============================================================================\n    28→scheduler = AsyncIOScheduler()\n    29→\n    30→async def refresh_tokens_job():\n    31→    logger.info(\"Executando job periódico de refresh de tokens...\")\n    32→    await token_manager.refresh_all_tokens()\n    33→\n    34→from data.database import Base, engine\n    35→\n    36→# =============================================================================\n    37→# Ciclo de Vida do FastAPI (Start/Shutdown)\n    38→# =============================================================================\n    39→@asynccontextmanager\n    40→async def lifespan(app: FastAPI):\n    41→    # 1. Cria tabelas novas que ainda não existem no banco (idempotente)\n    42→    Base.metadata.create_all(bind=engine)\n    43→    logger.info(\"Tabelas do banco de dados verificadas/criadas.\")\n    44→\n    45→    # 2. Aplica migrações de schema via Alembic (adiciona colunas, etc.)\n    46→    import os\n    47→    from alembic.config import Config as AlembicConfig\n    48→    from alembic import command as alembic_command\n    49→    try:\n    50→        alembic_cfg = AlembicConfig(os.path.join(os.path.dirname(__file__), \"alembic.ini\"))\n    51→        alembic_command.upgrade(alembic_cfg, \"head\")\n    52→        logger.info(\"Migrações Alembic aplicadas com sucesso.\")\n    53→    except Exception as e:\n    54→        logger.error(f\"Erro ao aplicar migrações Alembic: {e}\", exc_info=True)\n    55→\n    56→    # Inicializa scheduler de token refresh a cada 12 horas (proteção)\n    57→    # E roda imediatamente na subida\n    58→    logger.info(\"Axen WP Server iniciando...\")\n    59→    scheduler.add_job(refresh_tokens_job, \"interval\", hours=12)\n    60→    scheduler.start()\n    61→    \n    62→    await refresh_tokens_job()\n    63→    \n    64→    yield\n    65→    \n    66→    logger.info(\"Desligando servidor...\")\n    67→    scheduler.shutdown()\n    68→\n    69→# =============================================================================\n    70→# App FastAPI\n    71→# =============================================================================\n    72→app = FastAPI(\n    73→    title=\"Axen WP - WhatsApp Automation\",\n    74→    description=\"Hub de integração GHL Custom Conversation Provider e Z-API\",\n    75→    version=\"1.0.0\",\n    76→    lifespan=lifespan\n    77→)\n    78→\n    79→# CORS: restrito a origens configuradas; em debug mode permite tudo\n    80→_cors_origins = (\n    81→    [o.strip() for o in settings.allowed_origins.split(\",\") if o.strip()]\n    82→    if settings.allowed_origins\n    83→    else []\n    84→)\n    85→if not _cors_origins and not settings.debug:\n    86→    logger.warning(\n    87→        \"ALLOWED_ORIGINS nao configurado e DEBUG=false. \"\n    88→        \"CORS bloqueara requests cross-origin. \"\n    89→        \"Configure ALLOWED_ORIGINS no .env.\"\n    90→    )\n    91→\n    92→app.add_middleware(\n    93→    CORSMiddleware,\n    94→    allow_origins=_cors_origins if _cors_origins else ([\"*\"] if settings.debug else []),\n    95→    allow_credentials=True,\n    96→    allow_methods=[\"*\"],\n    97→    allow_headers=[\"*\"],\n    98→)\n    99→\n   100→# Registro de Rotas\n   101→app.include_router(oauth_router)\n   102→app.include_router(ghl_webhook_router)\n   103→app.include_router(zapi_webhook_router)\n   104→app.include_router(admin_router)\n   105→app.include_router(admin_ai_agent_router)\n   106→\n   107→\n   108→# Montagem de arquivos estáticos\n   109→app.mount(\"/static\", StaticFiles(directory=\"web/static\"), name=\"static\")\n   110→\n   111→@app.get(\"/favicon.ico\", include_in_schema=False)\n   112→async def favicon():\n   113→    return FileResponse(\"web/static/favicon.svg\", media_type=\"image/svg+xml\")\n   114→\n   115→@app.get(\"/\", tags=[\"Health\"])\n   116→async def root():\n   117→    # Redireciona a raiz para o admin se acessada no navegador\n   118→    from fastapi.responses import RedirectResponse\n   119→    return RedirectResponse(url=\"/admin/dashboard\", status_code=303)\n   120→\n   121→\n   122→@app.get(\"/health\", tags=[\"Health\"])\n   123→async def health_check():\n   124→    \"\"\"Retorna estado do servidor e os tenants ativos.\"\"\"\n   125→    tenants = token_manager.get_all_tenants()\n   126→    active_tenants = []\n   127→    \n   128→    for t in tenants:\n   129→        active_tenants.append({\n   130→            \"company\": t.company_name,\n   131→            \"location_id\": t.location_id,\n   132→            \"token_valid\": not t.is_token_expired,\n   133→            \"zapi_configured\": bool(t.zapi_instance_id and t.zapi_token),\n   134→            \"zapi_instance_id\": t.zapi_instance_id\n   135→        })\n   136→        \n   137→    return {\n   138→        \"status\": \"healthy\",\n   139→        \"tenants_loaded\": len(tenants),\n   140→        \"tenants\": active_tenants\n   141→    }\n   142→\n   143→\n   144→if __name__ == \"__main__\":\n   145→    logger.info(f\"Starting uvicorn server on {settings.host}:{settings.port}...\")\n   146→    uvicorn.run(\"main:app\", host=settings.host, port=settings.port, reload=settings.debug)\n   147→"}]},"parent_tool_use_id":"toolu_01B8mnjTvTQtsNa3ZEvvAPWv","session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"e525874e-cf35-4785-bf90-d47dd1fb88b9","timestamp":"2026-03-20T16:37:50.289Z"}
