{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VKsxWhNK1ykCzqJfuQrzTS","type":"tool_result","content":"     1→# ===========================\n     2→# GoHighLevel App (Marketplace)\n     3→# ===========================\n     4→GHL_CLIENT_ID=6927146f81129e5d3362bf17-mmf4qj9b\n     5→GHL_CLIENT_SECRET=5d5c051e-3f0b-41b0-8a41-ac1993092c39\n     6→GHL_REDIRECT_URI=https://seu-servidor.com/oauth/callback\n     7→\n     8→# Conversation Provider ID (do app Axen WP)\n     9→GHL_CONVERSATION_PROVIDER_ID=your-provider-id-here\n    10→\n    11→# ===========================\n    12→# Banco de Dados\n    13→# ===========================\n    14→DATABASE_URL=postgresql://user:password@host:5432/dbname\n    15→\n    16→# ===========================\n    17→# Servidor\n    18→# ===========================\n    19→HOST=0.0.0.0\n    20→PORT=8000\n    21→\n    22→# ===========================\n    23→# Segurança\n    24→# ===========================\n    25→# Token secreto para validar webhooks do Z-API (opcional, mas recomendado)\n    26→ZAPI_WEBHOOK_SECRET=um-token-secreto-qualquer\n    27→\n    28→# ===========================\n    29→# Logs\n    30→# ===========================\n    31→LOG_LEVEL=INFO\n    32→"}]},"parent_tool_use_id":"toolu_01B8mnjTvTQtsNa3ZEvvAPWv","session_id":"e47418a4-c150-4f43-895d-86d1b02f5994","uuid":"aeeea439-2a8e-4912-b53e-8af3cee275bc","timestamp":"2026-03-20T16:38:16.502Z"}
