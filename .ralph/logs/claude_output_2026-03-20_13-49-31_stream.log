{"type":"stream_event","event":{"type":"message_stop"},"session_id":"0b211461-9717-45cb-96b8-b1f56bba86ea","parent_tool_use_id":null,"uuid":"71b421d7-2f83-4d5d-8258-bca98602944b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F7BrPSei3z7MGm1GUd1GAk","type":"tool_result","content":"The file /Users/luizantonio/Documents/Antigravity/AxenWP/web/templates/dashboard.html has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"0b211461-9717-45cb-96b8-b1f56bba86ea","uuid":"8f72b37d-84a3-4636-a003-8ad2ff6a90b1","timestamp":"2026-03-20T16:51:03.167Z","tool_use_result":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/web/templates/dashboard.html","oldString":"            const alwaysAudio = btn.dataset.aialwaysaudio;\n            const groqKey = btn.dataset.aigroqkey;","newString":"            const groqKey = btn.dataset.aigroqkey;","originalFile":"<!DOCTYPE html>\n<html lang=\"pt-BR\" class=\"dark\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dashboard - Axen WP</title>\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.ico\">\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link\n        href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Space+Grotesk:wght@400;600&display=swap\"\n        rel=\"stylesheet\">\n    <script>\n        tailwind.config = {\n            darkMode: 'class',\n            theme: {\n                extend: {\n                    fontFamily: {\n                        sans: ['\"Space Grotesk\"', 'sans-serif'],\n                        display: ['Outfit', 'sans-serif'],\n                    },\n                    colors: {\n                        gray: {\n                            850: '#1f2937',\n                            900: '#111827',\n                            950: '#030712',\n                        },\n                        brand: {\n                            red: '#e11d48',\n                            darkred: '#be123c',\n                            black: '#0a0a0a',\n                            surface: '#121212',\n                        }\n                    }\n                }\n            }\n        }\n\n        function openZAPIModal(locationId, companyName, instanceId, token, clientToken) {\n            document.getElementById('zapi_location_id').value = locationId;\n            document.getElementById('zapi_company_name').innerText = companyName;\n            document.getElementById('zapi_instance_id').value = instanceId || '';\n            document.getElementById('zapi_token').value = token || '';\n            document.getElementById('zapi_client_token').value = clientToken || '';\n            document.getElementById('form_zapi').action = '/admin/tenant/' + locationId + '/zapi';\n            var host = window.location.host;\n            document.getElementById('zapi_webhook_instruction').innerText = 'https://' + host + '/webhook/zapi/inbound/' + locationId;\n            document.getElementById('zapi_webhook_status').innerText = 'https://' + host + '/webhook/zapi/status/' + locationId;\n            document.getElementById('zapiModal').classList.remove('hidden');\n        }\n\n        function closeZAPIModal() {\n            document.getElementById('zapiModal').classList.add('hidden');\n        }\n\n        function openNewCompanyModal() {\n            document.getElementById('newCompanyModal').classList.remove('hidden');\n        }\n\n        function closeNewCompanyModal() {\n            document.getElementById('newCompanyModal').classList.add('hidden');\n        }\n\n        function openAIAgentModal(btn) {\n            const locationId = btn.dataset.location;\n            const companyName = btn.dataset.company;\n            const agentName = btn.dataset.ainame;\n            const agentPrompt = btn.dataset.aiprompt;\n            const agentModel = btn.dataset.aimodel;\n            const agentApiKey = btn.dataset.aiapikey;\n            const isActive = btn.dataset.aiisactive;\n            const elevenlabsKey = btn.dataset.aielevenlabskey;\n            const elevenlabsVoiceId = btn.dataset.aielevenlabsvoice;\n            const alwaysAudio = btn.dataset.aialwaysaudio;\n            const groqKey = btn.dataset.aigroqkey;\n\n            document.getElementById('ai_location_id').value = locationId;\n            document.getElementById('ai_company_name').innerText = companyName;\n\n            document.getElementById('ai_name').value = agentName || 'Agente IA';\n            document.getElementById('ai_prompt').value = agentPrompt || 'Você é um assistente virtual prestativo.';\n            document.getElementById('ai_model').value = agentModel || 'openai/gpt-4o';\n            document.getElementById('ai_api_key').value = agentApiKey || '';\n            document.getElementById('ai_is_active').checked = String(isActive).toLowerCase() === 'true';\n\n            document.getElementById('ai_elevenlabs_api_key').value = elevenlabsKey || '';\n            document.getElementById('ai_groq_api_key').value = groqKey || '';\n\n            const speedVal = parseFloat(btn.dataset.aielspeed) || 1.0;\n            const stabilityVal = parseFloat(btn.dataset.aielstability) || 0.5;\n            const similarityVal = parseFloat(btn.dataset.aielsimilarity) || 0.75;\n            document.getElementById('ai_elevenlabs_speed').value = speedVal;\n            document.getElementById('el_speed_display').textContent = speedVal.toFixed(2) + 'x';\n            document.getElementById('ai_elevenlabs_stability').value = stabilityVal;\n            document.getElementById('el_stability_display').textContent = (stabilityVal * 100).toFixed(0) + '%';\n            document.getElementById('ai_elevenlabs_similarity').value = similarityVal;\n            document.getElementById('el_similarity_display').textContent = (similarityVal * 100).toFixed(0) + '%';\n\n            const debounceVal = parseFloat(btn.dataset.aidebounce) || 1.5;\n            const debounceInput = document.getElementById('ai_debounce_seconds');\n            debounceInput.value = debounceVal;\n            document.getElementById('debounce_display').textContent = debounceVal.toFixed(1) + 's';\n\n            // Set voice if exists, otherwise load won't pre-select it perfectly until fetched, handled in fetch\n            document.getElementById('ai_elevenlabs_voice_id').dataset.preselected = elevenlabsVoiceId || '';\n\n            document.getElementById('form_ai_agent').action = '/admin/agents/' + locationId + '/save';\n            document.getElementById('aiAgentModal').classList.remove('hidden');\n\n            // Default to Settings Tab\n            switchAITab('settings');\n        }\n\n        function closeAIAgentModal() {\n            document.getElementById('aiAgentModal').classList.add('hidden');\n        }\n\n        async function openQRModal(locationId, companyName) {\n            document.getElementById('qr_company_name').innerText = companyName;\n            const qrContainer = document.getElementById('qr_image_container');\n            qrContainer.innerHTML = '<div class=\"animate-pulse w-48 h-48 bg-gray-800 rounded-xl flex items-center justify-center border border-gray-700 mx-auto\"><span class=\"text-xs text-brand-red font-mono uppercase tracking-widest animate-bounce\">Loading...</span></div>';\n            document.getElementById('qrModal').classList.remove('hidden');\n\n            try {\n                const response = await fetch(`/admin/tenant/${locationId}/qrcode`);\n                const data = await response.json();\n\n                if (data.qrcode) {\n                    qrContainer.innerHTML = `<img src=\"${data.qrcode}\" alt=\"Scan to connect\" class=\"mx-auto rounded-xl w-64 h-64 border-2 border-brand-red/50 shadow-[0_0_30px_rgba(225,29,72,0.2)]\">`;\n                } else {\n                    qrContainer.innerHTML = `<div class=\"w-48 h-48 bg-gray-900 rounded-xl flex flex-col gap-2 items-center justify-center border border-brand-red/50 mx-auto p-4 text-center\"><svg class=\"w-8 h-8 text-brand-red\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\"></path></svg><span class=\"text-xs text-gray-400 font-mono focus:outline-none focus:ring-1\">${data.error || 'Failed to load code'}</span></div>`;\n                }\n            } catch (err) {\n                qrContainer.innerHTML = '<div class=\"text-xs text-red-500 font-mono\">Connection error</div>';\n            }\n        }\n\n        function closeQRModal() {\n            document.getElementById('qrModal').classList.add('hidden');\n            // Refresh to update the UI connectivity status\n            setTimeout(() => window.location.reload(), 500);\n        }\n\n        function switchAITab(tabName, btn) {\n            document.querySelectorAll('.ai-tab-content').forEach(el => el.classList.add('hidden'));\n            const targetContent = document.getElementById('ai_tab_' + tabName);\n            if (targetContent) targetContent.classList.remove('hidden');\n\n            document.querySelectorAll('.ai-tab-btn').forEach(el => {\n                el.classList.remove('border-brand-red', 'text-brand-red', 'bg-brand-red/10');\n                el.classList.add('border-transparent', 'text-gray-500');\n            });\n\n            const activeBtn = btn || document.getElementById('btn_ai_tab_' + tabName);\n            if (activeBtn) {\n                activeBtn.classList.remove('border-transparent', 'text-gray-500');\n                activeBtn.classList.add('border-brand-red', 'text-brand-red', 'bg-brand-red/10');\n            }\n        }\n\n        function openSystemModal() {\n            document.getElementById('systemModal').classList.remove('hidden');\n        }\n\n        function closeSystemModal() {\n            document.getElementById('systemModal').classList.add('hidden');\n        }\n\n        window.lastImprovedPrompt = null;\n        window.originalPromptForMaster = null;\n        let masterChatHistory = [];\n        let testHistory = [];\n\n        function formatMasterText(text) {\n            return text\n                .replace(/</g, \"&lt;\").replace(/>/g, \"&gt;\")\n                .replace(/\\*\\*(.*?)\\*\\*/g, '<strong class=\"text-white\">$1</strong>')\n                .replace(/\\n\\n/g, '<br><br>')\n                .replace(/\\n- /g, '<br>• ')\n                .replace(/\\n/g, '<br>');\n        }\n\n        // ctx = 'settings' | 'tester' — garante IDs únicos por contexto\n        function showApplyBtn(ctx) {\n            const btn = document.getElementById('btn_apply_master_' + ctx);\n            if (btn) btn.classList.remove('hidden');\n        }\n\n        function applySuggestedPrompt(ctx) {\n            const prompt = window.lastImprovedPrompt;\n            if (!prompt) return;\n\n            // Aplica o prompt no textarea (fica na aba Settings)\n            const textarea = document.getElementById('ai_prompt');\n            textarea.value = prompt;\n            textarea.classList.add('ring-2', 'ring-brand-red', 'ring-offset-2', 'ring-offset-gray-900');\n            setTimeout(() => textarea.classList.remove('ring-2', 'ring-brand-red', 'ring-offset-2', 'ring-offset-gray-900'), 1000);\n\n            // Esconde o painel correto e mostra confirmação\n            const panelId = ctx === 'tester' ? 'tester_analysis_result' : 'ai_analysis_result';\n            const panel = document.getElementById(panelId);\n            if (panel) {\n                panel.innerHTML = `<div class=\"flex items-center gap-2 p-3 text-xs text-green-400 font-mono\">\n                    <svg class=\"w-4 h-4 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n                    Prompt aplicado com sucesso! Vá para a aba Settings para revisar e salvar.\n                </div>`;\n                setTimeout(() => panel.classList.add('hidden'), 3000);\n            }\n        }\n\n        async function analyzePrompt() {\n            const promptText = document.getElementById('ai_prompt').value;\n            const btn = document.getElementById('btn_analyze_prompt');\n            const resultDiv = document.getElementById('ai_analysis_result');\n            const resultContent = document.getElementById('ai_analysis_content');\n\n            if (!promptText) return;\n\n            // Reset master chat state\n            masterChatHistory = [];\n            window.originalPromptForMaster = promptText;\n\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"animate-pulse\">✨ Analisando & Simulando...</span>';\n            resultDiv.classList.remove('hidden');\n            resultContent.innerHTML = '<span class=\"text-xs text-gray-400 font-mono animate-pulse\">A IA Mestre está realizando um teste prático com o robô nos bastidores. Aguarde...</span>';\n\n            try {\n                const response = await fetch('/admin/agents/analyze-prompt', {\n                    method: 'POST',\n                    headers: { 'Content-Type': 'application/json' },\n                    body: JSON.stringify({ prompt_text: promptText })\n                });\n                const data = await response.json();\n\n                if (data.success) {\n                    window.lastImprovedPrompt = data.improved_prompt;\n\n                    let transcriptHtml = '';\n                    if (data.simulation_transcript) {\n                        transcriptHtml = `\n                        <div class=\"mb-4 bg-brand-red/5 border border-brand-red/10 rounded-lg p-3\">\n                            <p class=\"text-[10px] text-brand-red font-bold uppercase tracking-widest mb-2 flex items-center gap-1\">\n                                <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\"></path></svg>\n                                Prova Real (Simulação Lead vs Agente):\n                            </p>\n                            <pre class=\"whitespace-pre-wrap text-[10px] text-gray-400 font-mono leading-relaxed bg-black/30 p-2 rounded\">${data.simulation_transcript}</pre>\n                        </div>`;\n                    }\n\n                    resultContent.innerHTML = transcriptHtml\n                        + `<div class=\"text-xs text-gray-300 font-mono leading-relaxed\">${formatMasterText(data.analysis)}</div>`\n                        + masterChatHtml('settings');\n\n                    if (data.improved_prompt) showApplyBtn('settings');\n                } else {\n                    resultContent.innerHTML = `<span class=\"text-brand-red font-bold\">${data.error}</span>`;\n                }\n            } catch (err) {\n                resultContent.innerHTML = `<span class=\"text-brand-red\">Erro de conexão ao analisar o prompt.</span>`;\n            } finally {\n                btn.disabled = false;\n                btn.innerHTML = '✨ Analisar Prompt';\n            }\n        }\n\n        function masterChatHtml(ctx) {\n            return `\n            <div class=\"mt-5 pt-4 border-t border-gray-800\">\n                <p class=\"text-[10px] text-brand-red font-bold uppercase tracking-widest mb-3 flex items-center gap-1.5\">\n                    <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z\"></path></svg>\n                    Conversar com a IA Mestre\n                </p>\n                <p class=\"text-[10px] text-gray-500 font-mono mb-3\">Dê seu feedback sobre o agente. A Mestre vai considerar e revisar o prompt se necessário.</p>\n                <div id=\"master_chat_messages_${ctx}\" class=\"space-y-2 mb-3 max-h-48 overflow-y-auto scrollbar-thin scrollbar-thumb-gray-800 scrollbar-track-transparent\"></div>\n                <div class=\"flex gap-2\">\n                    <input type=\"text\" id=\"master_chat_input_${ctx}\"\n                        class=\"input-dark flex-1 px-3 py-2 rounded-lg text-xs font-mono\"\n                        placeholder=\"Ex: o agente está sendo muito formal, precisa ser mais direto...\"\n                        onkeydown=\"if(event.key==='Enter'){event.preventDefault();sendMasterFeedback('${ctx}');}\">\n                    <button type=\"button\" onclick=\"sendMasterFeedback('${ctx}')\"\n                        class=\"bg-brand-red/20 hover:bg-brand-red text-brand-red hover:text-white border border-brand-red/40 transition-colors px-3 py-2 rounded-lg text-xs font-bold font-mono uppercase tracking-widest\">\n                        Enviar\n                    </button>\n                    <button type=\"button\" id=\"btn_apply_master_${ctx}\" onclick=\"applySuggestedPrompt('${ctx}')\"\n                        class=\"hidden bg-green-600/20 hover:bg-green-600 text-green-400 hover:text-white border border-green-600/40 transition-colors px-3 py-2 rounded-lg text-xs font-bold font-mono uppercase tracking-widest whitespace-nowrap\">\n                        Aplicar Mudanças\n                    </button>\n                </div>\n            </div>`;\n        }\n\n        async function sendMasterFeedback(ctx) {\n            const input = document.getElementById('master_chat_input_' + ctx);\n            const messagesDiv = document.getElementById('master_chat_messages_' + ctx);\n            const msg = input.value.trim();\n            if (!msg || !window.originalPromptForMaster) return;\n\n            input.value = '';\n            input.disabled = true;\n\n            // Show user message\n            messagesDiv.innerHTML += `<div class=\"flex justify-end\"><div class=\"bg-brand-red/20 border border-brand-red/30 text-gray-200 text-[11px] font-mono py-2 px-3 rounded-xl rounded-tr-none max-w-[85%]\">${msg}</div></div>`;\n\n            // Loading\n            const loadingId = 'mcloading_' + Date.now();\n            messagesDiv.innerHTML += `<div id=\"${loadingId}\" class=\"flex justify-start\"><div class=\"bg-gray-800/60 text-gray-400 text-[11px] font-mono py-2 px-3 rounded-xl animate-pulse\">Mestre pensando...</div></div>`;\n            messagesDiv.scrollTop = messagesDiv.scrollHeight;\n\n            try {\n                const resp = await fetch('/admin/agents/master-chat', {\n                    method: 'POST',\n                    headers: { 'Content-Type': 'application/json' },\n                    body: JSON.stringify({\n                        original_prompt: window.originalPromptForMaster,\n                        current_improved_prompt: window.lastImprovedPrompt || '',\n                        user_message: msg,\n                        chat_history: masterChatHistory\n                    })\n                });\n                const data = await resp.json();\n\n                document.getElementById(loadingId)?.remove();\n\n                if (data.success) {\n                    // Save to history\n                    masterChatHistory.push({ from: 'user', text: msg });\n                    masterChatHistory.push({ from: 'master', text: data.response });\n\n                    // Show master response\n                    messagesDiv.innerHTML += `<div class=\"flex justify-start\"><div class=\"bg-gray-800/60 border border-gray-700/50 text-gray-300 text-[11px] font-mono py-2 px-3 rounded-xl rounded-tl-none max-w-[85%] leading-relaxed\">${formatMasterText(data.response)}</div></div>`;\n\n                    // If master revised the prompt, show/update the apply button\n                    if (data.updated_prompt) {\n                        window.lastImprovedPrompt = data.updated_prompt;\n                        showApplyBtn(ctx);\n                        messagesDiv.innerHTML += `<div class=\"flex justify-center mt-1\"><span class=\"text-[10px] text-brand-red font-mono bg-brand-red/10 px-2 py-1 rounded\">✓ Prompt revisado com base no seu feedback</span></div>`;\n                    }\n                } else {\n                    messagesDiv.innerHTML += `<div class=\"text-[10px] text-brand-red font-mono text-center\">${data.error}</div>`;\n                }\n            } catch (e) {\n                document.getElementById(loadingId)?.remove();\n                messagesDiv.innerHTML += `<div class=\"text-[10px] text-brand-red font-mono text-center\">Erro de conexão.</div>`;\n            } finally {\n                input.disabled = false;\n                input.focus();\n                messagesDiv.scrollTop = messagesDiv.scrollHeight;\n            }\n        }\n\n\n        function clearTestChat() {\n            testHistory = [];\n            const body = document.getElementById('test_chat_body');\n            body.innerHTML = '<div class=\"bg-gray-800/50 border border-gray-700/50 rounded-lg p-3 text-xs text-gray-400 font-mono italic\">Chat resetado. Inicie uma nova conversa ou clique em <strong class=\"text-brand-red\">Simular com IA Mestre</strong>.</div>';\n            document.getElementById('tester_analysis_result').classList.add('hidden');\n        }\n\n        async function runMasterSimulation() {\n            const promptText = document.getElementById('ai_prompt').value;\n            const btn = document.getElementById('btn_master_simulate');\n            const body = document.getElementById('test_chat_body');\n            const analysisDiv = document.getElementById('tester_analysis_result');\n            const analysisContent = document.getElementById('tester_analysis_content');\n\n            if (!promptText) {\n                alert('Configure o System Prompt na aba Settings antes de simular.');\n                return;\n            }\n\n            // Reset state\n            testHistory = [];\n            masterChatHistory = [];\n            window.originalPromptForMaster = promptText;\n            analysisDiv.classList.add('hidden');\n\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"animate-pulse\">🤖 Simulando...</span>';\n\n            body.innerHTML = `<div class=\"flex justify-center\">\n                <span class=\"text-[10px] text-brand-red font-mono bg-brand-red/10 border border-brand-red/20 px-3 py-1.5 rounded-full animate-pulse\">\n                    IA Mestre gerando simulação...\n                </span>\n            </div>`;\n\n            try {\n                const response = await fetch('/admin/agents/analyze-prompt', {\n                    method: 'POST',\n                    headers: { 'Content-Type': 'application/json' },\n                    body: JSON.stringify({ prompt_text: promptText })\n                });\n                const data = await response.json();\n\n                body.innerHTML = '';\n\n                if (!data.success) {\n                    body.innerHTML = `<div class=\"text-xs text-brand-red font-mono p-3\">${data.error}</div>`;\n                    return;\n                }\n\n                window.lastImprovedPrompt = data.improved_prompt;\n\n                // Header da simulação\n                body.innerHTML += `<div class=\"flex justify-center my-1\">\n                    <span class=\"text-[10px] text-gray-500 font-mono bg-gray-800/60 border border-gray-700/50 px-3 py-1 rounded-full\">\n                        — Simulação IA Mestre —\n                    </span>\n                </div>`;\n\n                // Parsear o transcript em mensagens individuais\n                if (data.simulation_transcript) {\n                    const lines = data.simulation_transcript.split('\\n').filter(l => l.trim());\n                    for (const line of lines) {\n                        if (line.startsWith('Lead:') || line.startsWith('lead:')) {\n                            const text = line.replace(/^lead:/i, '').trim();\n                            body.innerHTML += `<div class=\"flex justify-end\"><div class=\"bg-brand-red text-white text-xs py-2 px-3 rounded-2xl rounded-tr-none min-w-0 max-w-[85%]\">${text}</div></div>`;\n                        } else if (line.startsWith('Agente:') || line.startsWith('agente:')) {\n                            const text = line.replace(/^agente:/i, '').trim();\n                            body.innerHTML += `<div class=\"flex justify-start\"><div class=\"bg-gray-800 text-gray-200 text-xs py-2 px-3 rounded-2xl rounded-tl-none min-w-0 max-w-[85%] font-mono whitespace-pre-wrap\">${text}</div></div>`;\n                        } else if (line.trim()) {\n                            // Linha sem prefixo reconhecido — exibe como separador informativo\n                            body.innerHTML += `<div class=\"flex justify-center\"><div class=\"text-[10px] text-gray-600 font-mono italic text-center\">${line}</div></div>`;\n                        }\n                    }\n                }\n\n                // Separador antes do diagnóstico\n                body.innerHTML += `<div class=\"flex justify-center my-1\">\n                    <span class=\"text-[10px] text-gray-500 font-mono bg-gray-800/60 border border-gray-700/50 px-3 py-1 rounded-full\">\n                        — Fim da Simulação —\n                    </span>\n                </div>`;\n                body.scrollTop = body.scrollHeight;\n\n                // Renderiza painel de diagnóstico abaixo do chat\n                analysisContent.innerHTML =\n                    `<div class=\"text-xs text-gray-300 font-mono leading-relaxed\">${formatMasterText(data.analysis)}</div>`\n                    + masterChatHtml('tester');\n\n                if (data.improved_prompt) showApplyBtn('tester');\n                analysisDiv.classList.remove('hidden');\n\n            } catch (err) {\n                body.innerHTML = `<div class=\"text-xs text-brand-red font-mono p-3\">Erro de conexão ao simular.</div>`;\n            } finally {\n                btn.disabled = false;\n                btn.innerHTML = '🤖 Simular com IA Mestre';\n            }\n        }\n\n        async function sendTestMessage() {\n            const input = document.getElementById('test_chat_input');\n            const body = document.getElementById('test_chat_body');\n            const msg = input.value.trim();\n            if (!msg) return;\n\n            // Add user message\n            addMessageToTester('me', msg);\n            input.value = '';\n\n            const locationId = document.getElementById('ai_location_id').value;\n            const agentData = {\n                prompt: document.getElementById('ai_prompt').value,\n                model: document.getElementById('ai_model').value,\n                api_key: document.getElementById('ai_api_key').value\n            };\n\n            // Loading bubble\n            const loadingId = 'loading_' + Date.now();\n            body.innerHTML += `<div id=\"${loadingId}\" class=\"flex justify-start\"><div class=\"bg-gray-800 text-gray-400 text-xs py-2 px-3 rounded-2xl animate-pulse\">...</div></div>`;\n            body.scrollTop = body.scrollHeight;\n\n            try {\n                const response = await fetch(`/admin/agents/${locationId}/test`, {\n                    method: 'POST',\n                    headers: { 'Content-Type': 'application/json' },\n                    body: JSON.stringify({ message: msg, agent_data: agentData, history: testHistory })\n                });\n                const data = await response.json();\n\n                document.getElementById(loadingId).remove();\n\n                if (data.success) {\n                    addMessageToTester('bot', data.response);\n                    testHistory.push({ from: 'me', text: msg });\n                    testHistory.push({ from: 'bot', text: data.response });\n                } else {\n                    addMessageToTester('system', data.error);\n                }\n            } catch (err) {\n                document.getElementById(loadingId).remove();\n                addMessageToTester('system', 'Erro de conexão com o simulador.');\n            }\n        }\n\n        function addMessageToTester(from, text) {\n            const body = document.getElementById('test_chat_body');\n            let html = '';\n            if (from === 'me') {\n                html = `<div class=\"flex justify-end\"><div class=\"bg-brand-red text-white text-xs py-2 px-3 rounded-2xl rounded-tr-none min-w-0 max-w-[85%]\">${text}</div></div>`;\n            } else if (from === 'bot') {\n                html = `<div class=\"flex justify-start\"><div class=\"bg-gray-800 text-gray-200 text-xs py-2 px-3 rounded-2xl rounded-tl-none min-w-0 max-w-[85%] font-mono whitespace-pre-wrap\">${text}</div></div>`;\n            } else {\n                html = `<div class=\"flex justify-center\"><div class=\"text-[10px] text-brand-red font-mono uppercase bg-brand-red/10 px-2 py-1 rounded text-center\">${text}</div></div>`;\n            }\n            body.innerHTML += html;\n            body.scrollTop = body.scrollHeight;\n        }\n\n        async function fetchElevenLabsVoices() {\n            const apiKey = document.getElementById('ai_elevenlabs_api_key').value;\n            const btn = document.getElementById('btn_fetch_voices');\n            const selectInfo = document.getElementById('voices_status_info');\n            const voiceSelect = document.getElementById('ai_elevenlabs_voice_id');\n            const preselected = voiceSelect.dataset.preselected;\n\n            if (!apiKey) {\n                alert(\"Please enter the ElevenLabs API Key first.\");\n                return;\n            }\n\n            btn.disabled = true;\n            btn.innerHTML = '<span class=\"animate-pulse\">Loading...</span>';\n            selectInfo.innerText = \"Fetching voices...\";\n\n            try {\n                const response = await fetch(`/admin/agents/elevenlabs/voices?api_key=${encodeURIComponent(apiKey)}`);\n                const data = await response.json();\n\n                if (response.ok && data.success) {\n                    voiceSelect.innerHTML = '<option value=\"\">-- Selecione a Voz --</option>';\n                    data.voices.forEach(v => {\n                        const opt = document.createElement('option');\n                        opt.value = v.voice_id;\n                        opt.innerText = v.name;\n                        if (v.voice_id === preselected) opt.selected = true;\n                        voiceSelect.appendChild(opt);\n                    });\n                    selectInfo.innerText = `${data.voices.length} voices loaded successfully.`;\n                    selectInfo.classList.replace('text-gray-400', 'text-green-400');\n                } else {\n                    selectInfo.innerText = data.detail || \"Error loading voices.\";\n                    selectInfo.classList.replace('text-gray-400', 'text-red-400');\n                }\n            } catch (err) {\n                selectInfo.innerText = \"Connection error.\";\n                selectInfo.classList.replace('text-gray-400', 'text-red-400');\n            } finally {\n                btn.disabled = false;\n                btn.innerHTML = 'Fetch Voices';\n            }\n        }\n    </script>\n    <style>\n        body {\n            background-color: #030712;\n            background-image:\n                radial-gradient(circle at 10% 20%, rgba(225, 29, 72, 0.05) 0%, transparent 40%),\n                radial-gradient(circle at 90% 80%, rgba(225, 29, 72, 0.08) 0%, transparent 50%),\n                linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.8));\n            background-attachment: fixed;\n            color: #d1d5db;\n        }\n\n        .glass-panel {\n            background: rgba(17, 24, 39, 0.4);\n            backdrop-filter: blur(24px);\n            -webkit-backdrop-filter: blur(24px);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);\n        }\n\n        .table-row-hover:hover {\n            background: rgba(225, 29, 72, 0.03);\n        }\n\n        .btn-brand {\n            background: linear-gradient(135deg, #e11d48, #be123c);\n            box-shadow: 0 4px 14px 0 rgba(225, 29, 72, 0.39);\n            transition: all 0.3s ease;\n        }\n\n        .btn-brand:hover {\n            box-shadow: 0 6px 20px 0 rgba(225, 29, 72, 0.5);\n            transform: translateY(-1px);\n        }\n\n        .input-dark {\n            background: rgba(3, 7, 18, 0.6);\n            border: 1px solid rgba(75, 85, 99, 0.4);\n            color: white;\n            transition: all 0.3s ease;\n        }\n\n        .input-dark:focus {\n            border-color: #e11d48;\n            box-shadow: 0 0 0 2px rgba(225, 29, 72, 0.2);\n            outline: none;\n        }\n\n        .status-badge {\n            background: rgba(255, 255, 255, 0.05);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .glow-text {\n            text-shadow: 0 0 20px rgba(225, 29, 72, 0.5);\n        }\n    </style>\n</head>\n\n<body class=\"font-sans min-h-screen antialiased selection:bg-brand-red selection:text-white\">\n\n    <!-- Top Navigation -->\n    <nav class=\"border-b border-gray-800 bg-black/50 backdrop-blur-xl sticky top-0 z-40\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"flex justify-between items-center h-16\">\n                <div class=\"flex items-center gap-3\">\n                    <div\n                        class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-brand-red to-brand-darkred flex items-center justify-center shadow-[0_0_15px_rgba(225,29,72,0.5)]\">\n                        <svg class=\"w-4 h-4 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path>\n                        </svg>\n                    </div>\n                    <span class=\"font-display text-xl font-bold text-white tracking-widest uppercase\">Axen<span\n                            class=\"text-brand-red\">WP</span></span>\n                    <span\n                        class=\"hidden md:inline-block ml-4 px-2 py-1 bg-gray-900 rounded-md text-[10px] uppercase tracking-widest border border-gray-800 text-gray-400 font-mono\">GHL\n                        ↔ Z-API Engine</span>\n                </div>\n                <div class=\"flex items-center gap-6\">\n                    <button onclick=\"openSystemModal()\"\n                        class=\"text-brand-red hover:text-white text-[10px] uppercase font-mono tracking-widest font-bold transition-colors flex items-center gap-2 border border-brand-red/30 bg-brand-red/10 px-3 py-1.5 rounded-lg shadow-[0_0_15px_rgba(225,29,72,0.1)]\">\n                        <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\">\n                            </path>\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\"></path>\n                        </svg>\n                        <span>Admin Settings</span>\n                    </button>\n                    <a href=\"/admin/logout\"\n                        class=\"text-gray-400 hover:text-white text-[10px] uppercase tracking-widest font-mono transition-colors flex items-center gap-1.5\">\n                        <span>Disconnect</span>\n                        <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1\">\n                            </path>\n                        </svg>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </nav>\n\n    <main class=\"max-w-7xl mx-auto mt-10 px-4 sm:px-6 lg:px-8\">\n\n        {% if message %}\n        <div\n            class=\"bg-green-500/10 border border-green-500/20 text-green-400 px-4 py-4 rounded-xl relative mb-8 flex items-start gap-3 backdrop-blur-sm shadow-lg\">\n            <svg class=\"h-5 w-5 shrink-0 mt-0.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                    d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"></path>\n            </svg>\n            <span class=\"block text-sm font-medium\">{{ message }}</span>\n        </div>\n        {% endif %}\n\n        {% if error_msg %}\n        <div\n            class=\"bg-brand-red/10 border border-brand-red/30 text-red-400 px-4 py-4 rounded-xl relative mb-8 flex items-start gap-3 backdrop-blur-sm shadow-lg\">\n            <svg class=\"h-5 w-5 shrink-0 mt-0.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                    d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\">\n                </path>\n            </svg>\n            <span class=\"block text-sm font-medium\">{{ error_msg }}</span>\n        </div>\n        {% endif %}\n\n        <!-- Header -->\n        <div class=\"flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4\">\n            <div>\n                <h2 class=\"font-display text-4xl font-extrabold text-white tracking-tight uppercase glow-text\">Locations\n                </h2>\n                <p class=\"text-sm text-gray-500 mt-1 font-mono uppercase tracking-widest\">Active System Integrations</p>\n            </div>\n            <button onclick=\"openNewCompanyModal()\"\n                class=\"btn-brand text-white font-bold py-2.5 px-6 rounded-lg shadow uppercase tracking-widest text-xs flex items-center gap-2\">\n                <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 4v16m8-8H4\"></path>\n                </svg>\n                Deploy New Instance\n            </button>\n        </div>\n\n        <!-- Data Table -->\n        <div class=\"glass-panel rounded-2xl overflow-hidden mb-12\">\n            <div class=\"overflow-x-auto\">\n                <table class=\"w-full text-left whitespace-nowrap\">\n                    <thead>\n                        <tr\n                            class=\"bg-gray-900/50 text-gray-400 text-[10px] uppercase tracking-widest font-mono border-b border-gray-800\">\n                            <th class=\"px-6 py-4 font-semibold\">Workspace</th>\n                            <th class=\"px-6 py-4 font-semibold\">Location ID</th>\n                            <th class=\"px-6 py-4 font-semibold text-center\">GHL Status</th>\n                            <th class=\"px-6 py-4 font-semibold text-center\">Z-API Engine</th>\n                            <th class=\"px-6 py-4 font-semibold text-right\">Operations</th>\n                        </tr>\n                    </thead>\n                    <tbody class=\"divide-y divide-gray-800/60 text-sm\">\n                        {% for tenant in tenants %}\n                        <tr class=\"table-row-hover transition-colors\">\n                            <td class=\"px-6 py-5\">\n                                <div class=\"flex items-center\">\n                                    <div\n                                        class=\"h-8 w-8 rounded bg-gray-800 flex items-center justify-center text-brand-red font-display font-bold mr-3 border border-gray-700\">\n                                        {{ tenant.company_name[0]|upper }}\n                                    </div>\n                                    <p class=\"font-bold text-white tracking-wide\">{{ tenant.company_name }}</p>\n                                </div>\n                            </td>\n                            <td class=\"px-6 py-5 text-gray-500 font-mono text-xs\">\n                                {{ tenant.location_id }}\n                            </td>\n                            <td class=\"px-6 py-5 text-center\">\n                                {% if tenant.is_token_expired %}\n                                <span\n                                    class=\"status-badge text-red-400 py-1 px-3 rounded-md text-[10px] uppercase tracking-widest inline-flex items-center gap-1.5 font-mono\">\n                                    <span class=\"w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse\"></span> Offline\n                                </span>\n                                {% else %}\n                                <span\n                                    class=\"status-badge text-green-400 py-1 px-3 rounded-md text-[10px] uppercase tracking-widest inline-flex items-center gap-1.5 font-mono\">\n                                    <span class=\"w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_5px_#22c55e]\"></span>\n                                    Synced\n                                </span>\n                                {% endif %}\n                            </td>\n                            <td class=\"px-6 py-5 text-center\">\n                                {% if tenant.zapi_connection_status == 'CONNECTED' %}\n                                <span class=\"text-gray-300 font-medium text-xs flex items-center justify-center gap-2\"\n                                    title=\"{{ tenant.zapi_instance_id }}\">\n                                    <svg class=\"w-4 h-4 text-brand-red\" fill=\"none\" stroke=\"currentColor\"\n                                        viewBox=\"0 0 24 24\">\n                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                            d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path>\n                                    </svg>\n                                    Connected\n                                </span>\n                                {% elif tenant.zapi_connection_status == 'DISCONNECTED' %}\n                                <span\n                                    class=\"text-yellow-500/80 font-medium text-xs flex items-center justify-center gap-2\"\n                                    title=\"WhatsApp Desktop offline or disconnected\">\n                                    <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                            d=\"M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4.978 4.978 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238L5.3 5.3m0 0L4.586 4.586m0 0L2.1 2.1\">\n                                        </path>\n                                    </svg>\n                                    Disconnected\n                                </span>\n                                {% else %}\n                                <span class=\"text-gray-600 font-medium text-xs flex items-center justify-center gap-2\">\n                                    <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                            d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\">\n                                        </path>\n                                    </svg>\n                                    Missing\n                                </span>\n                                {% endif %}\n                            </td>\n                            <td class=\"px-6 py-5 text-right flex items-center justify-end gap-4 h-full\">\n                                <form method=\"POST\" action=\"/admin/tenant/{{ tenant.location_id }}/toggle\"\n                                    class=\"mr-auto my-auto flex items-center\">\n                                    <input type=\"hidden\" name=\"is_active\"\n                                        value=\"{{ 'false' if tenant.is_active else 'true' }}\">\n                                    <button type=\"submit\"\n                                        class=\"relative inline-flex h-5 w-9 shrink-0 cursor-pointer items-center justify-center rounded-full focus:outline-none focus:ring-2 focus:ring-brand-red focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors {{ 'bg-green-500/80 shadow-[0_0_10px_rgba(34,197,94,0.3)]' if tenant.is_active else 'bg-gray-700' }}\"\n                                        role=\"switch\" aria-checked=\"{{ 'true' if tenant.is_active else 'false' }}\"\n                                        title=\"{{ 'Disable' if tenant.is_active else 'Enable' }} Automation\">\n                                        <span class=\"sr-only\">Toggle automation</span>\n                                        <span aria-hidden=\"true\"\n                                            class=\"pointer-events-none inline-block h-3.5 w-3.5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out {{ 'translate-x-4' if tenant.is_active else '-translate-x-0' }}\">\n                                        </span>\n                                    </button>\n                                </form>\n\n                                {% if tenant.zapi_connection_status == 'DISCONNECTED' %}\n                                <button onclick=\"openQRModal('{{ tenant.location_id }}', '{{ tenant.company_name }}')\"\n                                    class=\"text-brand-red hover:text-white hover:underline decoration-brand-red underline-offset-4 text-[10px] font-bold uppercase tracking-widest transition-colors font-mono flex items-center gap-1.5 bg-brand-red/10 px-2.5 py-1.5 rounded-md border border-brand-red/30\">\n                                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                            d=\"M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z\">\n                                        </path>\n                                    </svg>\n                                    Scan QR\n                                </button>\n                                {% endif %}\n                                <button data-location=\"{{ tenant.location_id }}\"\n                                    data-company=\"{{ tenant.company_name }}\"\n                                    data-ainame=\"{{ (tenant.ai_agent_data.name | forceescape) if tenant.ai_agent_data else '' }}\"\n                                    data-aiprompt=\"{{ (tenant.ai_agent_data.prompt | forceescape) if tenant.ai_agent_data and tenant.ai_agent_data.prompt else '' }}\"\n                                    data-aimodel=\"{{ (tenant.ai_agent_data.model | forceescape) if tenant.ai_agent_data else '' }}\"\n                                    data-aiapikey=\"{{ (tenant.ai_agent_data.api_key | forceescape) if tenant.ai_agent_data and tenant.ai_agent_data.api_key else '' }}\"\n                                    data-aiisactive=\"{{ tenant.ai_agent_data.is_active if tenant.ai_agent_data else 'False' }}\"\n                                    data-aielevenlabskey=\"{{ (tenant.ai_agent_data.elevenlabs_api_key | forceescape) if tenant.ai_agent_data and tenant.ai_agent_data.elevenlabs_api_key else '' }}\"\n                                    data-aielevenlabsvoice=\"{{ (tenant.ai_agent_data.elevenlabs_voice_id | forceescape) if tenant.ai_agent_data and tenant.ai_agent_data.elevenlabs_voice_id else '' }}\"\n                                    data-aielspeed=\"{{ tenant.ai_agent_data.elevenlabs_speed if tenant.ai_agent_data else '1.0' }}\"\n                                    data-aielstability=\"{{ tenant.ai_agent_data.elevenlabs_stability if tenant.ai_agent_data else '0.5' }}\"\n                                    data-aielsimilarity=\"{{ tenant.ai_agent_data.elevenlabs_similarity if tenant.ai_agent_data else '0.75' }}\"\n                                    data-aigroqkey=\"{{ (tenant.ai_agent_data.groq_api_key | forceescape) if tenant.ai_agent_data and tenant.ai_agent_data.groq_api_key else '' }}\"\n                                    data-aidebounce=\"{{ tenant.ai_agent_data.debounce_seconds if tenant.ai_agent_data else '1.5' }}\"\n                                    onclick=\"openAIAgentModal(this)\"\n                                    class=\"text-brand-red hover:text-white hover:underline decoration-brand-red underline-offset-4 text-[10px] font-bold uppercase tracking-widest transition-colors font-mono flex items-center gap-1.5 bg-brand-red/10 px-2.5 py-1.5 rounded-md border border-brand-red/30 mr-2\">\n                                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                            d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\">\n                                        </path>\n                                    </svg>\n                                    Agent AI\n                                </button>\n                                <button\n                                    onclick=\"openZAPIModal('{{ tenant.location_id }}', '{{ tenant.company_name | forceescape }}', '{{ tenant.zapi_instance_id or '' }}', '{{ tenant.zapi_token or '' }}', '{{ tenant.zapi_client_token or '' }}')\"\n                                    class=\"text-gray-400 hover:text-white hover:underline decoration-brand-red underline-offset-4 text-[10px] font-semibold uppercase tracking-widest transition-colors font-mono mt-0.5\">\n                                    Configure Z-API\n                                </button>\n                            </td>\n                        </tr>\n                        {% else %}\n                        <tr>\n                            <td colspan=\"5\"\n                                class=\"px-6 py-16 text-center text-gray-500 font-mono text-sm border-t border-gray-800\">\n                                <div class=\"flex flex-col items-center justify-center\">\n                                    <svg class=\"w-12 h-12 text-gray-800 mb-4\" fill=\"none\" stroke=\"currentColor\"\n                                        viewBox=\"0 0 24 24\">\n                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\"\n                                            d=\"M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4\"></path>\n                                    </svg>\n                                    No instances found. Initializing deployment sequence required.\n                                </div>\n                            </td>\n                        </tr>\n                        {% endfor %}\n                    </tbody>\n                </table>\n            </div>\n        </div>\n\n    </main>\n\n    <!-- Modals -->\n\n    <!-- Modal Admin System Settings -->\n    <div id=\"systemModal\" class=\"hidden fixed inset-0 z-50 flex items-center justify-center p-4\">\n        <!-- Backdrop -->\n        <div class=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" onclick=\"closeSystemModal()\"></div>\n\n        <!-- Modal Content -->\n        <div\n            class=\"relative w-full max-w-xl bg-gray-900 border border-brand-red/30 rounded-2xl shadow-[0_0_50px_rgba(225,29,72,0.15)] overflow-hidden\">\n            <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-red to-brand-darkred\"></div>\n\n            <div class=\"p-8\">\n                <div class=\"flex justify-between items-start mb-6 border-b border-gray-800 pb-4\">\n                    <div>\n                        <h3 class=\"font-display text-2xl font-bold text-white uppercase tracking-tight\">System Settings\n                        </h3>\n                        <p class=\"text-xs text-gray-400 font-mono mt-1\">Configurações Globais do Administrador</p>\n                    </div>\n                    <button onclick=\"closeSystemModal()\" class=\"text-gray-500 hover:text-white transition-colors\">\n                        <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M6 18L18 6M6 6l12 12\"></path>\n                        </svg>\n                    </button>\n                </div>\n\n                <div class=\"bg-brand-red/5 border border-brand-red/20 rounded-lg p-4 mb-6 relative\">\n                    <p class=\"text-xs text-gray-300 font-mono leading-relaxed\">\n                        A chave do OpenRouter configurada aqui é utilizada como <strong class=\"text-white\">IA\n                            Mestre</strong> para funcionalidades administrativas do sistema, como o <strong\n                            class=\"text-brand-red\">Analisador e Otimizador de Prompts</strong> nos agentes dos clientes.\n                    </p>\n                </div>\n\n                <form action=\"/admin/system/save\" method=\"POST\" class=\"space-y-5\">\n                    <div class=\"group\">\n                        <label\n                            class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">OpenRouter\n                            Master API Key</label>\n                        <input type=\"password\" name=\"admin_openrouter_key\"\n                            value=\"{{ system_settings.admin_openrouter_key if system_settings else '' }}\"\n                            placeholder=\"sk-or-v1-...\"\n                            class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono placeholder-gray-600\">\n                    </div>\n\n                    <div class=\"group\">\n                        <label\n                            class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest mt-4\">OpenRouter\n                            Master Model</label>\n                        <select name=\"admin_openrouter_model\"\n                            class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono\">\n                            <option value=\"openai/gpt-4o\" {% if system_settings and\n                                system_settings.admin_openrouter_model=='openai/gpt-4o' %}selected{% endif %}>\n                                openai/gpt-4o</option>\n                            <option value=\"anthropic/claude-3.5-sonnet\" {% if system_settings and\n                                system_settings.admin_openrouter_model=='anthropic/claude-3.5-sonnet' %}selected{% endif\n                                %}>anthropic/claude-3.5-sonnet</option>\n                            <option value=\"meta-llama/llama-3.1-70b-instruct\" {% if system_settings and\n                                system_settings.admin_openrouter_model=='meta-llama/llama-3.1-70b-instruct' %}selected{%\n                                endif %}>meta-llama/llama-3.1-70b-instruct</option>\n                        </select>\n                    </div>\n\n                    <div class=\"pt-6 flex justify-end gap-3 border-t border-gray-800\">\n                        <button type=\"button\" onclick=\"closeSystemModal()\"\n                            class=\"px-5 py-2 text-sm font-bold text-gray-400 hover:text-white uppercase tracking-widest transition-colors font-mono\">Cancelar</button>\n                        <button type=\"submit\"\n                            class=\"btn-brand px-6 py-2 rounded-lg text-white font-bold text-sm uppercase tracking-widest font-mono flex items-center gap-2\">\n                            Salvar Global\n                        </button>\n                    </div>\n                </form>\n            </div>\n        </div>\n    </div>\n\n    <!-- Modal Z-API -->\n    <div id=\"zapiModal\" class=\"hidden fixed inset-0 z-50 flex items-center justify-center p-4\">\n        <!-- Backdrop -->\n        <div class=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" onclick=\"closeZAPIModal()\"></div>\n\n        <!-- Modal Content -->\n        <div\n            class=\"relative w-full max-w-2xl bg-gray-900 border border-gray-800 rounded-2xl shadow-[0_0_50px_rgba(225,29,72,0.15)] overflow-hidden\">\n            <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-red to-brand-darkred\"></div>\n\n            <div class=\"p-8\">\n                <div class=\"flex justify-between items-start mb-6 border-b border-gray-800 pb-4\">\n                    <div>\n                        <h3 class=\"font-display text-2xl font-bold text-white uppercase tracking-tight\">Node\n                            Configuration</h3>\n                        <p class=\"text-xs text-gray-500 font-mono mt-1 uppercase tracking-widest\">Instance: <span\n                                id=\"zapi_company_name\"\n                                class=\"text-brand-red border-b border-brand-red/30 pb-0.5\"></span></p>\n                    </div>\n                    <button onclick=\"closeZAPIModal()\" class=\"text-gray-500 hover:text-white transition-colors\">\n                        <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M6 18L18 6M6 6l12 12\"></path>\n                        </svg>\n                    </button>\n                </div>\n\n                <div class=\"mb-8 bg-black/40 border border-brand-red/20 rounded-xl p-5 relative overflow-hidden group\">\n                    <div\n                        class=\"absolute inset-0 bg-brand-red/5 mix-blend-overlay opacity-0 group-hover:opacity-100 transition-opacity\">\n                    </div>\n                    <div class=\"flex items-start gap-4 relative z-10 w-full\">\n                        <div\n                            class=\"w-8 h-8 rounded-full bg-brand-red/10 flex items-center justify-center shrink-0 border border-brand-red/30 text-brand-red\">\n                            <svg class=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                    d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path>\n                            </svg>\n                        </div>\n                        <div class=\"min-w-0 flex-1 overflow-hidden\">\n                            <p class=\"text-xs text-brand-red font-bold uppercase tracking-widest mb-1\">Inbound Webhook\n                            </p>\n                            <p class=\"text-xs text-gray-400 mb-2\">Copy to Z-API \"Ao Receber Mensagem\":</p>\n                            <code id=\"zapi_webhook_instruction\"\n                                class=\"block w-full bg-black border border-gray-800 p-3 rounded-lg text-xs text-gray-300 font-mono select-all overflow-x-auto whitespace-nowrap scrollbar-thin scrollbar-thumb-gray-800 scrollbar-track-transparent selection:bg-brand-red/30\">https://{{ request.headers.host }}/webhook/zapi/inbound/ID</code>\n\n                            <p class=\"text-xs text-brand-red font-bold uppercase tracking-widest mt-5 mb-1\">Status\n                                Webhook</p>\n                            <p class=\"text-xs text-gray-400 mb-2\">Copy to Z-API \"Ao Alterar Status da Mensagem\":</p>\n                            <code id=\"zapi_webhook_status\"\n                                class=\"block w-full bg-black border border-gray-800 p-3 rounded-lg text-xs text-gray-300 font-mono select-all overflow-x-auto whitespace-nowrap scrollbar-thin scrollbar-thumb-gray-800 scrollbar-track-transparent selection:bg-brand-red/30\">https://{{ request.headers.host }}/webhook/zapi/status/ID</code>\n\n                            <p class=\"text-[10px] text-gray-500 mt-4 font-mono uppercase tracking-widest\">Client-Token\n                                header required if specified below.</p>\n                        </div>\n                    </div>\n\n                </div>\n\n                <form id=\"form_zapi\" method=\"POST\">\n                    <input type=\"hidden\" id=\"zapi_location_id\" name=\"location_id\">\n\n                    <div class=\"space-y-5\">\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">Instance\n                                ID (Z-API)</label>\n                            <input type=\"text\" id=\"zapi_instance_id\" name=\"instance_id\"\n                                class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono\" required>\n                        </div>\n\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">API\n                                Token (Z-API)</label>\n                            <input type=\"text\" id=\"zapi_token\" name=\"token\"\n                                class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono\" required>\n                        </div>\n\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">Secure\n                                Client Token (Optional)</label>\n                            <input type=\"text\" id=\"zapi_client_token\" name=\"client_token\"\n                                class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono placeholder-gray-700\"\n                                placeholder=\"Optional webhook security key\">\n                        </div>\n                    </div>\n\n                    <div class=\"mt-8 flex items-center justify-end gap-3 pt-4 border-t border-gray-800\">\n                        <button type=\"button\" onclick=\"closeZAPIModal()\"\n                            class=\"px-5 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-white hover:bg-gray-800 transition-colors\">Cancel</button>\n                        <button type=\"submit\"\n                            class=\"btn-brand px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest text-white\">Save\n                            Configuration</button>\n                    </div>\n                </form>\n            </div>\n        </div>\n    </div>\n\n    <!-- Modal Nova Empresa -->\n    <div id=\"newCompanyModal\" class=\"hidden fixed inset-0 z-50 flex items-center justify-center p-4\">\n        <div class=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" onclick=\"closeNewCompanyModal()\"></div>\n\n        <div\n            class=\"relative w-full max-w-md bg-gray-900 border border-gray-800 rounded-2xl shadow-[0_0_50px_rgba(225,29,72,0.15)] overflow-hidden\">\n            <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-red to-brand-darkred\"></div>\n\n            <div class=\"p-8\">\n                <div class=\"flex justify-between items-start mb-6 border-b border-gray-800 pb-4\">\n                    <div>\n                        <h3 class=\"font-display text-2xl font-bold text-white uppercase tracking-tight\">New Instance\n                        </h3>\n                        <p class=\"text-xs text-gray-500 font-mono mt-1 uppercase tracking-widest\">Connect CRM Engine</p>\n                    </div>\n                    <button onclick=\"closeNewCompanyModal()\" class=\"text-gray-500 hover:text-white transition-colors\">\n                        <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M6 18L18 6M6 6l12 12\"></path>\n                        </svg>\n                    </button>\n                </div>\n\n                <form action=\"/admin/onboard\" method=\"POST\" class=\"space-y-5\">\n                    <div class=\"group\">\n                        <label\n                            class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">Workspace\n                            Identity Label</label>\n                        <input type=\"text\" name=\"company_name\" class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm\"\n                            placeholder=\"e.g. MapInvest Auth\" required>\n                    </div>\n\n                    <div class=\"group\">\n                        <label\n                            class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">OAuth\n                            Client ID</label>\n                        <input type=\"text\" name=\"client_id\"\n                            class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono\" required>\n                    </div>\n\n                    <div class=\"group\">\n                        <label\n                            class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">OAuth\n                            Client Secret</label>\n                        <input type=\"password\" name=\"client_secret\"\n                            class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono\" required>\n                    </div>\n\n                    <div class=\"mt-8 flex flex-col gap-3 pt-4 border-t border-gray-800\">\n                        <button type=\"submit\"\n                            class=\"btn-brand w-full px-6 py-3 rounded-lg text-xs font-bold uppercase tracking-widest text-white flex justify-center items-center gap-2\">\n                            Initialize Connection\n                            <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                    d=\"M14 5l7 7m0 0l-7 7m7-7H3\"></path>\n                            </svg>\n                        </button>\n                    </div>\n                </form>\n            </div>\n        </div>\n    </div>\n\n    <!-- Modal Reconnect QR Code -->\n    <div id=\"qrModal\" class=\"hidden fixed inset-0 z-[60] flex items-center justify-center p-4\">\n        <div class=\"absolute inset-0 bg-black/80 backdrop-blur-md\" onclick=\"closeQRModal()\"></div>\n\n        <div\n            class=\"relative w-full max-w-sm bg-gray-900 border border-gray-800 rounded-3xl shadow-[0_0_80px_rgba(225,29,72,0.2)] overflow-hidden\">\n            <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-red to-brand-darkred\"></div>\n\n            <div class=\"p-8 text-center\">\n                <h3 class=\"font-display text-2xl font-bold text-white uppercase tracking-tight mb-2\">Connect Device</h3>\n                <p class=\"text-xs text-gray-500 font-mono mb-8 uppercase tracking-widest\">Instance: <span\n                        id=\"qr_company_name\" class=\"text-brand-red\"></span></p>\n\n                <div id=\"qr_image_container\" class=\"mb-8 min-h-[12rem] flex items-center justify-center\">\n                    <!-- Base64 Image Injected Here -->\n                </div>\n\n                <p class=\"text-[10px] text-gray-500 font-mono leading-relaxed px-4\">\n                    Open WhatsApp on the device and scan the code above to restore communications.\n                </p>\n\n                <div class=\"mt-8 border-t border-gray-800 pt-6\">\n                    <button type=\"button\" onclick=\"closeQRModal()\"\n                        class=\"px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest text-white bg-gray-800 hover:bg-gray-700 w-full transition-colors\">\n                        Done / Close\n                    </button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- Modal Configuração do Agente IA -->\n    <div id=\"aiAgentModal\" class=\"hidden fixed inset-0 z-50 flex items-center justify-center p-4\">\n        <div class=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" onclick=\"closeAIAgentModal()\"></div>\n\n        <div\n            class=\"relative w-full max-w-3xl bg-gray-900 border border-brand-red/30 rounded-2xl shadow-[0_0_50px_rgba(225,29,72,0.15)] overflow-hidden\">\n            <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-red to-brand-darkred\"></div>\n\n            <div\n                class=\"p-8 max-h-[90vh] overflow-y-auto scrollbar-thin scrollbar-thumb-brand-red scrollbar-track-gray-900\">\n                <div class=\"flex justify-between items-start mb-6 border-b border-gray-800 pb-4\">\n                    <div class=\"flex items-center gap-3\">\n                        <div\n                            class=\"w-10 h-10 rounded-lg bg-brand-red/10 flex items-center justify-center border border-brand-red/30\">\n                            <svg class=\"h-6 w-6 text-brand-red\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                    d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\">\n                                </path>\n                            </svg>\n                        </div>\n                        <div>\n                            <h3 class=\"font-display text-2xl font-bold text-white uppercase tracking-tight glow-text\">AI\n                                Agent Core</h3>\n                            <p class=\"text-xs text-gray-500 font-mono mt-1 uppercase tracking-widest\">Instance: <span\n                                    id=\"ai_company_name\" class=\"text-brand-red\"></span></p>\n                        </div>\n                    </div>\n                    <button onclick=\"closeAIAgentModal()\" class=\"text-gray-500 hover:text-white transition-colors\">\n                        <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                d=\"M6 18L18 6M6 6l12 12\"></path>\n                        </svg>\n                    </button>\n                </div>\n\n                <form id=\"form_ai_agent\" method=\"POST\" class=\"space-y-6\">\n                    <input type=\"hidden\" id=\"ai_location_id\" name=\"location_id\">\n\n                    <nav class=\"flex border-b border-gray-800 mb-8 overflow-x-auto scrollbar-none\">\n                        <button type=\"button\" id=\"btn_ai_tab_settings\" onclick=\"switchAITab('settings', this)\"\n                            class=\"ai-tab-btn px-6 py-3 text-xs font-bold uppercase tracking-widest border-b-2 border-brand-red text-brand-red bg-brand-red/10 transition-all\">⚙️\n                            Settings</button>\n                        <button type=\"button\" id=\"btn_ai_tab_voice\" onclick=\"switchAITab('voice', this)\"\n                            class=\"ai-tab-btn px-6 py-3 text-xs font-bold uppercase tracking-widest border-b-2 border-transparent text-gray-500 hover:text-white transition-all\">🗣️\n                            Voice & Audio</button>\n                        <button type=\"button\" id=\"btn_ai_tab_knowledge\" onclick=\"switchAITab('knowledge', this)\"\n                            class=\"ai-tab-btn px-6 py-3 text-xs font-bold uppercase tracking-widest border-b-2 border-transparent text-gray-500 hover:text-white transition-all\">🧠\n                            Knowledge Base</button>\n                        <button type=\"button\" id=\"btn_ai_tab_tester\" onclick=\"switchAITab('tester', this)\"\n                            class=\"ai-tab-btn px-6 py-3 text-xs font-bold uppercase tracking-widest border-b-2 border-transparent text-gray-500 hover:text-white transition-all\">🚀\n                            Tester (Simulator)</button>\n                    </nav>\n\n                    <!-- TAB: SETTINGS -->\n                    <div id=\"ai_tab_settings\" class=\"ai-tab-content space-y-6\">\n                        <div\n                            class=\"flex items-center justify-between bg-black/40 border border-gray-800 p-4 rounded-xl\">\n                            <div>\n                                <p class=\"text-sm font-bold text-white uppercase tracking-wide\">Enable Cognitive Engine\n                                </p>\n                                <p class=\"text-xs text-gray-500 mt-1\">When active, the AI will automatically intercept\n                                    inbound messages marked for AI processing.</p>\n                            </div>\n                            <div class=\"flex items-center\">\n                                <input type=\"checkbox\" id=\"ai_is_active\" name=\"is_active\" value=\"true\"\n                                    class=\"w-5 h-5 text-brand-red bg-gray-900 border-gray-700 rounded focus:ring-brand-red focus:ring-2\">\n                            </div>\n                        </div>\n\n                        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                            <div class=\"group\">\n                                <label\n                                    class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">Agent\n                                    Identity Name</label>\n                                <input type=\"text\" id=\"ai_name\" name=\"name\"\n                                    class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm\"\n                                    placeholder=\"e.g. MapInvest Consultant\">\n                            </div>\n\n                            <div class=\"group\">\n                                <label\n                                    class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">LLM\n                                    Routing Model</label>\n                                <select id=\"ai_model\" name=\"model\"\n                                    class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono\">\n                                    <option value=\"openai/gpt-4o\">OpenRouter - GPT-4o (OpenAI)</option>\n                                    <option value=\"openai/gpt-4o-mini\">OpenRouter - GPT-4o Mini (OpenAI)</option>\n                                    <option value=\"anthropic/claude-3.5-sonnet\">OpenRouter - Claude 3.5 Sonnet</option>\n                                    <option value=\"anthropic/claude-3-haiku\">OpenRouter - Claude 3 Haiku</option>\n                                    <option value=\"google/gemini-pro-1.5\">OpenRouter - Gemini 1.5 Pro</option>\n                                    <option value=\"meta-llama/llama-3-70b-instruct\">OpenRouter - LLaMA 3 70B</option>\n                                </select>\n                            </div>\n                        </div>\n\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest transition-colors flex justify-between\">\n                                <span class=\"group-focus-within:text-white\">API Key (OpenRouter)</span>\n                                <a href=\"https://openrouter.ai/keys\" target=\"_blank\"\n                                    class=\"text-brand-red hover:underline\">Get Key</a>\n                            </label>\n                            <input type=\"password\" id=\"ai_api_key\" name=\"api_key\"\n                                class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono placeholder-gray-700\"\n                                placeholder=\"sk-or-v1-xxxxxxxxxx...\">\n                        </div>\n\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">System\n                                Prompt (Cognitive Instructions)</label>\n                            <textarea id=\"ai_prompt\" name=\"prompt\" rows=\"12\"\n                                class=\"input-dark w-full py-3 px-4 rounded-lg text-sm font-mono leading-relaxed resize-y scrollbar-thin scrollbar-thumb-gray-800 scrollbar-track-transparent\"\n                                placeholder=\"You are a helpful assistant...\"></textarea>\n\n                            <div class=\"flex items-start justify-between mt-2 gap-4\">\n                                <p class=\"text-[10px] text-gray-500 font-mono mt-1\">This prompt dictates the exact\n                                    behavior,\n                                    tone, and constraints of the agent.</p>\n                                <button type=\"button\" id=\"btn_analyze_prompt\" onclick=\"analyzePrompt()\"\n                                    class=\"shrink-0 bg-brand-red/10 text-brand-red hover:bg-brand-red hover:text-white border border-brand-red/30 transition-colors px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-widest font-mono flex items-center gap-1.5\">\n                                    ✨ Analisar Prompt\n                                </button>\n                            </div>\n\n                            <!-- Analysis Result Container -->\n                            <div id=\"ai_analysis_result\"\n                                class=\"hidden mt-4 bg-black/60 border border-brand-red/30 rounded-lg p-4 shadow-inner\">\n                                <h4\n                                    class=\"text-white text-xs font-bold uppercase tracking-widest mb-3 flex items-center gap-2 border-b border-gray-800 pb-2\">\n                                    <svg class=\"w-4 h-4 text-brand-red\" fill=\"none\" stroke=\"currentColor\"\n                                        viewBox=\"0 0 24 24\">\n                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                            d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path>\n                                    </svg>\n                                    Diagnóstico & Sugestões Mestre\n                                </h4>\n                                <div id=\"ai_analysis_content\"\n                                    class=\"text-xs text-gray-300 font-mono leading-relaxed max-h-64 overflow-y-auto scrollbar-thin scrollbar-thumb-brand-red/50 scrollbar-track-transparent pr-2\">\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- TAB: VOICE -->\n                    <div id=\"ai_tab_voice\" class=\"ai-tab-content space-y-6 hidden\">\n\n                        <div class=\"bg-black/40 border border-gray-800 p-4 rounded-xl\">\n                            <p class=\"text-sm font-bold text-white uppercase tracking-wide flex items-center gap-2\">\n                                <svg class=\"w-4 h-4 text-brand-red\" fill=\"none\" stroke=\"currentColor\"\n                                    viewBox=\"0 0 24 24\">\n                                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                        d=\"M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z\">\n                                    </path>\n                                </svg>\n                                Modo de Resposta Inteligente\n                            </p>\n                            <div class=\"mt-2 space-y-1.5\">\n                                <p class=\"text-[11px] text-gray-400 flex items-center gap-2\">\n                                    <span class=\"text-brand-red font-bold\">1.</span>\n                                    Cliente envia <span class=\"text-white font-bold\">texto</span> &rarr; agente responde com <span class=\"text-white font-bold\">texto</span>\n                                </p>\n                                <p class=\"text-[11px] text-gray-400 flex items-center gap-2\">\n                                    <span class=\"text-brand-red font-bold\">2.</span>\n                                    Cliente envia <span class=\"text-white font-bold\">audio</span> &rarr; agente responde com <span class=\"text-white font-bold\">audio</span>\n                                </p>\n                                <p class=\"text-[11px] text-gray-500 flex items-center gap-2 mt-1 pl-4 border-l-2 border-gray-800\">\n                                    Excecao: se a resposta contiver valores (R$), enderecos, links ou dados especiais, o agente responde com texto para evitar erros de pronuncia.\n                                </p>\n                            </div>\n                        </div>\n\n                        <div class=\"group\">\n                            <label class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors flex justify-between items-center\">\n                                <span>Aguardar antes de responder (segundos)</span>\n                                <span id=\"debounce_display\" class=\"text-brand-red font-mono text-xs normal-case\">1.5s</span>\n                            </label>\n                            <input type=\"range\" id=\"ai_debounce_seconds\" name=\"debounce_seconds\"\n                                min=\"0.5\" max=\"15\" step=\"0.5\" value=\"1.5\"\n                                class=\"w-full accent-brand-red cursor-pointer\"\n                                oninput=\"document.getElementById('debounce_display').textContent = parseFloat(this.value).toFixed(1) + 's'\">\n                            <p class=\"text-[10px] text-gray-600 mt-1\">Tempo que o bot espera após a última mensagem do cliente antes de responder. Aumentar evita responder mensagens cortadas.</p>\n                        </div>\n\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest transition-colors flex justify-between\">\n                                <span class=\"group-focus-within:text-white\">Groq API Key (Transcrição de Áudio)</span>\n                                <a href=\"https://console.groq.com/keys\" target=\"_blank\"\n                                    class=\"text-brand-red hover:underline\">Get Key</a>\n                            </label>\n                            <input type=\"password\" id=\"ai_groq_api_key\" name=\"groq_api_key\"\n                                class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono placeholder-gray-700\"\n                                placeholder=\"gsk_...\">\n                            <p class=\"text-[10px] text-gray-600 mt-1\">Necessária para transcrever áudios recebidos dos clientes (Whisper). Gratuita no Groq.</p>\n                        </div>\n\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest transition-colors flex justify-between\">\n                                <span class=\"group-focus-within:text-white\">ElevenLabs API Key (Voz da IA)</span>\n                                <a href=\"https://elevenlabs.io/\" target=\"_blank\"\n                                    class=\"text-brand-red hover:underline\">Get Key</a>\n                            </label>\n                            <div class=\"flex gap-3\">\n                                <input type=\"password\" id=\"ai_elevenlabs_api_key\" name=\"elevenlabs_api_key\"\n                                    class=\"input-dark flex-1 py-2.5 px-3 rounded-lg text-sm font-mono placeholder-gray-700\"\n                                    placeholder=\"sk_...\">\n                                <button type=\"button\" id=\"btn_fetch_voices\" onclick=\"fetchElevenLabsVoices()\"\n                                    class=\"bg-gray-800 hover:bg-gray-700 text-white font-mono uppercase tracking-widest text-[10px] px-4 rounded-lg font-bold border border-gray-700 transition-colors\">\n                                    Fetch Voices\n                                </button>\n                            </div>\n                        </div>\n\n                        <div class=\"group\">\n                            <label\n                                class=\"block text-gray-400 text-[10px] font-bold mb-1.5 uppercase tracking-widest group-focus-within:text-white transition-colors\">Select\n                                Voice</label>\n                            <select id=\"ai_elevenlabs_voice_id\" name=\"elevenlabs_voice_id\"\n                                class=\"input-dark w-full py-2.5 px-3 rounded-lg text-sm font-mono\" data-preselected=\"\">\n                                <option value=\"\">-- Load Voices First --</option>\n                            </select>\n                            <p id=\"voices_status_info\" class=\"text-[10px] text-gray-400 mt-2 font-mono\">Select a\n                                predefined or cloned voice from your ElevenLabs account.</p>\n                        </div>\n\n                        <!-- Voice Settings Sliders -->\n                        <div class=\"bg-black/40 border border-gray-800 p-4 rounded-xl space-y-4 mt-2\">\n                            <p class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\">Voice Settings</p>\n\n                            <div>\n                                <label class=\"flex justify-between items-center text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1.5\">\n                                    <span>Velocidade</span>\n                                    <span id=\"el_speed_display\" class=\"text-brand-red font-mono text-xs normal-case\">1.00x</span>\n                                </label>\n                                <input type=\"range\" id=\"ai_elevenlabs_speed\" name=\"elevenlabs_speed\"\n                                    min=\"0.25\" max=\"4.0\" step=\"0.05\" value=\"1.0\"\n                                    class=\"w-full accent-brand-red cursor-pointer\"\n                                    oninput=\"document.getElementById('el_speed_display').textContent = parseFloat(this.value).toFixed(2) + 'x'\">\n                                <div class=\"flex justify-between text-[9px] text-gray-600 mt-0.5 font-mono\">\n                                    <span>0.25x (lento)</span>\n                                    <span>1.0x</span>\n                                    <span>4.0x (rapido)</span>\n                                </div>\n                            </div>\n\n                            <div>\n                                <label class=\"flex justify-between items-center text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1.5\">\n                                    <span>Estabilidade</span>\n                                    <span id=\"el_stability_display\" class=\"text-brand-red font-mono text-xs normal-case\">50%</span>\n                                </label>\n                                <input type=\"range\" id=\"ai_elevenlabs_stability\" name=\"elevenlabs_stability\"\n                                    min=\"0\" max=\"1\" step=\"0.05\" value=\"0.5\"\n                                    class=\"w-full accent-brand-red cursor-pointer\"\n                                    oninput=\"document.getElementById('el_stability_display').textContent = (parseFloat(this.value) * 100).toFixed(0) + '%'\">\n                                <div class=\"flex justify-between text-[9px] text-gray-600 mt-0.5 font-mono\">\n                                    <span>Expressivo</span>\n                                    <span>Estavel</span>\n                                </div>\n                            </div>\n\n                            <div>\n                                <label class=\"flex justify-between items-center text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1.5\">\n                                    <span>Similaridade</span>\n                                    <span id=\"el_similarity_display\" class=\"text-brand-red font-mono text-xs normal-case\">75%</span>\n                                </label>\n                                <input type=\"range\" id=\"ai_elevenlabs_similarity\" name=\"elevenlabs_similarity\"\n                                    min=\"0\" max=\"1\" step=\"0.05\" value=\"0.75\"\n                                    class=\"w-full accent-brand-red cursor-pointer\"\n                                    oninput=\"document.getElementById('el_similarity_display').textContent = (parseFloat(this.value) * 100).toFixed(0) + '%'\">\n                                <div class=\"flex justify-between text-[9px] text-gray-600 mt-0.5 font-mono\">\n                                    <span>Diverso</span>\n                                    <span>Fiel a voz</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- TAB: KNOWLEDGE BASE -->\n                    <div id=\"ai_tab_knowledge\"\n                        class=\"ai-tab-content hidden h-64 flex items-center justify-center border-2 border-dashed border-gray-800 rounded-xl bg-black/20\">\n                        <div class=\"text-center\">\n                            <svg class=\"mx-auto h-12 w-12 text-gray-700\" fill=\"none\" viewBox=\"0 0 24 24\"\n                                stroke=\"currentColor\" aria-hidden=\"true\">\n                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\"\n                                    d=\"M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10\">\n                                </path>\n                            </svg>\n                            <h3 class=\"mt-2 font-mono text-sm uppercase tracking-widest font-bold text-gray-400\">RAG\n                                Documents</h3>\n                            <p class=\"mt-1 text-xs text-gray-600 font-sans\">Uploading interface coming later in Phase 3.\n                            </p>\n                        </div>\n                    </div>\n\n                    <!-- TAB: TESTER (CHEST) -->\n                    <div id=\"ai_tab_tester\" class=\"ai-tab-content space-y-4 hidden\">\n                        <div class=\"bg-black/40 border border-gray-800 rounded-xl flex flex-col h-[400px]\">\n                            <!-- Chat Header -->\n                            <div class=\"p-4 border-b border-gray-800 flex justify-between items-center gap-2\">\n                                <span class=\"text-[10px] font-bold text-brand-red uppercase tracking-widest font-mono shrink-0\">Simulador de Chat</span>\n                                <div class=\"flex items-center gap-2\">\n                                    <button type=\"button\" id=\"btn_master_simulate\" onclick=\"runMasterSimulation()\"\n                                        class=\"bg-brand-red/10 text-brand-red hover:bg-brand-red hover:text-white border border-brand-red/30 transition-colors px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-widest font-mono flex items-center gap-1.5\">\n                                        🤖 Simular com IA Mestre\n                                    </button>\n                                    <button type=\"button\" onclick=\"clearTestChat()\"\n                                        class=\"text-[10px] text-gray-500 hover:text-white transition-colors uppercase font-mono\">Limpar</button>\n                                </div>\n                            </div>\n                            <!-- Chat Body -->\n                            <div id=\"test_chat_body\"\n                                class=\"flex-1 p-4 space-y-3 overflow-y-auto scrollbar-thin scrollbar-thumb-gray-800 scrollbar-track-transparent\">\n                                <div class=\"bg-gray-800/50 border border-gray-700/50 rounded-lg p-3 text-xs text-gray-400 font-mono italic\">\n                                    Inicie uma conversa manualmente ou clique em <strong class=\"text-brand-red\">Simular com IA Mestre</strong> para ver uma simulação automática.\n                                </div>\n                            </div>\n                            <!-- Chat Input -->\n                            <div class=\"p-4 border-t border-gray-800\">\n                                <div class=\"flex gap-2\">\n                                    <input type=\"text\" id=\"test_chat_input\"\n                                        class=\"input-dark flex-1 px-4 py-2 rounded-lg text-sm\"\n                                        placeholder=\"Digite uma mensagem para o Agente...\"\n                                        onkeydown=\"if(event.key === 'Enter') { event.preventDefault(); sendTestMessage(); }\">\n                                    <button type=\"button\" onclick=\"sendTestMessage()\"\n                                        class=\"bg-brand-red hover:bg-brand-darkred text-white p-2 rounded-lg transition-colors\">\n                                        <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n                                                d=\"M12 19l9 2-9-18-9 18 9-2zm0 0v-8\"></path>\n                                        </svg>\n                                    </button>\n                                </div>\n                                <p class=\"text-[9px] text-gray-600 mt-2 font-mono uppercase\">Teste manual usa a chave API do Agente (aba Settings). Simulação usa a chave do Admin (Admin Settings).</p>\n                            </div>\n                        </div>\n\n                        <!-- Painel de Diagnóstico do Tester (aparece após simulação) -->\n                        <div id=\"tester_analysis_result\" class=\"hidden mt-4 bg-black/60 border border-brand-red/30 rounded-lg p-4 shadow-inner\">\n                            <h4 class=\"text-white text-xs font-bold uppercase tracking-widest mb-3 flex items-center gap-2 border-b border-gray-800 pb-2\">\n                                <svg class=\"w-4 h-4 text-brand-red\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path>\n                                </svg>\n                                Diagnóstico & Sugestões Mestre\n                            </h4>\n                            <div id=\"tester_analysis_content\"\n                                class=\"text-xs text-gray-300 font-mono leading-relaxed max-h-64 overflow-y-auto scrollbar-thin scrollbar-thumb-brand-red/50 scrollbar-track-transparent pr-2\">\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"mt-8 flex items-center justify-end gap-3 pt-4 border-t border-gray-800\">\n                        <button type=\"button\" onclick=\"closeAIAgentModal()\"\n                            class=\"px-5 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-white hover:bg-gray-800 transition-colors\">Cancel</button>\n                        <button type=\"submit\"\n                            class=\"btn-brand px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest text-white shadow-[0_0_15px_rgba(225,29,72,0.4)]\">Salvar</button>\n                    </div>\n                </form>\n            </div>\n        </div>\n    </div>\n\n</body>\n\n</html>","stru