{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bazv8X9Px3u9ez1mTNTu2k","type":"tool_result","content":"     1→\"\"\"\n     2→Configurações globais carregadas do .env.\n     3→\"\"\"\n     4→\n     5→from pydantic_settings import BaseSettings\n     6→from pydantic import Field\n     7→\n     8→\n     9→class Settings(BaseSettings):\n    10→    \"\"\"Configurações da aplicação. Valores lidos do arquivo .env.\"\"\"\n    11→\n    12→    # GoHighLevel App\n    13→    ghl_client_id: str = Field(default=\"\", description=\"Client ID do app no Marketplace\")\n    14→    ghl_client_secret: str = Field(default=\"\", description=\"Client Secret do app\")\n    15→    ghl_redirect_uri: str = Field(\n    16→        default=\"http://localhost:8000/oauth/callback\",\n    17→        description=\"URI de callback OAuth\",\n    18→    )\n    19→    ghl_conversation_provider_id: str = Field(\n    20→        default=\"\", description=\"ID do Conversation Provider Axen WP\"\n    21→    )\n    22→\n    23→    database_url: str = Field(\n    24→        default=\"sqlite:///./data/axenwp.db\",\n    25→        description=\"URL de conexão com o banco de dados (ex: postgresql://...)\"\n    26→    )\n    27→\n    28→    # Servidor\n    29→    host: str = Field(default=\"0.0.0.0\")\n    30→    port: int = Field(default=8000)\n    31→\n    32→    # Segurança\n    33→    zapi_webhook_secret: str = Field(\n    34→        default=\"\", description=\"Token para validar webhooks do Z-API\"\n    35→    )\n    36→    allowed_origins: str = Field(\n    37→        default=\"\",\n    38→        description=\"Origens permitidas para CORS (separadas por virgula). Ex: https://app.example.com,https://admin.example.com\"\n    39→    )\n    40→    debug: bool = Field(default=False, description=\"Modo debug (habilita reload, CORS permissivo, etc.)\")\n    41→\n    42→    # Logs\n    43→    log_level: str = Field(default=\"INFO\")\n    44→\n    45→    # GHL API Base\n    46→    ghl_api_