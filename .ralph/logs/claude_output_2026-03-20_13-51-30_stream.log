ug: bool = Field(default=False, description=\"Modo debug (habilita reload, CORS permissivo, etc.)\")\n\n    # Logs\n    log_level: str = Field(default=\"INFO\")\n\n    # GHL API Base\n    ghl_api_base: str = Field(\n        default=\"https://services.leadconnectorhq.com\",\n        description=\"Base URL da API GHL\",\n    )\n\n    class Config:\n        env_file = \".env\"\n        env_file_encoding = \"utf-8\"\n\n\n# Instância global\nsettings = Settings()\n","numLines":58,"startLine":1,"totalLines":58}}}
