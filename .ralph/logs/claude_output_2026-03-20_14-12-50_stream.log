{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WrMGaFmrSYd54W9aU4icPw","type":"tool_result","content":"     1→\"\"\"\n     2→Cliente HTTP para a API Z-API.\n     3→Gerencia envio de mensagens de texto, imagem, documento e áudio via WhatsApp.\n     4→\"\"\"\n     5→\n     6→import httpx\n     7→\n     8→from utils.logger import logger\n     9→\n    10→\n    11→class ZAPIService:\n    12→    \"\"\"Serviço para interagir com a API Z-API.\"\"\"\n    13→\n    14→    BASE_URL = \"https://api.z-api.io\"\n    15→\n    16→    def _build_url(self, instance_id: str, token: str, endpoint: str) -> str:\n    17→        \"\"\"Monta a URL completa do endpoint Z-API.\"\"\"\n    18→        return f\"{self.BASE_URL}/instances/{instance_id}/token/{token}/{endpoint}\"\n    19→\n    20→    def _get_headers(self, client_token: str = \"\") -> dict:\n    21→        \"\"\"Headers padrão para chamadas Z-API.\"\"\"\n    22→        headers = {\"Content-Type\": \"application/json\"}\n    23→        if client_token:\n    24→            headers[\"Client-Token\"] = client_token\n    25→        return headers\n    26→\n    27→    async def send_text(\n    28→        self,\n    29→        instance_id: str,\n    30→        token: str,\n    31→        phone: str,\n    32→        message: str,\n    33→        client_token: str = \"\",\n    34→        delay_typing: int = 0,\n    35→    ) -> dict | None:\n    36→        \"\"\"\n    37→        Envia uma mensagem de texto simples.\n    38→        POST /instances/{id}/token/{token}/send-text\n    39→        \"\"\"\n    40→        url = self._build_url(instance_id, token, \"send-text\")\n    41→        payload = {\n    42→            \"phone\": self._format_phone(phone),\n    43→            \"message\": message,\n    44→        }\n    45→        if delay_typing:\n    46→            payload[\"delayTyping\"] = delay_typing\n    47→\n    48→        return await self._post(url, payload, client_token)\n    49→\n    50→    async def send_image(\n    51→        self,\n    52→        instance_id: str,\n    53→        token: str,\n    54→        phone: str,\n    55→        image_url: str,\n    56→        caption: str = \"\",\n    57→        client_token: str = \"\",\n    58→    ) -> dict | None:\n    59→        \"\"\"\n    60→        Envia uma imagem.\n    61→        POST /instances/{id}/token/{token}/send-image\n    62→        \"\"\"\n    63→        url = self._build_url(instance_id, token, \"send-image\")\n    64→        payload = {\n    65→            \"phone\": self._format_phone(phone),\n    66→            \"image\": image_url,\n    67→        }\n    68→        if caption:\n    69→            payload[\"caption\"] = caption\n    70→\n    71→        return await self._post(url, payload, client_token)\n    72→\n    73→    async def send_document(\n    74→        self,\n    75→        instance_id: str,\n    76→        token: str,\n    77→        phone: str,\n    78→        document_url: str,\n    79→        filename: str = \"document\",\n    80→        client_token: str = \"\",\n    81→    ) -> dict | None:\n    82→        \"\"\"\n    83→        Envia um documento/arquivo.\n    84→        POST /instances/{id}/token/{token}/send-document/{extension}\n    85→        \"\"\"\n    86→        # Extrair extensão do filename\n    87→        ext = filename.rsplit(\".\", 1)[-1] if \".\" in filename else \"pdf\"\n    88→        url = self._build_url(instance_id, token, f\"send-document/{ext}\")\n    89→        payload = {\n    90→            \"phone\": self._format_phone(phone),\n    91→            \"document\": document_url,\n    92→            \"fileName\": filename,\n    93→        }\n    94→\n    95→        return await self._post(url, payload, client_token)\n    96→\n    97→    async def send_audio(\n    98→        self,\n    99→        instance_id: str,\n   100→        token: str,\n   101→        phone: str,\n   102→        audio_url: str,\n   103→        client_token: str = \"\",\n   104→        record_audio: bool = True,\n   105→    ) -> dict | None:\n   106→        \"\"\"\n   107→        Envia um áudio.\n   108→        POST /instances/{id}/token/{token}/send-audio\n   109→        \"\"\"\n   110→        url = self._build_url(instance_id, token, \"send-audio\")\n   111→        payload = {\n   112→            \"phone\": self._format_phone(phone),\n   113→            \"audio\": audio_url,\n   114→            \"recordAudio\": record_audio,\n   115→        }\n   116→\n   117→        return await self._post(url, payload, client_token)\n   118→\n   119→    async def send_link(\n   120→        self,\n   121→        instance_id: str,\n   122→        token: str,\n   123→        phone: str,\n   124→        message: str,\n   125→        link_url: str,\n   126→        title: str = \"\",\n   127→        description: str = \"\",\n   128→        image_url: str = \"\",\n   129→        client_token: str = \"\",\n   130→    ) -> dict | None:\n   131→        \"\"\"\n   132→        Envia uma mensagem com preview de link.\n   133→        POST /instances/{id}/token/{token}/send-link\n   134→        \"\"\"\n   135→        url = self._build_url(instance_id, token, \"send-link\")\n   136→        payload = {\n   137→            \"phone\": self._format_phone(phone),\n   138→            \"message\": message,\n   139→            \"linkUrl\": link_url,\n   140→        }\n   141→        if title:\n   142→            payload[\"title\"] = title\n   143→        if description:\n   144→            payload[\"description\"] = description\n   145→        if image_url:\n   146→            payload[\"image\"] = image_url\n   147→\n   148→        return await self._post(url, payload, client_token)\n   149→\n   150→    async def _post(\n   151→        self, url: str, payload: dict, client_token: str = \"\"\n   152→    ) -> dict | None:\n   153→        \"\"\"Executa um POST genérico para a Z-API.\"\"\"\n   154→        try:\n   155→            async with httpx.AsyncClient(timeout=30.0) as client:\n   156→                response = await client.post(\n   157→                    url,\n   158→                    json=payload,\n   159→                    headers=self._get_headers(client_token),\n   160→                )\n   161→\n   162→                if response.status_code in (200, 201):\n   163→                    data = response.json()\n   164→                    logger.info(\n   165→                        f\"Z-API enviou mensagem com sucesso: \"\n   166→                        f\"phone={payload.get('phone')}, zapiMessageId={data.get('zapiMessageId', 'N/A')}\"\n   167→                    )\n   168→                    return data\n   169→                else:\n   170→                    logger.error(\n   171→                        f\"Erro Z-API: status={response.status_code}, \"\n   172→                        f\"url={url}, body={response.text}\"\n   173→                    )\n   174→                    return None\n   175→\n   176→        except Exception as e:\n   177→            logger.error(f\"Exceção ao chamar Z-API: {e}\")\n   178→            return None\n   179→\n   180→    @staticmethod\n   181→    def _format_phone(phone: str) -> str:\n   182→        \"\"\"\n   183→        Formata o telefone para o padrão Z-API (apenas números, sem + ou espaços).\n   184→        Ex: '+5511999999999' → '5511999999999'\n   185→        \"\"\"\n   186→        return \"\".join(c for c in phone if c.isdigit())\n   187→\n   188→    async def get_status(\n   189→        self, instance_id: str, token: str, client_token: str = \"\"\n   190→    ) -> dict | None:\n   191→        \"\"\"\n   192→        Retorna o status de conexão da instância (CONNECTED, DISCONNECTED, etc).\n   193→        GET /instances/{id}/token/{token}/status\n   194→        \"\"\"\n   195→        url = self._build_url(instance_id, token, \"status\")\n   196→        try:\n   197→            async with httpx.AsyncClient(timeout=10.0) as client:\n   198→                response = await client.get(url, headers=self._get_headers(client_token))\n   199→                if response.status_code == 200:\n   200→                    return response.json()\n   201→        except Exception as e:\n   202→            logger.error(f\"Erro ao buscar status Z-API: {e}\")\n   203→        return None\n   204→\n   205→    async def get_qr_code(\n   206→        self, instance_id: str, token: str, client_token: str = \"\"\n   207→    ) -> dict | None:\n   208→        \"\"\"\n   209→        Solicita um novo QR Code para reconexão.\n   210→        GET /instances/{id}/token/{token}/qr-code/image\n   211→        \"\"\"\n   212→        url = self._build_url(instance_id, token, \"qr-code/image\")\n   213→        try:\n   214→            async with httpx.AsyncClient(timeout=15.0) as client:\n   215→                response = await client.get(url, headers=self._get_headers(client_token))\n   216→                if response.status_code == 200:\n   217→                    return response.json() # Retorna {\"value\": \"data:image/png;base64,...\"}\n   218→        except Exception as e:\n   219→            logger.error(f\"Erro ao buscar QR Code Z-API: {e}\")\n   220→        return None\n   221→\n   222→\n   223→# Instância global\n   224→zapi_service = ZAPIService()\n   225→"}]},"parent_tool_use_id":null,"session_id":"c65344f3-6aa1-4b02-b3ae-01430f0d6aae","uuid":"9ec01340-b956-411d-a022-86fd01c968fd","timestamp":"2026-03-20T17:13:06.236Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/services/zapi_service.py","content":"\"\"\"\nCliente HTTP para a API Z-API.\nGerencia envio de mensagens de texto, imagem, documento e áudio via WhatsApp.\n\"\"\"\n\nimport httpx\n\nfrom utils.logger import logger\n\n\nclass ZAPIService:\n    \"\"\"Serviço para interagir com a API Z-API.\"\"\"\n\n    BASE_URL = \"https://api.z-api.io\"\n\n    def _build_url(self, instance_id: str, token: str, endpoint: str) -> str:\n        \"\"\"Monta a URL completa do endpoint Z-API.\"\"\"\n        return f\"{self.BASE_URL}/instances/{instance_id}/token/{token}/{endpoint}\"\n\n    def _get_headers(self, client_token: str = \"\") -> dict:\n        \"\"\"Headers padrão para chamadas Z-API.\"\"\"\n        headers = {\"Content-Type\": \"application/json\"}\n        if client_token:\n            headers[\"Client-Token\"] = client_token\n        return headers\n\n    async def send_text(\n        self,\n        instance_id: str,\n        token: str,\n        phone: str,\n        message: str,\n        client_token: str = \"\",\n        delay_typing: int = 0,\n    ) -> dict | None:\n        \"\"\"\n        Envia uma mensagem de texto simples.\n        POST /instances/{id}/token/{token}/send-text\n        \"\"\"\n        url = self._build_url(instance_id, token, \"send-text\")\n        payload = {\n            \"phone\": self._format_phone(phone),\n            \"message\": message,\n        }\n        if delay_typing:\n            payload[\"delayTyping\"] = delay_typing\n\n        return await self._post(url, payload, client_token)\n\n    async def send_image(\n        self,\n        instance_id: str,\n        token: str,\n        phone: str,\n        image_url: str,\n        caption: str = \"\",\n        client_token: str = \"\",\n    ) -> dict | None:\n        \"\"\"\n        Envia uma imagem.\n        POST /instances/{id}/token/{token}/send-image\n        \"\"\"\n        url = self._build_url(instance_id, token, \"send-image\")\n        payload = {\n            \"phone\": self._format_phone(phone),\n            \"image\": image_url,\n        }\n        if caption:\n            payload[\"caption\"] = caption\n\n        return await self._post(url, payload, client_token)\n\n    async def send_document(\n        self,\n        instance_id: str,\n        token: str,\n        phone: str,\n        document_url: str,\n        filename: str = \"document\",\n        client_token: str = \"\",\n    ) -> dict | None:\n        \"\"\"\n        Envia um documento/arquivo.\n        POST /instances/{id}/token/{token}/send-document/{extension}\n        \"\"\"\n        # Extrair extensão do filename\n        ext = filename.rsplit(\".\", 1)[-1] if \".\" in filename else \"pdf\"\n        url = self._build_url(instance_id, token, f\"send-document/{ext}\")\n        payload = {\n            \"phone\": self._format_phone(phone),\n            \"document\": document_url,\n            \"fileName\": filename,\n        }\n\n        return await self._post(url, payload, client_token)\n\n    async def send_audio(\n        self,\n        instance_id: str,\n        token: str,\n        phone: str,\n        audio_url: str,\n        client_token: str = \"\",\n        record_audio: bool = True,\n    ) -> dict | None:\n        \"\"\"\n        Envia um áudio.\n        POST /instances/{id}/token/{token}/send-audio\n        \"\"\"\n        url = self._build_url(instance_id, token, \"send-audio\")\n        payload = {\n            \"phone\": self._format_phone(phone),\n            \"audio\": audio_url,\n            \"recordAudio\": record_audio,\n        }\n\n        return await self._post(url, payload, client_token)\n\n    async def send_link(\n        self,\n        instance_id: str,\n        token: str,\n        phone: str,\n        message: str,\n        link_url: str,\n        title: str = \"\",\n        description: str = \"\",\n        image_url: str = \"\",\n        client_token: str = \"\",\n    ) -> dict | None:\n        \"\"\"\n        Envia uma mensagem com preview de link.\n        POST /instances/{id}/token/{token}/send-link\n        \"\"\"\n        url = self._build_url(instance_id, token, \"send-link\")\n        payload = {\n            \"phone\": self._format_phone(phone),\n            \"message\": message,\n            \"linkUrl\": link_url,\n        }\n        if title:\n            payload[\"title\"] = title\n        if description:\n            payload[\"description\"] = description\n        if image_url:\n            payload[\"image\"] = image_url\n\n        return await self._post(url, payload, client_token)\n\n    async def _post(\n        self, url: str, payload: dict, client_token: str = \"\"\n    ) -> dict | None:\n        \"\"\"Executa um POST genérico para a Z-API.\"\"\"\n        try:\n            async with httpx.AsyncClient(timeout=30.0) as client:\n                response = await client.post(\n                    url,\n                    json=payload,\n                    headers=self._get_headers(client_token),\n                )\n\n                if response.status_code in (200, 201):\n                    data = response.json()\n                    logger.info(\n                        f\"Z-API enviou mensagem com sucesso: \"\n                        f\"phone={payload.get('phone')}, zapiMessageId={data.get('zapiMessageId', 'N/A')}\"\n                    )\n                    return data\n                else:\n                    logger.error(\n                        f\"Erro Z-API: status={response.status_code}, \"\n                        f\"url={url}, body={response.text}\"\n                    )\n                    return None\n\n        except Exception as e:\n            logger.error(f\"Exceção ao chamar Z-API: {e}\")\n            return None\n\n    @staticmethod\n    def _format_phone(phone: str) -> str:\n        \"\"\"\n        Formata o telefone para o padrão Z-API (apenas números, sem + ou espaços).\n        Ex: '+5511999999999' → '5511999999999'\n        \"\"\"\n        return \"\".join(c for c in phone if c.isdigit())\n\n    async def get_status(\n        self, instance_id: str, token: str, client_token: str = \"\"\n    ) -> dict | None:\n        \"\"\"\n        Retorna o status de conexão da instância (CONNECTED, DISCONNECTED, etc).\n        GET /instances/{id}/token/{token}/status\n        \"\"\"\n        url = self._build_url(instance_id, token, \"status\")\n        try:\n            async with httpx.AsyncClient(timeout=10.0) as client:\n                response = await client.get(url, headers=self._get_headers(client_token))\n                if response.status_code == 200:\n                    return response.json()\n        except Exception as e:\n            logger.error(f\"Erro ao buscar status Z-API: {e}\")\n        return None\n\n    async def get_qr_code(\n        self, instance_id: str, token: str, client_token: str = \"\"\n    ) -> dict | None:\n        \"\"\"\n        Solicita um novo QR Code para reconexão.\n        GET /instances/{id}/token/{token}/qr-code/image\n        \"\"\"\n        url = self._build_url(instance_id, token, \"qr-code/image\")\n        try:\n            async with httpx.AsyncClient(timeout=15.0) as client:\n                response = await client.get(url, headers=self._get_headers(client_token))\n                if response.status_code == 200:\n                    return response.json() # Retorna {\"value\": \"data:image/png;base64,...\"}\n        except Exception as e:\n            logger.error(f\"Erro ao buscar QR Code Z-API: {e}\")\n        return None\n\n\n# Instância global\nzapi_service = ZAPIService()\n","numLines":225,"startLine":1,"totalLines":225}}}
