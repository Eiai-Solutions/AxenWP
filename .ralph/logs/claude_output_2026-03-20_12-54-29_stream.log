{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012tesBMVKNkqCWuGjGW7H6j","type":"tool_result","content":"     1→\"\"\"\n     2→Ponto de entrada do servidor FastAPI do Axen WP.\n     3→\"\"\"\n     4→\n     5→from fastapi import FastAPI\n     6→from fastapi.middleware.cors import CORSMiddleware\n     7→from fastapi.staticfiles import StaticFiles\n     8→from fastapi.responses import FileResponse\n     9→import uvicorn\n    10→from contextlib import asynccontextmanager\n    11→\n    12→from apscheduler.schedulers.asyncio import AsyncIOScheduler\n    13→\n    14→from utils.logger import logger\n    15→from utils.config import settings\n    16→from auth.token_manager import token_manager\n    17→\n    18→# Importa as rotas\n    19→from auth.oauth import router as oauth_router\n    20→from webhooks.ghl_provider import router as ghl_webhook_router\n    21→from webhooks.zapi_receiver import router as zapi_webhook_router\n    22→from admin.dashboard import router as admin_router\n    23→from admin.ai_agent import router as admin_ai_agent_router\n    24→\n    25→# =============================================================================\n    26→# Configuração do APScheduler (Tokens)\n    27→# =============================================================================\n    28→scheduler = AsyncIOScheduler()\n    29→\n    30→async def refresh_tokens_job():\n    31→    logger.info(\"Executando job periódico de refresh de tokens...\")\n    32→    await token_manager.refresh_all_tokens()\n    33→\n    34→from data.database import Base, engine\n    35→\n    36→# =============================================================================\n    37→# Ciclo de Vida do FastAPI (Start/Shutdown)\n    38→# =============================================================================\n    39→@asynccontextmanager\n    40→async def lifespan(app: FastAPI):\n    41→    # 1. Cria tabelas novas que ainda não existem no banco (idempotente)\n    42→    Base.metadata.create_all(bind=engine)\n    43→    logger.info(\"Tabelas do banco de dados verificadas/criadas.\")\n    44→\n    45→    # 2. Aplica migrações de schema via Alembic (adiciona colunas, etc.)\n    46→    import os\n    47→    from alembic.config import Config as AlembicConfig\n    48→    from alembic import command as alembic_command\n    49→    try:\n    50→        alembic_cfg = AlembicConfig(os.path.join(os.path.dirname(__file__), \"alembic.ini\"))\n    51→        alembic_command.upgrade(alembic_cfg, \"head\")\n    52→        logger.info(\"Migrações Alembic aplicadas com sucesso.\")\n    53→    except Exception as e:\n    54→        logger.error(f\"Erro ao aplicar migrações Alembic: {e}\", exc_info=True)\n    55→\n    56→    # Inicializa scheduler de token refresh a cada 12 horas (proteção)\n    57→    # E roda imediatamente na subida\n    58→    logger.info(\"Axen WP Server iniciando...\")\n    59→    scheduler.add_job(refresh_tokens_job, \"interval\", hours=12)\n    60→    scheduler.start()\n    61→    \n    62→    await refresh_tokens_job()\n    63→    \n    64→    yield\n    65→    \n    66→    logger.info(\"Desligando servidor...\")\n    67→    scheduler.shutdown()\n    68→\n    69→# =============================================================================\n    70→# App FastAPI\n    71→# =============================================================================\n    72→app = FastAPI(\n    73→    title=\"Axen WP - WhatsApp Automation\",\n    74→    description=\"Hub de integração GHL Custom Conversation Provider e Z-API\",\n    75→    version=\"1.0.0\",\n    76→    lifespan=lifespan\n    77→)\n    78→\n    79→app.add_middleware(\n    80→    CORSMiddleware,\n    81→    allow_origins=[\"*\"],\n    82→    allow_credentials=True,\n    83→    allow_methods=[\"*\"],\n    84→    allow_headers=[\"*\"],\n    85→)\n    86→\n    87→# Registro de Rotas\n    88→app.include_router(oauth_router)\n    89→app.include_router(ghl_webhook_router)\n    90→app.include_router(zapi_webhook_router)\n    91→app.include_router(admin_router)\n    92→app.include_router(admin_ai_agent_router)\n    93→\n    94→\n    95→# Montagem de arquivos estáticos\n    96→app.mount(\"/static\", StaticFiles(directory=\"web/static\"), name=\"static\")\n    97→\n    98→@app.get(\"/favicon.ico\", include_in_schema=False)\n    99→async def favicon():\n   100→    return FileResponse(\"web/static/favicon.svg\", media_type=\"image/svg+xml\")\n   101→\n   102→@app.get(\"/\", tags=[\"Health\"])\n   103→async def root():\n   104→    # Redireciona a raiz para o admin se acessada no navegador\n   105→    from fastapi.responses import RedirectResponse\n   106→    return RedirectResponse(url=\"/admin/dashboard\", status_code=303)\n   107→\n   108→\n   109→@app.get(\"/health\", tags=[\"Health\"])\n   110→async def health_check():\n   111→    \"\"\"Retorna estado do servidor e os tenants ativos.\"\"\"\n   112→    tenants = token_manager.get_all_tenants()\n   113→    active_tenants = []\n   114→    \n   115→    for t in tenants:\n   116→        active_tenants.append({\n   117→            \"company\": t.company_name,\n   118→            \"location_id\": t.location_id,\n   119→            \"token_valid\": not t.is_token_expired,\n   120→            \"zapi_configured\": bool(t.zapi_instance_id and t.zapi_token),\n   121→            \"zapi_instance_id\": t.zapi_instance_id\n   122→        })\n   123→        \n   124→    return {\n   125→        \"status\": \"healthy\",\n   126→        \"tenants_loaded\": len(tenants),\n   127→        \"tenants\": active_tenants\n   128→    }\n   129→\n   130→\n   131→if __name__ == \"__main__\":\n   132→    logger.info(f\"Starting uvicorn server on {settings.host}:{settings.port}...\")\n   133→    uvicorn.run(\"main:app\", host=settings.host, port=settings.port, reload=True)\n   134→"}]},"parent_tool_use_id":null,"session_id":"6f572577-b487-4fd0-ac64-329f60bf21fb","uuid":"6e562eb9-b21d-4c15-9969-6f825ac98a2e","timestamp":"2026-03-20T15:54:58.011Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/luizantonio/Documents/Antigravity/AxenWP/main.py","content":"\"\"\"\nPonto de entrada do servidor FastAPI do Axen WP.\n\"\"\"\n\nfrom fastapi import FastAPI\nfrom fastapi.middleware.cors import CORSMiddleware\nfrom fastapi.staticfiles import StaticFiles\nfrom fastapi.responses import FileResponse\nimport uvicorn\nfrom contextlib import asynccontextmanager\n\nfrom apscheduler.schedulers.asyncio import AsyncIOScheduler\n\nfrom utils.logger import logger\nfrom utils.config import settings\nfrom auth.token_manager import token_manager\n\n# Importa as rotas\nfrom auth.oauth import router as oauth_router\nfrom webhooks.ghl_provider import router as ghl_webhook_router\nfrom webhooks.zapi_receiver import router as zapi_webhook_router\nfrom admin.dashboard import router as admin_router\nfrom admin.ai_agent import router as admin_ai_agent_router\n\n# =============================================================================\n# Configuração do APScheduler (Tokens)\n# =============================================================================\nscheduler = AsyncIOScheduler()\n\nasync def refresh_tokens_job():\n    logger.info(\"Executando job periódico de refresh de tokens...\")\n    await token_manager.refresh_all_tokens()\n\nfrom data.database import Base, engine\n\n# =============================================================================\n# Ciclo de Vida do FastAPI (Start/Shutdown)\n# =============================================================================\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    # 1. Cria tabelas novas que ainda não existem no banco (idempotente)\n    Base.metadata.create_all(bind=engine)\n    logger.info(\"Tabelas do banco de dados verificadas/criadas.\")\n\n    # 2. Aplica migrações de schema via Alembic (adiciona colunas, etc.)\n    import os\n    from alembic.config import Config as AlembicConfig\n    from alembic import command as alembic_command\n    try:\n        alembic_cfg = AlembicConfig(os.path.join(os.path.dirname(__file__), \"alembic.ini\"))\n        alembic_command.upgrade(alembic_cfg, \"head\")\n        logger.info(\"Migrações Alembic aplicadas com sucesso.\")\n    except Exception as e:\n        logger.error(f\"Erro ao aplicar migrações Alembic: {e}\", exc_info=True)\n\n    # Inicializa scheduler de token refresh a cada 12 horas (proteção)\n    # E roda imediatamente na subida\n    logger.info(\"Axen WP Server iniciando...\")\n    scheduler.add_job(refresh_tokens_job, \"interval\", hours=12)\n    scheduler.start()\n    \n    await refresh_tokens_job()\n    \n    yield\n    \n    logger.info(\"Desligando servidor...\")\n    scheduler.shutdown()\n\n# =============================================================================\n# App FastAPI\n# =============================================================================\napp = FastAPI(\n    title=\"Axen WP - WhatsApp Automation\",\n    description=\"Hub de integração GHL Custom Conversation Provider e Z-API\",\n    version=\"1.0.0\",\n    lifespan=lifespan\n)\n\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=[\"*\"],\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\n# Registro de Rotas\napp.include_router(oauth_router)\napp.include_router(ghl_webhook_router)\napp.include_router(zapi_webhook_router)\napp.include_router(admin_router)\napp.include_router(admin_ai_agent_router)\n\n\n# Montagem de arquivos estáticos\napp.mount(\"/static\", StaticFiles(directory=\"web/static\"), name=\"static\")\n\n@app.get(\"/favicon.ico\", include_in_schema=False)\nasync def favicon():\n    return FileResponse(\"web/static/favicon.svg\", media_type=\"image/svg+xml\")\n\n@app.get(\"/\", tags=[\"Health\"])\nasync def root():\n    # Redireciona a raiz para o admin se acessada no navegador\n    from fastapi.responses import RedirectResponse\n    return RedirectResponse(url=\"/admin/dashboard\", status_code=303)\n\n\n@app.get(\"/health\", tags=[\"Health\"])\nasync def health_check():\n    \"\"\"Retorna estado do servidor e os tenants ativos.\"\"\"\n    tenants = token_manager.get_all_tenants()\n    active_tenants = []\n    \n    for t in tenants:\n        active_tenants.append({\n            \"company\": t.company_name,\n            \"location_id\": t.location_id,\n            \"token_valid\": not t.is_token_expired,\n            \"zapi_configured\": bool(t.zapi_instance_id and t.zapi_token),\n            \"zapi_instance_id\": t.zapi_instance_id\n        })\n        \n    return {\n        \"status\": \"healthy\",\n        \"tenants_loaded\": len(tenants),\n        \"tenants\": active_tenants\n    }\n\n\nif __name__ == \"__main__\":\n    logger.info(f\"Starting uvicorn server on {settings.host}:{settings.port}...\")\n    uvicorn.run(\"main:app\", host=settings.host, port=settings.port, reload=True)\n","numLines":134,"startLine":1,"totalLines":134}}}
