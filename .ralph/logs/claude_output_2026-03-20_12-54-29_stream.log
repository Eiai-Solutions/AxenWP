x: postgresql://...)\"\n    )\n\n    # Servidor\n    host: str = Field(default=\"0.0.0.0\")\n    port: int = Field(default=8000)\n\n    # Segurança\n    zapi_webhook_secret: str = Field(\n        default=\"\", description=\"Token para validar webhooks do Z-API\"\n    )\n\n    # Logs\n    log_level: str = Field(default=\"INFO\")\n\n    # GHL API Base\n    ghl_api_base: str = Field(\n        default=\"https://services.leadconnectorhq.com\",\n        description=\"Base URL da API GHL\",\n    )\n\n    class Config:\n        env_file = \".env\"\n        env_file_encoding = \"utf-8\"\n\n\n# Instância global\nsettings = Settings()\n","structuredPatch":[{"oldStart":33,"oldLines":6,"newStart":33,"newLines":11,"lines":["     zapi_webhook_secret: str = Field(","         default=\"\", description=\"Token para validar webhooks do Z-API\"","     )","+    allowed_origins: str = Field(","+        default=\"\",","+        description=\"Origens permitidas para CORS (separadas por virgula). Ex: https://app.example.com,https://admin.example.com\"","+    )","+    debug: bool = Field(default=False, description=\"Modo debug (habilita reload, CORS permissivo, etc.)\")"," ","     # Logs","     log_level: str = Field(default=\"INFO\")"]}],"userModified":false,"replaceAll":false}}
