# ===========================
# GoHighLevel App (Marketplace)
# ===========================
GHL_CLIENT_ID=6927146f81129...
GHL_CLIENT_SECRET=your-client-secret-here
GHL_REDIRECT_URI=https://seu-servidor.com/oauth/callback

# Conversation Provider ID (do app Axen WP)
GHL_CONVERSATION_PROVIDER_ID=your-provider-id-here

# ===========================
# Servidor
# ===========================
HOST=0.0.0.0
PORT=8000

# ===========================
# Segurança
# ===========================
# Token secreto para validar webhooks do Z-API (opcional, mas recomendado)
ZAPI_WEBHOOK_SECRET=um-token-secreto-qualquer

# ===========================
# Logs
# ===========================
LOG_LEVEL=INFO
